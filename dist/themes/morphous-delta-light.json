    "statusBar.background": "#faf7f2",
    "statusBar.foreground": "#0a4f55",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#faf7f2",
    "titleBar.activeBackground": "#faf7f2",
    "titleBar.activeForeground": "#0a4f55",
    "titleBar.inactiveBackground": "#faf7f2",
    "titleBar.inactiveForeground": "#0a4f5560",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#e6dcc3aa",
    "tab.activeBackground": "#faf7f2",
    "tab.activeForeground": "#0a4f55",
    "tab.inactiveBackground": "#faf7f260",
    "tab.inactiveForeground": "#0a4f5580",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#118e97",
    "list.activeSelectionBackground": "#118e9730",
