    "activityBar.inactiveForeground": "#20281860",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#7f8446",
    "activityBarBadge.foreground": "#f4f1e4",
    "statusBar.background": "#f4f1e4",
    "statusBar.foreground": "#202818",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#f4f1e4",
    "titleBar.activeBackground": "#f4f1e4",
    "titleBar.activeForeground": "#202818",
    "titleBar.inactiveBackground": "#f4f1e4",
    "titleBar.inactiveForeground": "#20281860",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#ded8bdaa",
    "tab.activeBackground": "#f4f1e4",
    "tab.activeForeground": "#202818",
    "tab.inactiveBackground": "#f4f1e460",
    "tab.inactiveForeground": "#20281880",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#7f8446",
    "list.activeSelectionBackground": "#7f844630",
    "list.activeSelectionForeground": "#202818",
    "list.hoverBackground": "#ded8bd40",
    "list.hoverForeground": "#202818",
    "list.inactiveSelectionBackground": "#7f844615",
    "list.inactiveSelectionForeground": "#202818",
    "list.highlightForeground": "#7f8446",
    "terminal.background": "#f4f1e4",
    "terminal.foreground": "#202818",
    "terminal.ansiBlack": "#202818",
    "terminal.ansiRed": "#a88753",
    "terminal.ansiGreen": "#7f8446",
    "terminal.ansiYellow": "#b2b878",
    "terminal.ansiBlue": "#8a6f48",
    "terminal.ansiMagenta": "#a88753",
    "terminal.ansiCyan": "#b2b878",
    "terminal.ansiWhite": "#202818",
    "input.background": "#ded8bd",
    "input.foreground": "#202818",
    "input.border": "#00000015",
    "input.placeholderForeground": "#20281860",
    "button.background": "#7f8446",
    "button.foreground": "#f4f1e4",
    "button.hoverBackground": "#7f8446dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#b8b58a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#8a6f48",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8a6f48",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7f8446"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#b2b878"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#a88753"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#202818"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#202818"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#202818dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#20281880"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#202818"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#b2b878",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#7f8446"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#8a6f48"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7f8446"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#b8b58a"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#a88753"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#7f8446"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#b2b878"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#7f8446",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#b2b878"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#7f8446"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#b8b58a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#8a6f48"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#b8b58a",
        "fontStyle": "italic"
      }
    }
  ]
}
