    "terminal.ansiRed": "#98AC78",
    "terminal.ansiGreen": "#7B4A2E",
    "terminal.ansiYellow": "#687F4E",
    "terminal.ansiBlue": "#9B6A45",
    "terminal.ansiMagenta": "#98AC78",
    "terminal.ansiCyan": "#687F4E",
    "terminal.ansiWhite": "#2E2418",
