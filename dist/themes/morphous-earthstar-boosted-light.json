    "terminal.ansiYellow": "#A37429",
    "terminal.ansiBlue": "#835621",
    "terminal.ansiMagenta": "#765219",
    "terminal.ansiCyan": "#A37429",
    "terminal.ansiWhite": "#1F1913",
