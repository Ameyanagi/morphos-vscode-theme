{
  "name": "Morphous Magpie - Boosted (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#67E9D6",
    "foreground": "#ffffff",
    "widget.border": "#ffffff15",
    "selection.background": "#79AFEC35",
    "editor.background": "#353A40",
    "editor.foreground": "#ffffff",
    "editor.lineHighlightBackground": "#080C0C40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#67E9D6",
    "editor.selectionBackground": "#79AFEC35",
    "editor.inactiveSelectionBackground": "#79AFEC3580",
    "editorLineNumber.foreground": "#77a08a80",
    "editorLineNumber.activeForeground": "#67E9D6",
    "sideBar.background": "#080C0C",
    "sideBar.foreground": "#ffffff",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#353A4080",
    "sideBarSectionHeader.foreground": "#ffffff",
    "sideBarTitle.foreground": "#67E9D6",
    "activityBar.background": "#353A40",
    "activityBar.foreground": "#67E9D6",
    "activityBar.inactiveForeground": "#ffffff60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#67E9D6",
    "activityBarBadge.foreground": "#353A40",
    "statusBar.background": "#353A40",
    "statusBar.foreground": "#ffffff",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#353A40",
    "titleBar.activeBackground": "#353A40",
    "titleBar.activeForeground": "#ffffff",
    "titleBar.inactiveBackground": "#353A40",
    "titleBar.inactiveForeground": "#ffffff60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#353A40dd",
    "tab.activeBackground": "#353A40",
    "tab.activeForeground": "#ffffff",
    "tab.inactiveBackground": "#080C0C60",
    "tab.inactiveForeground": "#ffffff80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#67E9D6",
    "list.activeSelectionBackground": "#67E9D630",
    "list.activeSelectionForeground": "#ffffff",
    "list.hoverBackground": "#080C0C40",
    "list.hoverForeground": "#ffffff",
    "list.inactiveSelectionBackground": "#67E9D615",
    "list.inactiveSelectionForeground": "#ffffff",
    "list.highlightForeground": "#67E9D6",
    "terminal.background": "#353A40",
    "terminal.foreground": "#ffffff",
    "terminal.ansiBlack": "#353A40",
    "terminal.ansiRed": "#83AAF1",
    "terminal.ansiGreen": "#67E9D6",
    "terminal.ansiYellow": "#55E79E",
    "terminal.ansiBlue": "#79AFEC",
    "terminal.ansiMagenta": "#83AAF1",
    "terminal.ansiCyan": "#55E79E",
    "terminal.ansiWhite": "#ffffff",
    "input.background": "#080C0C",
    "input.foreground": "#ffffff",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#ffffff60",
    "button.background": "#67E9D6",
    "button.foreground": "#353A40",
    "button.hoverBackground": "#67E9D6dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#77a08a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#79AFEC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#79AFEC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#67E9D6"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#55E79E"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#83AAF1"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#ffffffdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#ffffff80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#55E79E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#67E9D6"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#79AFEC"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#67E9D6"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#77a08a"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#83AAF1"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#67E9D6"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#55E79E"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#67E9D6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#55E79E"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#67E9D6"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#77a08a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79AFEC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#77a08a",
        "fontStyle": "italic"
      }
    }
  ]
}
