    "terminal.ansiGreen": "#E99D67",
    "terminal.ansiYellow": "#A5E755",
    "terminal.ansiBlue": "#ECBA79",
    "terminal.ansiMagenta": "#F1CB83",
    "terminal.ansiCyan": "#A5E755",
    "terminal.ansiWhite": "#eee1c7",
