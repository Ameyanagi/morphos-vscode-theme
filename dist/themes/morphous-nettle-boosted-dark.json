    "terminal.ansiRed": "#83F189",
    "terminal.ansiGreen": "#67E9A6",
    "terminal.ansiYellow": "#C2E755",
    "terminal.ansiBlue": "#79EC9C",
    "terminal.ansiMagenta": "#83F189",
    "terminal.ansiCyan": "#C2E755",
    "terminal.ansiWhite": "#F8FBF8",
