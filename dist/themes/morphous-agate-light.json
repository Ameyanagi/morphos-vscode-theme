    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#25201b"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
