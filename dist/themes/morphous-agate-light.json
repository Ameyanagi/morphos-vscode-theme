      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#7b563f"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#e8dbc4"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#7b563f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#e8dbc4"
      }
