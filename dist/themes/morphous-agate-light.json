        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#e8dbc4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#7b563f"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#6f8fa7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7b563f"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
