      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#49606f",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6f8fa7"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#49606f",
        "fontStyle": "italic"
      }
    }
