    "terminal.foreground": "#F3F7FA",
    "terminal.ansiBlack": "#040A11",
    "terminal.ansiRed": "#83A4F1",
    "terminal.ansiGreen": "#67B1E9",
    "terminal.ansiYellow": "#55C7E7",
    "terminal.ansiBlue": "#ECBE79",
    "terminal.ansiMagenta": "#83A4F1",
    "terminal.ansiCyan": "#55C7E7",
    "terminal.ansiWhite": "#F3F7FA",
    "input.background": "#08121B",
    "input.foreground": "#F3F7FA",
    "input.border": "#ffffff15",
