    "titleBar.inactiveBackground": "#040A11",
    "titleBar.inactiveForeground": "#F3F7FA60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#040A11dd",
    "tab.activeBackground": "#040A11",
    "tab.activeForeground": "#F3F7FA",
    "tab.inactiveBackground": "#08121B60",
    "tab.inactiveForeground": "#F3F7FA80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#67B1E9",
    "list.activeSelectionBackground": "#67B1E930",
    "list.activeSelectionForeground": "#F3F7FA",
