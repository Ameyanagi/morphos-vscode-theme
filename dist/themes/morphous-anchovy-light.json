{
  "name": "Morphous Anchovy (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#4EA096",
    "foreground": "#1A2B2F",
    "widget.border": "#00000015",
    "selection.background": "#D2D7DB25",
    "editor.background": "#F7FAFA",
    "editor.foreground": "#1A2B2F",
    "editor.lineHighlightBackground": "#EEF3F350",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#4EA096",
    "editor.selectionBackground": "#D2D7DB25",
    "editor.inactiveSelectionBackground": "#D2D7DB2580",
    "editorLineNumber.foreground": "#B8C3C780",
    "editorLineNumber.activeForeground": "#4EA096",
    "sideBar.background": "#EEF3F3",
    "sideBar.foreground": "#1A2B2F",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#EEF3F380",
    "sideBarSectionHeader.foreground": "#1A2B2F",
    "sideBarTitle.foreground": "#4EA096",
    "activityBar.background": "#F7FAFA",
    "activityBar.foreground": "#4EA096",
    "activityBar.inactiveForeground": "#1A2B2F60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#4EA096",
    "activityBarBadge.foreground": "#F7FAFA",
    "statusBar.background": "#F7FAFA",
    "statusBar.foreground": "#1A2B2F",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7FAFA",
    "titleBar.activeBackground": "#F7FAFA",
    "titleBar.activeForeground": "#1A2B2F",
    "titleBar.inactiveBackground": "#F7FAFA",
    "titleBar.inactiveForeground": "#1A2B2F60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#EEF3F3aa",
    "tab.activeBackground": "#F7FAFA",
    "tab.activeForeground": "#1A2B2F",
    "tab.inactiveBackground": "#F7FAFA60",
    "tab.inactiveForeground": "#1A2B2F80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#4EA096",
    "list.activeSelectionBackground": "#4EA09630",
    "list.activeSelectionForeground": "#1A2B2F",
    "list.hoverBackground": "#EEF3F340",
    "list.hoverForeground": "#1A2B2F",
    "list.inactiveSelectionBackground": "#4EA09615",
    "list.inactiveSelectionForeground": "#1A2B2F",
    "list.highlightForeground": "#4EA096",
    "terminal.background": "#F7FAFA",
    "terminal.foreground": "#1A2B2F",
    "terminal.ansiBlack": "#1A2B2F",
    "terminal.ansiRed": "#E76D63",
    "terminal.ansiGreen": "#4EA096",
    "terminal.ansiYellow": "#7FB7B0",
    "terminal.ansiBlue": "#D2D7DB",
    "terminal.ansiMagenta": "#E76D63",
    "terminal.ansiCyan": "#7FB7B0",
    "terminal.ansiWhite": "#1A2B2F",
    "input.background": "#EEF3F3",
    "input.foreground": "#1A2B2F",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1A2B2F60",
    "button.background": "#4EA096",
    "button.foreground": "#F7FAFA",
    "button.hoverBackground": "#4EA096dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B8C3C7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#D2D7DB",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D2D7DB",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4EA096"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#7FB7B0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#E76D63"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1A2B2F"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1A2B2F"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1A2B2Fdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1A2B2F80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1A2B2F"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#7FB7B0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#4EA096"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#D2D7DB"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4EA096"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#B8C3C7"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#E76D63"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#4EA096"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#7FB7B0"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#4EA096",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#7FB7B0"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#4EA096"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#B8C3C7",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#D2D7DB"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#B8C3C7",
        "fontStyle": "italic"
      }
    }
  ]
}
