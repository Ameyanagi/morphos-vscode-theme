    "titleBar.inactiveBackground": "#f8f6ee",
    "titleBar.inactiveForeground": "#15151560",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#efebe2aa",
    "tab.activeBackground": "#f8f6ee",
