    "tab.inactiveBackground": "#f8f6ee60",
    "tab.inactiveForeground": "#15151580",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#d8232a",
    "list.activeSelectionBackground": "#d8232a30",
    "list.activeSelectionForeground": "#151515",
    "list.hoverBackground": "#efebe240",
