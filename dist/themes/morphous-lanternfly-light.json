    "statusBar.background": "#f8f6ee",
    "statusBar.foreground": "#151515",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#f8f6ee",
    "titleBar.activeBackground": "#f8f6ee",
