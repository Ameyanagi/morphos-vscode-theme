{
  "name": "Morphous Thundercloud (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#f5c400",
    "foreground": "#1f252d",
    "widget.border": "#00000015",
    "selection.background": "#59636f25",
    "editor.background": "#eef2f3",
    "editor.foreground": "#1f252d",
    "editor.lineHighlightBackground": "#d7dde150",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#f5c400",
    "editor.selectionBackground": "#59636f25",
    "editor.inactiveSelectionBackground": "#59636f2580",
    "editorLineNumber.foreground": "#9ba8b180",
    "editorLineNumber.activeForeground": "#f5c400",
    "sideBar.background": "#d7dde1",
    "sideBar.foreground": "#1f252d",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#d7dde180",
    "sideBarSectionHeader.foreground": "#1f252d",
    "sideBarTitle.foreground": "#f5c400",
    "activityBar.background": "#eef2f3",
    "activityBar.foreground": "#f5c400",
    "activityBar.inactiveForeground": "#1f252d60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#f5c400",
    "activityBarBadge.foreground": "#eef2f3",
    "statusBar.background": "#eef2f3",
    "statusBar.foreground": "#1f252d",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#eef2f3",
    "titleBar.activeBackground": "#eef2f3",
    "titleBar.activeForeground": "#1f252d",
    "titleBar.inactiveBackground": "#eef2f3",
    "titleBar.inactiveForeground": "#1f252d60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#d7dde1aa",
    "tab.activeBackground": "#eef2f3",
    "tab.activeForeground": "#1f252d",
    "tab.inactiveBackground": "#eef2f360",
    "tab.inactiveForeground": "#1f252d80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#f5c400",
    "list.activeSelectionBackground": "#f5c40030",
    "list.activeSelectionForeground": "#1f252d",
    "list.hoverBackground": "#d7dde140",
    "list.hoverForeground": "#1f252d",
    "list.inactiveSelectionBackground": "#f5c40015",
    "list.inactiveSelectionForeground": "#1f252d",
    "list.highlightForeground": "#f5c400",
    "terminal.background": "#eef2f3",
    "terminal.foreground": "#1f252d",
    "terminal.ansiBlack": "#1f252d",
    "terminal.ansiRed": "#d99b12",
    "terminal.ansiGreen": "#f5c400",
    "terminal.ansiYellow": "#4f8aa8",
    "terminal.ansiBlue": "#59636f",
    "terminal.ansiMagenta": "#d99b12",
    "terminal.ansiCyan": "#4f8aa8",
    "terminal.ansiWhite": "#1f252d",
    "input.background": "#d7dde1",
    "input.foreground": "#1f252d",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1f252d60",
    "button.background": "#f5c400",
    "button.foreground": "#eef2f3",
    "button.hoverBackground": "#f5c400dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9ba8b1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#59636f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#59636f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#f5c400"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#4f8aa8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#d99b12"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1f252d"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1f252d"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1f252ddd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1f252d80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1f252d"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#4f8aa8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#f5c400"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#59636f"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f5c400"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9ba8b1"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#d99b12"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#f5c400"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#4f8aa8"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#f5c400",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#4f8aa8"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#f5c400"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9ba8b1",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#59636f"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9ba8b1",
        "fontStyle": "italic"
      }
    }
  ]
}
