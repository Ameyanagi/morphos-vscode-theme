    "activityBar.background": "#3D2B1F",
    "activityBar.foreground": "#E97067",
    "activityBar.inactiveForeground": "#F6F2E860",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E97067",
    "activityBarBadge.foreground": "#3D2B1F",
    "statusBar.background": "#3D2B1F",
    "statusBar.foreground": "#F6F2E8",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#3D2B1F",
    "titleBar.activeBackground": "#3D2B1F",
    "titleBar.activeForeground": "#F6F2E8",
    "titleBar.inactiveBackground": "#3D2B1F",
    "titleBar.inactiveForeground": "#F6F2E860",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#3D2B1Fdd",
    "tab.activeBackground": "#3D2B1F",
    "tab.activeForeground": "#F6F2E8",
    "tab.inactiveBackground": "#18181660",
    "tab.inactiveForeground": "#F6F2E880",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E97067",
    "list.activeSelectionBackground": "#E9706730",
    "list.activeSelectionForeground": "#F6F2E8",
    "list.hoverBackground": "#18181640",
    "list.hoverForeground": "#F6F2E8",
    "list.inactiveSelectionBackground": "#E9706715",
    "list.inactiveSelectionForeground": "#F6F2E8",
    "list.highlightForeground": "#E97067",
    "terminal.background": "#3D2B1F",
    "terminal.foreground": "#F6F2E8",
    "terminal.ansiBlack": "#3D2B1F",
    "terminal.ansiRed": "#AFF183",
    "terminal.ansiGreen": "#E97067",
    "terminal.ansiYellow": "#69E755",
    "terminal.ansiBlue": "#EC7D79",
    "terminal.ansiMagenta": "#AFF183",
    "terminal.ansiCyan": "#69E755",
    "terminal.ansiWhite": "#F6F2E8",
    "input.background": "#181816",
    "input.foreground": "#F6F2E8",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F6F2E860",
    "button.background": "#E97067",
    "button.foreground": "#3D2B1F",
    "button.hoverBackground": "#E97067dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A5A3E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#EC7D79",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#EC7D79",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E97067"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#69E755"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#AFF183"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F6F2E8"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F6F2E8"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F6F2E8dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F6F2E880"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F6F2E8"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#69E755",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E97067"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#EC7D79"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E97067"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#7A5A3E"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#AFF183"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E97067"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#69E755"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E97067",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#69E755"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E97067"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7A5A3E",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#EC7D79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7A5A3E",
        "fontStyle": "italic"
      }
    }
  ]
}
