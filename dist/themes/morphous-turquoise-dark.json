    "activityBarBadge.foreground": "#4a3020",
    "statusBar.background": "#4a3020",
    "statusBar.foreground": "#fbf8ef",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#4a3020",
    "titleBar.activeBackground": "#4a3020",
    "titleBar.activeForeground": "#fbf8ef",
    "titleBar.inactiveBackground": "#4a3020",
    "titleBar.inactiveForeground": "#fbf8ef60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#4a3020dd",
    "tab.activeBackground": "#4a3020",
    "tab.activeForeground": "#fbf8ef",
    "tab.inactiveBackground": "#23211c60",
    "tab.inactiveForeground": "#fbf8ef80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#1aa6a8",
    "list.activeSelectionBackground": "#1aa6a830",
    "list.activeSelectionForeground": "#fbf8ef",
    "list.hoverBackground": "#23211c40",
