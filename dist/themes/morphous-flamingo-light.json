{
  "name": "Morphous Flamingo (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#f06a8a",
    "foreground": "#2c2224",
    "widget.border": "#00000015",
    "selection.background": "#ff7b6525",
    "editor.background": "#fff7f2",
    "editor.foreground": "#2c2224",
    "editor.lineHighlightBackground": "#f7ebe550",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#f06a8a",
    "editor.selectionBackground": "#ff7b6525",
    "editor.inactiveSelectionBackground": "#ff7b652580",
    "editorLineNumber.foreground": "#9b837480",
    "editorLineNumber.activeForeground": "#f06a8a",
    "sideBar.background": "#f7ebe5",
    "sideBar.foreground": "#2c2224",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#f7ebe580",
    "sideBarSectionHeader.foreground": "#2c2224",
    "sideBarTitle.foreground": "#f06a8a",
    "activityBar.background": "#fff7f2",
    "activityBar.foreground": "#f06a8a",
    "activityBar.inactiveForeground": "#2c222460",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#f06a8a",
    "activityBarBadge.foreground": "#fff7f2",
    "statusBar.background": "#fff7f2",
    "statusBar.foreground": "#2c2224",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#fff7f2",
    "titleBar.activeBackground": "#fff7f2",
    "titleBar.activeForeground": "#2c2224",
    "titleBar.inactiveBackground": "#fff7f2",
    "titleBar.inactiveForeground": "#2c222460",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#f7ebe5aa",
    "tab.activeBackground": "#fff7f2",
    "tab.activeForeground": "#2c2224",
    "tab.inactiveBackground": "#fff7f260",
    "tab.inactiveForeground": "#2c222480",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#f06a8a",
    "list.activeSelectionBackground": "#f06a8a30",
    "list.activeSelectionForeground": "#2c2224",
    "list.hoverBackground": "#f7ebe540",
    "list.hoverForeground": "#2c2224",
    "list.inactiveSelectionBackground": "#f06a8a15",
    "list.inactiveSelectionForeground": "#2c2224",
    "list.highlightForeground": "#f06a8a",
    "terminal.background": "#fff7f2",
    "terminal.foreground": "#2c2224",
    "terminal.ansiBlack": "#2c2224",
    "terminal.ansiRed": "#f8b9ad",
    "terminal.ansiGreen": "#f06a8a",
    "terminal.ansiYellow": "#5baec4",
    "terminal.ansiBlue": "#ff7b65",
    "terminal.ansiMagenta": "#f8b9ad",
    "terminal.ansiCyan": "#5baec4",
    "terminal.ansiWhite": "#2c2224",
    "input.background": "#f7ebe5",
    "input.foreground": "#2c2224",
    "input.border": "#00000015",
    "input.placeholderForeground": "#2c222460",
    "button.background": "#f06a8a",
    "button.foreground": "#fff7f2",
    "button.hoverBackground": "#f06a8add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9b8374",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#ff7b65",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff7b65",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#f06a8a"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#5baec4"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#f8b9ad"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#2c2224"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#2c2224"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#2c2224dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2c222480"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#2c2224"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#5baec4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#f06a8a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff7b65"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f06a8a"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9b8374"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#f8b9ad"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#f06a8a"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#5baec4"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#f06a8a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#5baec4"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#f06a8a"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9b8374",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ff7b65"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9b8374",
        "fontStyle": "italic"
      }
    }
  ]
}
