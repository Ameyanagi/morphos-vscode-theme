    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F9F1FE80",
    "sideBarSectionHeader.foreground": "#101827",
    "sideBarTitle.foreground": "#582593",
    "activityBar.background": "#FBFDFE",
