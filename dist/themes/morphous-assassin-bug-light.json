    "statusBar.background": "#FAFAFA",
    "statusBar.foreground": "#F7F2F2",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FAFAFA",
    "titleBar.activeBackground": "#FAFAFA",
