    "terminal.ansiRed": "#567a42",
    "terminal.ansiGreen": "#653256",
    "terminal.ansiYellow": "#d8a85b",
    "terminal.ansiBlue": "#c86f7a",
    "terminal.ansiMagenta": "#567a42",
    "terminal.ansiCyan": "#d8a85b",
    "terminal.ansiWhite": "#22131d",
