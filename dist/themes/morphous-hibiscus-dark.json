    "selection.background": "#0F3D2235",
    "editor.background": "#0A1A12",
    "editor.foreground": "#FFF1E6",
    "editor.lineHighlightBackground": "#0A1A1240",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#E11D2E",
    "editor.selectionBackground": "#0F3D2235",
    "editor.inactiveSelectionBackground": "#0F3D223580",
    "editorLineNumber.foreground": "#7D9A7280",
    "editorLineNumber.activeForeground": "#E11D2E",
    "sideBar.background": "#0A1A12",
    "sideBar.foreground": "#FFF1E6",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#0A1A1280",
    "sideBarSectionHeader.foreground": "#FFF1E6",
    "sideBarTitle.foreground": "#E11D2E",
    "activityBar.background": "#0A1A12",
    "activityBar.foreground": "#E11D2E",
    "activityBar.inactiveForeground": "#FFF1E660",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E11D2E",
    "activityBarBadge.foreground": "#0A1A12",
    "statusBar.background": "#0A1A12",
    "statusBar.foreground": "#FFF1E6",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#0A1A12",
    "titleBar.activeBackground": "#0A1A12",
    "titleBar.activeForeground": "#FFF1E6",
    "titleBar.inactiveBackground": "#0A1A12",
    "titleBar.inactiveForeground": "#FFF1E660",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#0A1A12dd",
    "tab.activeBackground": "#0A1A12",
    "tab.activeForeground": "#FFF1E6",
    "tab.inactiveBackground": "#0A1A1260",
    "tab.inactiveForeground": "#FFF1E680",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E11D2E",
    "list.activeSelectionBackground": "#E11D2E30",
    "list.activeSelectionForeground": "#FFF1E6",
    "list.hoverBackground": "#0A1A1240",
    "list.hoverForeground": "#FFF1E6",
    "list.inactiveSelectionBackground": "#E11D2E15",
    "list.inactiveSelectionForeground": "#FFF1E6",
    "list.highlightForeground": "#E11D2E",
    "terminal.background": "#0A1A12",
    "terminal.foreground": "#FFF1E6",
    "terminal.ansiBlack": "#0A1A12",
    "terminal.ansiRed": "#FF6B4D",
    "terminal.ansiGreen": "#E11D2E",
    "terminal.ansiYellow": "#FFC904",
    "terminal.ansiBlue": "#0F3D22",
    "terminal.ansiMagenta": "#FF6B4D",
    "terminal.ansiCyan": "#FFC904",
    "terminal.ansiWhite": "#FFF1E6",
    "input.background": "#0A1A12",
    "input.foreground": "#FFF1E6",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#FFF1E660",
    "button.background": "#E11D2E",
    "button.foreground": "#0A1A12",
    "button.hoverBackground": "#E11D2Edd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7D9A72",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#0F3D22",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#0F3D22",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E11D2E"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#FFC904"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#FF6B4D"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#FFF1E6"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#FFF1E6"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFF1E6dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#FFF1E680"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FFF1E6"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#FFC904",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E11D2E"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#0F3D22"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E11D2E"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#7D9A72"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#FF6B4D"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E11D2E"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#FFC904"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E11D2E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#FFC904"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E11D2E"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7D9A72",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#0F3D22"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7D9A72",
        "fontStyle": "italic"
      }
    }
  ]
}
