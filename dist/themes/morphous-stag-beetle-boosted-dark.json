      "settings": {
        "foreground": "#F18783"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E97D67"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E75A55"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E97D67",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E75A55"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E97D67"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9c8974",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECC079"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9c8974",
        "fontStyle": "italic"
      }
    }
