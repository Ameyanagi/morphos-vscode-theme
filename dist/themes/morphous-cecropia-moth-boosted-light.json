      ],
      "settings": {
        "foreground": "#933B25"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#6B4A3A",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#834121"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#6B4A3A",
        "fontStyle": "italic"
      }
    }
