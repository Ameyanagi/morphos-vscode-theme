        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A36E29",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#933B25"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#834121"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#933B25"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
