    "activityBar.inactiveForeground": "#ead5ad60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E9A267",
    "activityBarBadge.foreground": "#3D2315",
    "statusBar.background": "#3D2315",
    "statusBar.foreground": "#ead5ad",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#3D2315",
    "titleBar.activeBackground": "#3D2315",
    "titleBar.activeForeground": "#ead5ad",
    "titleBar.inactiveBackground": "#3D2315",
    "titleBar.inactiveForeground": "#ead5ad60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#3D2315dd",
    "tab.activeBackground": "#3D2315",
    "tab.activeForeground": "#ead5ad",
    "tab.inactiveBackground": "#0C0A0860",
    "tab.inactiveForeground": "#ead5ad80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E9A267",
    "list.activeSelectionBackground": "#E9A26730",
    "list.activeSelectionForeground": "#ead5ad",
    "list.hoverBackground": "#0C0A0840",
    "list.hoverForeground": "#ead5ad",
    "list.inactiveSelectionBackground": "#E9A26715",
    "list.inactiveSelectionForeground": "#ead5ad",
    "list.highlightForeground": "#E9A267",
    "terminal.background": "#3D2315",
    "terminal.foreground": "#ead5ad",
    "terminal.ansiBlack": "#3D2315",
    "terminal.ansiRed": "#F1CB83",
    "terminal.ansiGreen": "#E9A267",
    "terminal.ansiYellow": "#E7AF55",
    "terminal.ansiBlue": "#DDEC79",
    "terminal.ansiMagenta": "#F1CB83",
    "terminal.ansiCyan": "#E7AF55",
    "terminal.ansiWhite": "#ead5ad",
    "input.background": "#0C0A08",
    "input.foreground": "#ead5ad",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#ead5ad60",
    "button.background": "#E9A267",
    "button.foreground": "#3D2315",
    "button.hoverBackground": "#E9A267dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7b6652",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#DDEC79",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#DDEC79",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E9A267"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#E7AF55"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F1CB83"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#ead5ad"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#ead5ad"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#ead5addd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#ead5ad80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#ead5ad"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#E7AF55",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E9A267"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#DDEC79"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E9A267"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#7b6652"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F1CB83"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E9A267"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E7AF55"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E9A267",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E7AF55"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E9A267"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7b6652",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#DDEC79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7b6652",
        "fontStyle": "italic"
      }
    }
  ]
}
