    "terminal.ansiRed": "#764919",
    "terminal.ansiGreen": "#7D9325",
    "terminal.ansiYellow": "#64A329",
    "terminal.ansiBlue": "#834D21",
    "terminal.ansiMagenta": "#764919",
    "terminal.ansiCyan": "#64A329",
    "terminal.ansiWhite": "#342617",
