    "terminal.ansiRed": "#2F5C35",
    "terminal.ansiGreen": "#A9472F",
    "terminal.ansiYellow": "#5E7D35",
    "terminal.ansiBlue": "#7F2F26",
    "terminal.ansiMagenta": "#2F5C35",
    "terminal.ansiCyan": "#5E7D35",
    "terminal.ansiWhite": "#1F2A1C",
