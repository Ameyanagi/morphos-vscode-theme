{
  "name": "Morphous Kelp Forest (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#5F6F2F",
    "foreground": "#0D1821",
    "widget.border": "#00000015",
    "selection.background": "#2F6D8A25",
    "editor.background": "#F2F6F4",
    "editor.foreground": "#0D1821",
    "editor.lineHighlightBackground": "#FFFFFF50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#5F6F2F",
    "editor.selectionBackground": "#2F6D8A25",
    "editor.inactiveSelectionBackground": "#2F6D8A2580",
    "editorLineNumber.foreground": "#D0E6E180",
    "editorLineNumber.activeForeground": "#5F6F2F",
    "sideBar.background": "#FFFFFF",
    "sideBar.foreground": "#0D1821",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFFFFF80",
    "sideBarSectionHeader.foreground": "#0D1821",
    "sideBarTitle.foreground": "#5F6F2F",
    "activityBar.background": "#F2F6F4",
    "activityBar.foreground": "#5F6F2F",
    "activityBar.inactiveForeground": "#0D182160",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#5F6F2F",
    "activityBarBadge.foreground": "#F2F6F4",
    "statusBar.background": "#F2F6F4",
    "statusBar.foreground": "#0D1821",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F2F6F4",
    "titleBar.activeBackground": "#F2F6F4",
    "titleBar.activeForeground": "#0D1821",
    "titleBar.inactiveBackground": "#F2F6F4",
    "titleBar.inactiveForeground": "#0D182160",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFFFFaa",
    "tab.activeBackground": "#F2F6F4",
    "tab.activeForeground": "#0D1821",
    "tab.inactiveBackground": "#F2F6F460",
    "tab.inactiveForeground": "#0D182180",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#5F6F2F",
    "list.activeSelectionBackground": "#5F6F2F30",
    "list.activeSelectionForeground": "#0D1821",
    "list.hoverBackground": "#FFFFFF40",
    "list.hoverForeground": "#0D1821",
    "list.inactiveSelectionBackground": "#5F6F2F15",
    "list.inactiveSelectionForeground": "#0D1821",
    "list.highlightForeground": "#5F6F2F",
    "terminal.background": "#F2F6F4",
    "terminal.foreground": "#0D1821",
    "terminal.ansiBlack": "#0D1821",
    "terminal.ansiRed": "#4C7F6C",
    "terminal.ansiGreen": "#5F6F2F",
    "terminal.ansiYellow": "#D78A1A",
    "terminal.ansiBlue": "#2F6D8A",
    "terminal.ansiMagenta": "#4C7F6C",
    "terminal.ansiCyan": "#D78A1A",
    "terminal.ansiWhite": "#0D1821",
    "input.background": "#FFFFFF",
    "input.foreground": "#0D1821",
    "input.border": "#00000015",
    "input.placeholderForeground": "#0D182160",
    "button.background": "#5F6F2F",
    "button.foreground": "#F2F6F4",
    "button.hoverBackground": "#5F6F2Fdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D0E6E1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#2F6D8A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#2F6D8A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#5F6F2F"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#D78A1A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#4C7F6C"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#0D1821"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#0D1821"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#0D1821dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#0D182180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#0D1821"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#D78A1A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#5F6F2F"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#2F6D8A"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#5F6F2F"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D0E6E1"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#4C7F6C"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#5F6F2F"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#D78A1A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#5F6F2F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D78A1A"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#5F6F2F"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D0E6E1",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#2F6D8A"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D0E6E1",
        "fontStyle": "italic"
      }
    }
  ]
}
