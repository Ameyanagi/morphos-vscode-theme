    "terminal.ansiYellow": "#55CFE7",
    "terminal.ansiBlue": "#C2EC79",
    "terminal.ansiMagenta": "#F1CB83",
    "terminal.ansiCyan": "#55CFE7",
    "terminal.ansiWhite": "#f7f4ec",
