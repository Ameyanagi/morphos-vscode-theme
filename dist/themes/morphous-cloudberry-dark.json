    "terminal.ansiGreen": "#F4A618",
    "terminal.ansiYellow": "#6A8F5A",
    "terminal.ansiBlue": "#FFC56A",
    "terminal.ansiMagenta": "#8BAE68",
    "terminal.ansiCyan": "#6A8F5A",
    "terminal.ansiWhite": "#fbf4df",
