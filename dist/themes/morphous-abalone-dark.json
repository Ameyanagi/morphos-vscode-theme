    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9BA8AA",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6ED1C5"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9BA8AA",
        "fontStyle": "italic"
      }
