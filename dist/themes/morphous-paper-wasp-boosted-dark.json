    "widget.border": "#ffffff15",
    "selection.background": "#9CEC7935",
    "editor.background": "#3A2413",
    "editor.foreground": "#FAF9F6",
    "editor.lineHighlightBackground": "#0B0B0A40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#E9BE67",
    "editor.selectionBackground": "#9CEC7935",
    "editor.inactiveSelectionBackground": "#9CEC793580",
    "editorLineNumber.foreground": "#C8C6BD80",
    "editorLineNumber.activeForeground": "#E9BE67",
    "sideBar.background": "#0B0B0A",
    "sideBar.foreground": "#FAF9F6",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#3A241380",
