    "sideBarTitle.foreground": "#E9BE67",
    "activityBar.background": "#3A2413",
    "activityBar.foreground": "#E9BE67",
    "activityBar.inactiveForeground": "#FAF9F660",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E9BE67",
    "activityBarBadge.foreground": "#3A2413",
    "statusBar.background": "#3A2413",
    "statusBar.foreground": "#FAF9F6",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#3A2413",
    "titleBar.activeBackground": "#3A2413",
    "titleBar.activeForeground": "#FAF9F6",
    "titleBar.inactiveBackground": "#3A2413",
    "titleBar.inactiveForeground": "#FAF9F660",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#3A2413dd",
    "tab.activeBackground": "#3A2413",
    "tab.activeForeground": "#FAF9F6",
    "tab.inactiveBackground": "#0B0B0A60",
    "tab.inactiveForeground": "#FAF9F680",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E9BE67",
    "list.activeSelectionBackground": "#E9BE6730",
    "list.activeSelectionForeground": "#FAF9F6",
    "list.hoverBackground": "#0B0B0A40",
    "list.hoverForeground": "#FAF9F6",
    "list.inactiveSelectionBackground": "#E9BE6715",
    "list.inactiveSelectionForeground": "#FAF9F6",
    "list.highlightForeground": "#E9BE67",
    "terminal.background": "#3A2413",
    "terminal.foreground": "#FAF9F6",
    "terminal.ansiBlack": "#3A2413",
    "terminal.ansiRed": "#F1CD83",
    "terminal.ansiGreen": "#E9BE67",
    "terminal.ansiYellow": "#5594E7",
    "terminal.ansiBlue": "#9CEC79",
    "terminal.ansiMagenta": "#F1CD83",
    "terminal.ansiCyan": "#5594E7",
    "terminal.ansiWhite": "#FAF9F6",
    "input.background": "#0B0B0A",
    "input.foreground": "#FAF9F6",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#FAF9F660",
    "button.background": "#E9BE67",
    "button.foreground": "#3A2413",
    "button.hoverBackground": "#E9BE67dd"
