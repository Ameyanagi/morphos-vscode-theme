{
  "name": "Morphous Lionfish - Boosted (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#E96767",
    "foreground": "#FFF7F5",
    "widget.border": "#ffffff15",
    "selection.background": "#EC7F7935",
    "editor.background": "#390E12",
