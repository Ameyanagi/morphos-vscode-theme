    "terminal.ansiYellow": "#A3E755",
    "terminal.ansiBlue": "#ECAB79",
    "terminal.ansiMagenta": "#C7F183",
    "terminal.ansiCyan": "#A3E755",
    "terminal.ansiWhite": "#FBF7F1",
