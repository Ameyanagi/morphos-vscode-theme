    "terminal.ansiGreen": "#679BE9",
    "terminal.ansiYellow": "#55A3E7",
    "terminal.ansiBlue": "#79A9EC",
    "terminal.ansiMagenta": "#83ABF1",
    "terminal.ansiCyan": "#55A3E7",
    "terminal.ansiWhite": "#f7f9fc",
