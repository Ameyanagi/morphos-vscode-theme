    "terminal.ansiYellow": "#55E7D1",
    "terminal.ansiBlue": "#79BAEC",
    "terminal.ansiMagenta": "#83DFF1",
    "terminal.ansiCyan": "#55E7D1",
    "terminal.ansiWhite": "#F6FAFC",
