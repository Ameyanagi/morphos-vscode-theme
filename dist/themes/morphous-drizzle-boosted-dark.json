    "terminal.ansiRed": "#F1CB83",
    "terminal.ansiGreen": "#6EE967",
    "terminal.ansiYellow": "#55BBE7",
    "terminal.ansiBlue": "#79ECAB",
    "terminal.ansiMagenta": "#F1CB83",
    "terminal.ansiCyan": "#55BBE7",
    "terminal.ansiWhite": "#F0F2F1",
