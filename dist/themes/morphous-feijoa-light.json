{
  "name": "Morphous Feijoa (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#5E7F63",
    "foreground": "#232823",
    "widget.border": "#00000015",
    "selection.background": "#A7B6A825",
    "editor.background": "#FBFCFA",
    "editor.foreground": "#232823",
    "editor.lineHighlightBackground": "#F7F4EE50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#5E7F63",
    "editor.selectionBackground": "#A7B6A825",
    "editor.inactiveSelectionBackground": "#A7B6A82580",
    "editorLineNumber.foreground": "#E7ECE780",
    "editorLineNumber.activeForeground": "#5E7F63",
    "sideBar.background": "#F7F4EE",
    "sideBar.foreground": "#232823",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F7F4EE80",
    "sideBarSectionHeader.foreground": "#232823",
    "sideBarTitle.foreground": "#5E7F63",
    "activityBar.background": "#FBFCFA",
    "activityBar.foreground": "#5E7F63",
    "activityBar.inactiveForeground": "#23282360",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#5E7F63",
    "activityBarBadge.foreground": "#FBFCFA",
    "statusBar.background": "#FBFCFA",
    "statusBar.foreground": "#232823",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FBFCFA",
    "titleBar.activeBackground": "#FBFCFA",
    "titleBar.activeForeground": "#232823",
    "titleBar.inactiveBackground": "#FBFCFA",
    "titleBar.inactiveForeground": "#23282360",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F7F4EEaa",
    "tab.activeBackground": "#FBFCFA",
    "tab.activeForeground": "#232823",
    "tab.inactiveBackground": "#FBFCFA60",
    "tab.inactiveForeground": "#23282380",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#5E7F63",
    "list.activeSelectionBackground": "#5E7F6330",
    "list.activeSelectionForeground": "#232823",
    "list.hoverBackground": "#F7F4EE40",
    "list.hoverForeground": "#232823",
    "list.inactiveSelectionBackground": "#5E7F6315",
    "list.inactiveSelectionForeground": "#232823",
    "list.highlightForeground": "#5E7F63",
    "terminal.background": "#FBFCFA",
    "terminal.foreground": "#232823",
    "terminal.ansiBlack": "#232823",
    "terminal.ansiRed": "#C81D2E",
    "terminal.ansiGreen": "#5E7F63",
    "terminal.ansiYellow": "#7FAF78",
    "terminal.ansiBlue": "#A7B6A8",
    "terminal.ansiMagenta": "#C81D2E",
    "terminal.ansiCyan": "#7FAF78",
    "terminal.ansiWhite": "#232823",
    "input.background": "#F7F4EE",
    "input.foreground": "#232823",
    "input.border": "#00000015",
    "input.placeholderForeground": "#23282360",
    "button.background": "#5E7F63",
    "button.foreground": "#FBFCFA",
    "button.hoverBackground": "#5E7F63dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#E7ECE7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#A7B6A8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#A7B6A8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#5E7F63"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#7FAF78"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#C81D2E"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#232823"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#232823"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#232823dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#23282380"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#232823"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#7FAF78",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#5E7F63"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#A7B6A8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#5E7F63"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#E7ECE7"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#C81D2E"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#5E7F63"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#7FAF78"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#5E7F63",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#7FAF78"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#5E7F63"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E7ECE7",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#A7B6A8"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E7ECE7",
        "fontStyle": "italic"
      }
    }
  ]
}
