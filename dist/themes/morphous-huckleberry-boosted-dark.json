    "activityBar.inactiveForeground": "#E9EDF260",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#6797E9",
    "activityBarBadge.foreground": "#090C16",
    "statusBar.background": "#090C16",
    "statusBar.foreground": "#E9EDF2",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#090C16",
    "titleBar.activeBackground": "#090C16",
    "titleBar.activeForeground": "#E9EDF2",
    "titleBar.inactiveBackground": "#090C16",
    "titleBar.inactiveForeground": "#E9EDF260",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#090C16dd",
    "tab.activeBackground": "#090C16",
    "tab.activeForeground": "#E9EDF2",
    "tab.inactiveBackground": "#090C1660",
    "tab.inactiveForeground": "#E9EDF280",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#6797E9",
    "list.activeSelectionBackground": "#6797E930",
    "list.activeSelectionForeground": "#E9EDF2",
    "list.hoverBackground": "#090C1640",
    "list.hoverForeground": "#E9EDF2",
    "list.inactiveSelectionBackground": "#6797E915",
    "list.inactiveSelectionForeground": "#E9EDF2",
    "list.highlightForeground": "#6797E9",
    "terminal.background": "#090C16",
    "terminal.foreground": "#E9EDF2",
    "terminal.ansiBlack": "#090C16",
    "terminal.ansiRed": "#F19F83",
    "terminal.ansiGreen": "#6797E9",
    "terminal.ansiYellow": "#7FE755",
    "terminal.ansiBlue": "#79A1EC",
    "terminal.ansiMagenta": "#F19F83",
    "terminal.ansiCyan": "#7FE755",
    "terminal.ansiWhite": "#E9EDF2",
    "input.background": "#090C16",
    "input.foreground": "#E9EDF2",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#E9EDF260",
    "button.background": "#6797E9",
    "button.foreground": "#090C16",
    "button.hoverBackground": "#6797E9dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a3adb6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#79A1EC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#79A1EC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6797E9"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#7FE755"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F19F83"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#E9EDF2"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#E9EDF2"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#E9EDF2dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#E9EDF280"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#E9EDF2"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#7FE755",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#6797E9"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#79A1EC"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6797E9"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#a3adb6"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F19F83"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6797E9"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#7FE755"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6797E9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#7FE755"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#6797E9"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#a3adb6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79A1EC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#a3adb6",
        "fontStyle": "italic"
      }
    }
  ]
}
