    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#EF9A7A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8d7b70",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79533f"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8d7b70",
        "fontStyle": "italic"
      }
    }
