    "terminal.ansiRed": "#18a8d8",
    "terminal.ansiGreen": "#b6782b",
    "terminal.ansiYellow": "#0057b8",
    "terminal.ansiBlue": "#25282b",
    "terminal.ansiMagenta": "#18a8d8",
    "terminal.ansiCyan": "#0057b8",
    "terminal.ansiWhite": "#111316",
