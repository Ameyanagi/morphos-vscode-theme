    "terminal.ansiRed": "#9c78c2",
    "terminal.ansiGreen": "#7B5FE1",
    "terminal.ansiYellow": "#FFFFFF",
    "terminal.ansiBlue": "#B69AEF",
    "terminal.ansiMagenta": "#9c78c2",
    "terminal.ansiCyan": "#FFFFFF",
    "terminal.ansiWhite": "#FAFAFD",
    "input.background": "#1F1F28",
