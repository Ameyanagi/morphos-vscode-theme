      ],
      "settings": {
        "foreground": "#ECCF79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#4C5C33",
        "fontStyle": "italic"
      }
