    "activityBar.inactiveForeground": "#223b3860",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#259346",
    "activityBarBadge.foreground": "#F6F9F7",
    "statusBar.background": "#F6F9F7",
    "statusBar.foreground": "#223b38",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F6F9F7",
    "titleBar.activeBackground": "#F6F9F7",
    "titleBar.activeForeground": "#223b38",
    "titleBar.inactiveBackground": "#F6F9F7",
    "titleBar.inactiveForeground": "#223b3860",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F7F9F6aa",
    "tab.activeBackground": "#F6F9F7",
    "tab.activeForeground": "#223b38",
    "tab.inactiveBackground": "#F6F9F760",
    "tab.inactiveForeground": "#223b3880",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#259346",
    "list.activeSelectionBackground": "#25934630",
    "list.activeSelectionForeground": "#223b38",
    "list.hoverBackground": "#F7F9F640",
    "list.hoverForeground": "#223b38",
    "list.inactiveSelectionBackground": "#25934615",
    "list.inactiveSelectionForeground": "#223b38",
    "list.highlightForeground": "#259346",
    "terminal.background": "#F6F9F7",
    "terminal.foreground": "#223b38",
    "terminal.ansiBlack": "#223b38",
    "terminal.ansiRed": "#765519",
    "terminal.ansiGreen": "#259346",
    "terminal.ansiYellow": "#29A39F",
    "terminal.ansiBlue": "#5F8321",
    "terminal.ansiMagenta": "#765519",
    "terminal.ansiCyan": "#29A39F",
    "terminal.ansiWhite": "#223b38",
    "input.background": "#F7F9F6",
    "input.foreground": "#223b38",
    "input.border": "#00000015",
    "input.placeholderForeground": "#223b3860",
    "button.background": "#259346",
    "button.foreground": "#F6F9F7",
    "button.hoverBackground": "#259346dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a9b3ad",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#5F8321",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5F8321",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#259346"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#29A39F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#765519"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#223b38"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#223b38"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#223b38dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#223b3880"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#223b38"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#29A39F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#259346"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#5F8321"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#259346"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#a9b3ad"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#765519"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#259346"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#29A39F"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#259346",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#29A39F"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#259346"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#a9b3ad",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#5F8321"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#a9b3ad",
        "fontStyle": "italic"
      }
    }
  ]
}
