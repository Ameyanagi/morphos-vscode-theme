    "terminal.ansiGreen": "#259379",
    "terminal.ansiYellow": "#29A399",
    "terminal.ansiBlue": "#488321",
    "terminal.ansiMagenta": "#765219",
    "terminal.ansiCyan": "#29A399",
    "terminal.ansiWhite": "#152017",
