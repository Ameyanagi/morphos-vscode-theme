    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E9BA67",
    "list.activeSelectionBackground": "#E9BA6730",
    "list.activeSelectionForeground": "#FBF9F3",
    "list.hoverBackground": "#20201D40",
