    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#5C3F24dd",
    "tab.activeBackground": "#5C3F24",
    "tab.activeForeground": "#FBF9F3",
    "tab.inactiveBackground": "#20201D60",
