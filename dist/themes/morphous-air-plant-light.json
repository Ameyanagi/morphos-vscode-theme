    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1E2320"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
