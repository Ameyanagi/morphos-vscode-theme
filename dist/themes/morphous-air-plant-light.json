      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#7D9F76"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#D9C6DF"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#7D9F76",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D9C6DF"
      }
