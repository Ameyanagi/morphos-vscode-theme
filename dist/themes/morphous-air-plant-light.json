      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E6ECE8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#C7D0C8"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E6ECE8",
        "fontStyle": "italic"
      }
    }
