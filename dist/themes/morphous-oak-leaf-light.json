    "activityBar.inactiveForeground": "#0E241860",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#1F3D2E",
    "activityBarBadge.foreground": "#F4EEDD",
    "statusBar.background": "#F4EEDD",
    "statusBar.foreground": "#0E2418",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F4EEDD",
    "titleBar.activeBackground": "#F4EEDD",
    "titleBar.activeForeground": "#0E2418",
    "titleBar.inactiveBackground": "#F4EEDD",
    "titleBar.inactiveForeground": "#0E241860",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#DCC8A6aa",
    "tab.activeBackground": "#F4EEDD",
    "tab.activeForeground": "#0E2418",
    "tab.inactiveBackground": "#F4EEDD60",
    "tab.inactiveForeground": "#0E241880",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#1F3D2E",
    "list.activeSelectionBackground": "#1F3D2E30",
    "list.activeSelectionForeground": "#0E2418",
    "list.hoverBackground": "#DCC8A640",
