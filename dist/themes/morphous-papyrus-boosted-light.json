{
  "name": "Morphous Papyrus - Boosted (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#4F9325",
    "foreground": "#202621",
    "widget.border": "#00000015",
    "selection.background": "#83652125",
    "editor.background": "#F9F6EC",
    "editor.foreground": "#202621",
    "editor.lineHighlightBackground": "#FCFAF350",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#4F9325",
    "editor.selectionBackground": "#83652125",
    "editor.inactiveSelectionBackground": "#8365212580",
    "editorLineNumber.foreground": "#d7c89d80",
    "editorLineNumber.activeForeground": "#4F9325",
    "sideBar.background": "#FCFAF3",
    "sideBar.foreground": "#202621",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FCFAF380",
    "sideBarSectionHeader.foreground": "#202621",
    "sideBarTitle.foreground": "#4F9325",
    "activityBar.background": "#F9F6EC",
    "activityBar.foreground": "#4F9325",
    "activityBar.inactiveForeground": "#20262160",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#4F9325",
    "activityBarBadge.foreground": "#F9F6EC",
    "statusBar.background": "#F9F6EC",
    "statusBar.foreground": "#202621",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F9F6EC",
    "titleBar.activeBackground": "#F9F6EC",
    "titleBar.activeForeground": "#202621",
    "titleBar.inactiveBackground": "#F9F6EC",
    "titleBar.inactiveForeground": "#20262160",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FCFAF3aa",
    "tab.activeBackground": "#F9F6EC",
    "tab.activeForeground": "#202621",
    "tab.inactiveBackground": "#F9F6EC60",
    "tab.inactiveForeground": "#20262180",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#4F9325",
    "list.activeSelectionBackground": "#4F932530",
    "list.activeSelectionForeground": "#202621",
    "list.hoverBackground": "#FCFAF340",
    "list.hoverForeground": "#202621",
    "list.inactiveSelectionBackground": "#4F932515",
    "list.inactiveSelectionForeground": "#202621",
    "list.highlightForeground": "#4F9325",
    "terminal.background": "#F9F6EC",
    "terminal.foreground": "#202621",
    "terminal.ansiBlack": "#202621",
    "terminal.ansiRed": "#765C19",
    "terminal.ansiGreen": "#4F9325",
    "terminal.ansiYellow": "#29A39D",
    "terminal.ansiBlue": "#836521",
    "terminal.ansiMagenta": "#765C19",
    "terminal.ansiCyan": "#29A39D",
    "terminal.ansiWhite": "#202621",
    "input.background": "#FCFAF3",
    "input.foreground": "#202621",
    "input.border": "#00000015",
    "input.placeholderForeground": "#20262160",
    "button.background": "#4F9325",
    "button.foreground": "#F9F6EC",
    "button.hoverBackground": "#4F9325dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#d7c89d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#836521",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#836521",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4F9325"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#29A39D"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#765C19"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#202621"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#202621"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#202621dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#20262180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#202621"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#29A39D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#4F9325"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#836521"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4F9325"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#d7c89d"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#765C19"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#4F9325"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#29A39D"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#4F9325",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#29A39D"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#4F9325"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#d7c89d",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#836521"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#d7c89d",
        "fontStyle": "italic"
      }
    }
  ]
}
