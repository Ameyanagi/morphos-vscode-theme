  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#EDE6D6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#ECC679",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ECC679",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#67E9CD"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#E77555"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F1CD83"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F6F3EC"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F6F3EC"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F6F3ECdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F6F3EC80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F6F3EC"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#E77555",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#67E9CD"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ECC679"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#67E9CD"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#EDE6D6"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F1CD83"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#67E9CD"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E77555"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#67E9CD",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E77555"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#67E9CD"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#EDE6D6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECC679"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#EDE6D6",
        "fontStyle": "italic"
      }
    }
  ]
}
