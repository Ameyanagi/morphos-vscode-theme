    "tab.inactiveBackground": "#fff7ea60",
    "tab.inactiveForeground": "#26111680",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#D32F58",
    "list.activeSelectionBackground": "#D32F5830",
    "list.activeSelectionForeground": "#261116",
