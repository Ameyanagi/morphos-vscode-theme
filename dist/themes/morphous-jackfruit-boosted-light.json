    "activityBar.inactiveForeground": "#1b1a1760",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#937725",
    "activityBarBadge.foreground": "#FFFCF5",
    "statusBar.background": "#FFFCF5",
    "statusBar.foreground": "#1b1a17",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FFFCF5",
    "titleBar.activeBackground": "#FFFCF5",
    "titleBar.activeForeground": "#1b1a17",
    "titleBar.inactiveBackground": "#FFFCF5",
    "titleBar.inactiveForeground": "#1b1a1760",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F9F7F0aa",
    "tab.activeBackground": "#FFFCF5",
    "tab.activeForeground": "#1b1a17",
    "tab.inactiveBackground": "#FFFCF560",
    "tab.inactiveForeground": "#1b1a1780",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#937725",
    "list.activeSelectionBackground": "#93772530",
    "list.activeSelectionForeground": "#1b1a17",
    "list.hoverBackground": "#F9F7F040",
    "list.hoverForeground": "#1b1a17",
    "list.inactiveSelectionBackground": "#93772515",
    "list.inactiveSelectionForeground": "#1b1a17",
    "list.highlightForeground": "#937725",
    "terminal.background": "#FFFCF5",
    "terminal.foreground": "#1b1a17",
    "terminal.ansiBlack": "#1b1a17",
    "terminal.ansiRed": "#547619",
    "terminal.ansiGreen": "#937725",
    "terminal.ansiYellow": "#81A329",
    "terminal.ansiBlue": "#836521",
    "terminal.ansiMagenta": "#547619",
    "terminal.ansiCyan": "#81A329",
    "terminal.ansiWhite": "#1b1a17",
    "input.background": "#F9F7F0",
    "input.foreground": "#1b1a17",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1b1a1760",
    "button.background": "#937725",
    "button.foreground": "#FFFCF5",
    "button.hoverBackground": "#937725dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#e6e1d4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#836521",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#836521",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#81A329"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#547619"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1b1a17"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1b1a17"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1b1a17dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1b1a1780"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1b1a17"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#81A329",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#836521"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#e6e1d4"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#547619"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#81A329"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#937725",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#81A329"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#e6e1d4",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#836521"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#e6e1d4",
        "fontStyle": "italic"
      }
    }
  ]
}
