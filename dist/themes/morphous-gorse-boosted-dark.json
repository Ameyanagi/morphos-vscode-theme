    "statusBar.background": "#7E6544",
    "statusBar.foreground": "#F5F6F8",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#7E6544",
    "titleBar.activeBackground": "#7E6544",
