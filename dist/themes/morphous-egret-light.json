{
  "name": "Morphous Egret (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#5c6f55",
    "foreground": "#111111",
    "widget.border": "#00000015",
    "selection.background": "#93a38e25",
    "editor.background": "#fafaf9",
    "editor.foreground": "#111111",
    "editor.lineHighlightBackground": "#f5f6f450",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#5c6f55",
    "editor.selectionBackground": "#93a38e25",
    "editor.inactiveSelectionBackground": "#93a38e2580",
    "editorLineNumber.foreground": "#8e888380",
    "editorLineNumber.activeForeground": "#5c6f55",
    "sideBar.background": "#f5f6f4",
    "sideBar.foreground": "#111111",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#f5f6f480",
    "sideBarSectionHeader.foreground": "#111111",
    "sideBarTitle.foreground": "#5c6f55",
    "activityBar.background": "#fafaf9",
    "activityBar.foreground": "#5c6f55",
    "activityBar.inactiveForeground": "#11111160",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#5c6f55",
    "activityBarBadge.foreground": "#fafaf9",
    "statusBar.background": "#fafaf9",
    "statusBar.foreground": "#111111",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#fafaf9",
    "titleBar.activeBackground": "#fafaf9",
    "titleBar.activeForeground": "#111111",
    "titleBar.inactiveBackground": "#fafaf9",
    "titleBar.inactiveForeground": "#11111160",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#f5f6f4aa",
    "tab.activeBackground": "#fafaf9",
    "tab.activeForeground": "#111111",
    "tab.inactiveBackground": "#fafaf960",
    "tab.inactiveForeground": "#11111180",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#5c6f55",
    "list.activeSelectionBackground": "#5c6f5530",
    "list.activeSelectionForeground": "#111111",
    "list.hoverBackground": "#f5f6f440",
    "list.hoverForeground": "#111111",
    "list.inactiveSelectionBackground": "#5c6f5515",
    "list.inactiveSelectionForeground": "#111111",
    "list.highlightForeground": "#5c6f55",
    "terminal.background": "#fafaf9",
    "terminal.foreground": "#111111",
    "terminal.ansiBlack": "#111111",
    "terminal.ansiRed": "#cac3b5",
    "terminal.ansiGreen": "#5c6f55",
    "terminal.ansiYellow": "#e7e2d6",
    "terminal.ansiBlue": "#93a38e",
    "terminal.ansiMagenta": "#cac3b5",
    "terminal.ansiCyan": "#e7e2d6",
    "terminal.ansiWhite": "#111111",
    "input.background": "#f5f6f4",
    "input.foreground": "#111111",
    "input.border": "#00000015",
    "input.placeholderForeground": "#11111160",
    "button.background": "#5c6f55",
    "button.foreground": "#fafaf9",
    "button.hoverBackground": "#5c6f55dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8e8883",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#93a38e",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#93a38e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#5c6f55"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#e7e2d6"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#cac3b5"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#111111dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#11111180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#e7e2d6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#5c6f55"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#93a38e"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#5c6f55"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#8e8883"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#cac3b5"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#5c6f55"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#e7e2d6"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#5c6f55",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#e7e2d6"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#5c6f55"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8e8883",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#93a38e"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8e8883",
        "fontStyle": "italic"
      }
    }
  ]
}
