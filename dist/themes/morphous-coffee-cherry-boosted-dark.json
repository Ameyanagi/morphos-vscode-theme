    "activityBar.inactiveForeground": "#FAFAF860",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E96770",
    "activityBarBadge.foreground": "#1D251D",
    "statusBar.background": "#1D251D",
    "statusBar.foreground": "#FAFAF8",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#1D251D",
    "titleBar.activeBackground": "#1D251D",
    "titleBar.activeForeground": "#FAFAF8",
    "titleBar.inactiveBackground": "#1D251D",
    "titleBar.inactiveForeground": "#FAFAF860",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#1D251Ddd",
    "tab.activeBackground": "#1D251D",
    "tab.activeForeground": "#FAFAF8",
    "tab.inactiveBackground": "#0F140F60",
    "tab.inactiveForeground": "#FAFAF880",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E96770",
    "list.activeSelectionBackground": "#E9677030",
    "list.activeSelectionForeground": "#FAFAF8",
    "list.hoverBackground": "#0F140F40",
    "list.hoverForeground": "#FAFAF8",
    "list.inactiveSelectionBackground": "#E9677015",
    "list.inactiveSelectionForeground": "#FAFAF8",
    "list.highlightForeground": "#E96770",
    "terminal.background": "#1D251D",
    "terminal.foreground": "#FAFAF8",
    "terminal.ansiBlack": "#1D251D",
    "terminal.ansiRed": "#F1BE83",
    "terminal.ansiGreen": "#E96770",
    "terminal.ansiYellow": "#E7A355",
    "terminal.ansiBlue": "#79ECA3",
    "terminal.ansiMagenta": "#F1BE83",
    "terminal.ansiCyan": "#E7A355",
    "terminal.ansiWhite": "#FAFAF8",
    "input.background": "#0F140F",
    "input.foreground": "#FAFAF8",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#FAFAF860",
    "button.background": "#E96770",
    "button.foreground": "#1D251D",
    "button.hoverBackground": "#E96770dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8C8F94",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#79ECA3",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#79ECA3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E96770"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#E7A355"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F1BE83"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#FAFAF8"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#FAFAF8"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FAFAF8dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#FAFAF880"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FAFAF8"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#E7A355",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E96770"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#79ECA3"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E96770"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#8C8F94"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F1BE83"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E96770"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E7A355"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E96770",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E7A355"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E96770"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8C8F94",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79ECA3"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8C8F94",
        "fontStyle": "italic"
      }
    }
  ]
}
