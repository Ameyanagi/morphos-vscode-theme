    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#1D251D80",
    "sideBarSectionHeader.foreground": "#FAFAF8",
    "sideBarTitle.foreground": "#E96770",
    "activityBar.background": "#1D251D",
