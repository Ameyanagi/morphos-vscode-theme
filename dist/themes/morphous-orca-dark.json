    "terminal.foreground": "#F7FAFA",
    "terminal.ansiBlack": "#0A2540",
    "terminal.ansiRed": "#FFB020",
    "terminal.ansiGreen": "#0D6EFD",
    "terminal.ansiYellow": "#FFFFFF",
    "terminal.ansiBlue": "#19C7D3",
    "terminal.ansiMagenta": "#FFB020",
    "terminal.ansiCyan": "#FFFFFF",
    "terminal.ansiWhite": "#F7FAFA",
    "input.background": "#080B0D",
    "input.foreground": "#F7FAFA",
    "input.border": "#ffffff15",
