    "statusBar.background": "#0A2540",
    "statusBar.foreground": "#F7FAFA",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#0A2540",
    "titleBar.activeBackground": "#0A2540",
