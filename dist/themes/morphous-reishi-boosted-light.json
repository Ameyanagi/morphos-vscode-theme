    "sideBarSectionHeader.foreground": "#1F1713",
    "sideBarTitle.foreground": "#932528",
    "activityBar.background": "#FBF8F4",
    "activityBar.foreground": "#932528",
    "activityBar.inactiveForeground": "#1F171360",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#932528",
    "activityBarBadge.foreground": "#FBF8F4",
    "statusBar.background": "#FBF8F4",
    "statusBar.foreground": "#1F1713",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FBF8F4",
    "titleBar.activeBackground": "#FBF8F4",
    "titleBar.activeForeground": "#1F1713",
    "titleBar.inactiveBackground": "#FBF8F4",
    "titleBar.inactiveForeground": "#1F171360",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFF9F0aa",
    "tab.activeBackground": "#FBF8F4",
    "tab.activeForeground": "#1F1713",
    "tab.inactiveBackground": "#FBF8F460",
    "tab.inactiveForeground": "#1F171380",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#932528",
    "list.activeSelectionBackground": "#93252830",
    "list.activeSelectionForeground": "#1F1713",
    "list.hoverBackground": "#FFF9F040",
    "list.hoverForeground": "#1F1713",
    "list.inactiveSelectionBackground": "#93252815",
    "list.inactiveSelectionForeground": "#1F1713",
    "list.highlightForeground": "#932528",
    "terminal.background": "#FBF8F4",
    "terminal.foreground": "#1F1713",
    "terminal.ansiBlack": "#1F1713",
    "terminal.ansiRed": "#765119",
    "terminal.ansiGreen": "#932528",
    "terminal.ansiYellow": "#A37029",
    "terminal.ansiBlue": "#835A21",
    "terminal.ansiMagenta": "#765119",
    "terminal.ansiCyan": "#A37029",
    "terminal.ansiWhite": "#1F1713",
    "input.background": "#FFF9F0",
    "input.foreground": "#1F1713",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1F171360",
    "button.background": "#932528",
    "button.foreground": "#FBF8F4",
    "button.hoverBackground": "#932528dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#E8D9B5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#835A21",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#835A21",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#932528"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A37029"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#765119"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1F1713"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1F1713"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1F1713dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1F171380"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1F1713"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A37029",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#932528"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#835A21"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#932528"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#E8D9B5"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#765119"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#932528"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A37029"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#932528",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A37029"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#932528"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E8D9B5",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#835A21"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E8D9B5",
        "fontStyle": "italic"
      }
    }
  ]
}
