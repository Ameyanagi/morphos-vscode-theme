    "statusBar.background": "#FAFAF7",
    "statusBar.foreground": "#11131A",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FAFAF7",
    "titleBar.activeBackground": "#FAFAF7",
