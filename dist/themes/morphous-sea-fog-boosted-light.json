    "tab.inactiveBackground": "#FCFDFC60",
    "tab.inactiveForeground": "#18283280",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#256C93",
    "list.activeSelectionBackground": "#256C9330",
    "list.activeSelectionForeground": "#182832",
    "list.hoverBackground": "#F6F8F840",
