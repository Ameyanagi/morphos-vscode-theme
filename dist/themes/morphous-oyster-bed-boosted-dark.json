{
  "name": "Morphous Oyster Bed - Boosted (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#67A8E9",
    "foreground": "#F7F5EF",
    "widget.border": "#ffffff15",
    "selection.background": "#ECC07935",
    "editor.background": "#060709",
    "editor.foreground": "#F7F5EF",
    "editor.lineHighlightBackground": "#1E252940",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#67A8E9",
    "editor.selectionBackground": "#ECC07935",
    "editor.inactiveSelectionBackground": "#ECC0793580",
    "editorLineNumber.foreground": "#B7C0BE80",
    "editorLineNumber.activeForeground": "#67A8E9",
    "sideBar.background": "#1E2529",
    "sideBar.foreground": "#F7F5EF",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#06070980",
    "sideBarSectionHeader.foreground": "#F7F5EF",
    "sideBarTitle.foreground": "#67A8E9",
    "activityBar.background": "#060709",
    "activityBar.foreground": "#67A8E9",
    "activityBar.inactiveForeground": "#F7F5EF60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#67A8E9",
    "activityBarBadge.foreground": "#060709",
    "statusBar.background": "#060709",
    "statusBar.foreground": "#F7F5EF",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#060709",
    "titleBar.activeBackground": "#060709",
    "titleBar.activeForeground": "#F7F5EF",
    "titleBar.inactiveBackground": "#060709",
    "titleBar.inactiveForeground": "#F7F5EF60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#060709dd",
    "tab.activeBackground": "#060709",
    "tab.activeForeground": "#F7F5EF",
    "tab.inactiveBackground": "#1E252960",
    "tab.inactiveForeground": "#F7F5EF80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#67A8E9",
    "list.activeSelectionBackground": "#67A8E930",
    "list.activeSelectionForeground": "#F7F5EF",
    "list.hoverBackground": "#1E252940",
    "list.hoverForeground": "#F7F5EF",
    "list.inactiveSelectionBackground": "#67A8E915",
    "list.inactiveSelectionForeground": "#F7F5EF",
    "list.highlightForeground": "#67A8E9",
    "terminal.background": "#060709",
    "terminal.foreground": "#F7F5EF",
    "terminal.ansiBlack": "#060709",
    "terminal.ansiRed": "#F19583",
    "terminal.ansiGreen": "#67A8E9",
    "terminal.ansiYellow": "#90E755",
    "terminal.ansiBlue": "#ECC079",
    "terminal.ansiMagenta": "#F19583",
    "terminal.ansiCyan": "#90E755",
    "terminal.ansiWhite": "#F7F5EF",
    "input.background": "#1E2529",
    "input.foreground": "#F7F5EF",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F7F5EF60",
    "button.background": "#67A8E9",
    "button.foreground": "#060709",
    "button.hoverBackground": "#67A8E9dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B7C0BE",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#ECC079",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ECC079",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#67A8E9"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#90E755"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F19583"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F7F5EF"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F7F5EF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F7F5EFdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F7F5EF80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F7F5EF"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#90E755",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#67A8E9"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ECC079"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#67A8E9"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#B7C0BE"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F19583"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#67A8E9"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#90E755"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#67A8E9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#90E755"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#67A8E9"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#B7C0BE",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECC079"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#B7C0BE",
        "fontStyle": "italic"
      }
    }
  ]
}
