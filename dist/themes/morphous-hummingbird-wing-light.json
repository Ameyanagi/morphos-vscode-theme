{
  "name": "Morphous Hummingbird Wing (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#00857A",
    "foreground": "#1B1F22",
    "widget.border": "#00000015",
    "selection.background": "#6CD4BB25",
    "editor.background": "#FAFBFA",
    "editor.foreground": "#1B1F22",
    "editor.lineHighlightBackground": "#F7F4F450",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#00857A",
    "editor.selectionBackground": "#6CD4BB25",
    "editor.inactiveSelectionBackground": "#6CD4BB2580",
    "editorLineNumber.foreground": "#D5D9DC80",
    "editorLineNumber.activeForeground": "#00857A",
    "sideBar.background": "#F7F4F4",
    "sideBar.foreground": "#1B1F22",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F7F4F480",
    "sideBarSectionHeader.foreground": "#1B1F22",
    "sideBarTitle.foreground": "#00857A",
    "activityBar.background": "#FAFBFA",
    "activityBar.foreground": "#00857A",
    "activityBar.inactiveForeground": "#1B1F2260",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#00857A",
    "activityBarBadge.foreground": "#FAFBFA",
    "statusBar.background": "#FAFBFA",
    "statusBar.foreground": "#1B1F22",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FAFBFA",
    "titleBar.activeBackground": "#FAFBFA",
    "titleBar.activeForeground": "#1B1F22",
    "titleBar.inactiveBackground": "#FAFBFA",
    "titleBar.inactiveForeground": "#1B1F2260",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F7F4F4aa",
    "tab.activeBackground": "#FAFBFA",
    "tab.activeForeground": "#1B1F22",
    "tab.inactiveBackground": "#FAFBFA60",
    "tab.inactiveForeground": "#1B1F2280",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#00857A",
    "list.activeSelectionBackground": "#00857A30",
    "list.activeSelectionForeground": "#1B1F22",
    "list.hoverBackground": "#F7F4F440",
    "list.hoverForeground": "#1B1F22",
    "list.inactiveSelectionBackground": "#00857A15",
    "list.inactiveSelectionForeground": "#1B1F22",
    "list.highlightForeground": "#00857A",
    "terminal.background": "#FAFBFA",
    "terminal.foreground": "#1B1F22",
    "terminal.ansiBlack": "#1B1F22",
    "terminal.ansiRed": "#D90343",
    "terminal.ansiGreen": "#00857A",
    "terminal.ansiYellow": "#18AA80",
    "terminal.ansiBlue": "#6CD4BB",
    "terminal.ansiMagenta": "#D90343",
    "terminal.ansiCyan": "#18AA80",
    "terminal.ansiWhite": "#1B1F22",
    "input.background": "#F7F4F4",
    "input.foreground": "#1B1F22",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1B1F2260",
    "button.background": "#00857A",
    "button.foreground": "#FAFBFA",
    "button.hoverBackground": "#00857Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D5D9DC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#6CD4BB",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6CD4BB",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#00857A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#18AA80"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#D90343"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1B1F22"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1B1F22"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1B1F22dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1B1F2280"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1B1F22"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#18AA80",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#00857A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#6CD4BB"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#00857A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D5D9DC"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#D90343"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#00857A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#18AA80"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#00857A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#18AA80"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#00857A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D5D9DC",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6CD4BB"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D5D9DC",
        "fontStyle": "italic"
      }
    }
  ]
}
