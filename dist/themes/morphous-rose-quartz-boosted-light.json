    "terminal.ansiYellow": "#A3297A",
    "terminal.ansiBlue": "#83213E",
    "terminal.ansiMagenta": "#763E19",
    "terminal.ansiCyan": "#A3297A",
    "terminal.ansiWhite": "#2b1c26",
