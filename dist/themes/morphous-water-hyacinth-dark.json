        "foreground": "#b85e4c"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#5fa443"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#6e55c7"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#5fa443",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#6e55c7"
      }
