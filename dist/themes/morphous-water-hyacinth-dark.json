        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#6e55c7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#5fa443"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#e7e1f7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#5fa443"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
