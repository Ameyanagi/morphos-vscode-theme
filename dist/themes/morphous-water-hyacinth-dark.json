        "foreground": "#5fa443"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#ede8e0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#e7e1f7"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#ede8e0",
        "fontStyle": "italic"
      }
    }
