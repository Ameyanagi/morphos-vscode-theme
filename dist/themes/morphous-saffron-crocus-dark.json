    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#F2ECF8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6A3FB6"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#F2ECF8",
        "fontStyle": "italic"
      }
    }
