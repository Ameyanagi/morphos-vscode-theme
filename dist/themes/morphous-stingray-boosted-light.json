{
  "name": "Morphous Stingray - Boosted (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#256E93",
    "foreground": "#2E3A40",
    "widget.border": "#00000015",
    "selection.background": "#83682125",
    "editor.background": "#F1EFE9",
    "editor.foreground": "#2E3A40",
    "editor.lineHighlightBackground": "#DFE0DC50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#256E93",
    "editor.selectionBackground": "#83682125",
    "editor.inactiveSelectionBackground": "#8368212580",
    "editorLineNumber.foreground": "#ECE9E180",
    "editorLineNumber.activeForeground": "#256E93",
    "sideBar.background": "#DFE0DC",
    "sideBar.foreground": "#2E3A40",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#DFE0DC80",
    "sideBarSectionHeader.foreground": "#2E3A40",
    "sideBarTitle.foreground": "#256E93",
    "activityBar.background": "#F1EFE9",
    "activityBar.foreground": "#256E93",
    "activityBar.inactiveForeground": "#2E3A4060",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#256E93",
    "activityBarBadge.foreground": "#F1EFE9",
    "statusBar.background": "#F1EFE9",
    "statusBar.foreground": "#2E3A40",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F1EFE9",
    "titleBar.activeBackground": "#F1EFE9",
    "titleBar.activeForeground": "#2E3A40",
    "titleBar.inactiveBackground": "#F1EFE9",
    "titleBar.inactiveForeground": "#2E3A4060",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#DFE0DCaa",
    "tab.activeBackground": "#F1EFE9",
    "tab.activeForeground": "#2E3A40",
    "tab.inactiveBackground": "#F1EFE960",
    "tab.inactiveForeground": "#2E3A4080",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#256E93",
    "list.activeSelectionBackground": "#256E9330",
    "list.activeSelectionForeground": "#2E3A40",
    "list.hoverBackground": "#DFE0DC40",
    "list.hoverForeground": "#2E3A40",
    "list.inactiveSelectionBackground": "#256E9315",
    "list.inactiveSelectionForeground": "#2E3A40",
    "list.highlightForeground": "#256E93",
    "terminal.background": "#F1EFE9",
    "terminal.foreground": "#2E3A40",
    "terminal.ansiBlack": "#2E3A40",
    "terminal.ansiRed": "#197671",
    "terminal.ansiGreen": "#256E93",
    "terminal.ansiYellow": "#29A3A1",
    "terminal.ansiBlue": "#836821",
    "terminal.ansiMagenta": "#197671",
    "terminal.ansiCyan": "#29A3A1",
    "terminal.ansiWhite": "#2E3A40",
    "input.background": "#DFE0DC",
    "input.foreground": "#2E3A40",
    "input.border": "#00000015",
    "input.placeholderForeground": "#2E3A4060",
    "button.background": "#256E93",
    "button.foreground": "#F1EFE9",
    "button.hoverBackground": "#256E93dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#ECE9E1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#836821",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#836821",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#256E93"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#29A3A1"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#197671"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#2E3A40"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#2E3A40"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#2E3A40dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2E3A4080"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#2E3A40"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#29A3A1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#256E93"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#836821"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#256E93"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#ECE9E1"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#197671"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#256E93"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#29A3A1"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#256E93",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#29A3A1"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#256E93"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#ECE9E1",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#836821"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#ECE9E1",
        "fontStyle": "italic"
      }
    }
  ]
}
