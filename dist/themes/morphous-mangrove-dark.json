    "tab.activeForeground": "#f3efe6",
    "tab.inactiveBackground": "#24322F60",
    "tab.inactiveForeground": "#f3efe680",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#2E6F6F",
    "list.activeSelectionBackground": "#2E6F6F30",
