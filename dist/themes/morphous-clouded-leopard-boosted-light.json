    "terminal.ansiRed": "#765119",
    "terminal.ansiGreen": "#259354",
    "terminal.ansiYellow": "#68A329",
    "terminal.ansiBlue": "#835D21",
    "terminal.ansiMagenta": "#765119",
    "terminal.ansiCyan": "#68A329",
    "terminal.ansiWhite": "#171511",
