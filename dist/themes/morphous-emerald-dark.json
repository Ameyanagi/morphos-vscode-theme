    "tab.inactiveForeground": "#fbf7ec80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#006b45",
    "list.activeSelectionBackground": "#006b4530",
    "list.activeSelectionForeground": "#fbf7ec",
