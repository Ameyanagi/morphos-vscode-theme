{
  "name": "Morphous Cilantro (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#3F8A2F",
    "foreground": "#102114",
    "widget.border": "#00000015",
    "selection.background": "#74B84B25",
    "editor.background": "#F7F6E8",
    "editor.foreground": "#102114",
    "editor.lineHighlightBackground": "#FCFBF050",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#3F8A2F",
    "editor.selectionBackground": "#74B84B25",
    "editor.inactiveSelectionBackground": "#74B84B2580",
    "editorLineNumber.foreground": "#E5E7D480",
    "editorLineNumber.activeForeground": "#3F8A2F",
    "sideBar.background": "#FCFBF0",
    "sideBar.foreground": "#102114",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FCFBF080",
    "sideBarSectionHeader.foreground": "#102114",
    "sideBarTitle.foreground": "#3F8A2F",
    "activityBar.background": "#F7F6E8",
    "activityBar.foreground": "#3F8A2F",
    "activityBar.inactiveForeground": "#10211460",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#3F8A2F",
    "activityBarBadge.foreground": "#F7F6E8",
    "statusBar.background": "#F7F6E8",
    "statusBar.foreground": "#102114",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7F6E8",
    "titleBar.activeBackground": "#F7F6E8",
    "titleBar.activeForeground": "#102114",
    "titleBar.inactiveBackground": "#F7F6E8",
    "titleBar.inactiveForeground": "#10211460",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FCFBF0aa",
    "tab.activeBackground": "#F7F6E8",
    "tab.activeForeground": "#102114",
    "tab.inactiveBackground": "#F7F6E860",
    "tab.inactiveForeground": "#10211480",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#3F8A2F",
    "list.activeSelectionBackground": "#3F8A2F30",
    "list.activeSelectionForeground": "#102114",
    "list.hoverBackground": "#FCFBF040",
    "list.hoverForeground": "#102114",
    "list.inactiveSelectionBackground": "#3F8A2F15",
    "list.inactiveSelectionForeground": "#102114",
    "list.highlightForeground": "#3F8A2F",
    "terminal.background": "#F7F6E8",
    "terminal.foreground": "#102114",
    "terminal.ansiBlack": "#102114",
    "terminal.ansiRed": "#E9E0B8",
    "terminal.ansiGreen": "#3F8A2F",
    "terminal.ansiYellow": "#DCEB9A",
    "terminal.ansiBlue": "#74B84B",
    "terminal.ansiMagenta": "#E9E0B8",
    "terminal.ansiCyan": "#DCEB9A",
    "terminal.ansiWhite": "#102114",
    "input.background": "#FCFBF0",
    "input.foreground": "#102114",
    "input.border": "#00000015",
    "input.placeholderForeground": "#10211460",
    "button.background": "#3F8A2F",
    "button.foreground": "#F7F6E8",
    "button.hoverBackground": "#3F8A2Fdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#E5E7D4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#74B84B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#74B84B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#3F8A2F"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#DCEB9A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#E9E0B8"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#102114"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#102114"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#102114dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#10211480"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#102114"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#DCEB9A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#3F8A2F"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#74B84B"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#3F8A2F"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#E5E7D4"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#E9E0B8"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#3F8A2F"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#DCEB9A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#3F8A2F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#DCEB9A"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#3F8A2F"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E5E7D4",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#74B84B"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E5E7D4",
        "fontStyle": "italic"
      }
    }
  ]
}
