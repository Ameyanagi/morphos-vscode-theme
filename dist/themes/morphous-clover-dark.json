    "titleBar.inactiveBackground": "#4B3628",
    "titleBar.inactiveForeground": "#F6F8F460",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#4B3628dd",
    "tab.activeBackground": "#4B3628",
    "tab.activeForeground": "#F6F8F4",
    "tab.inactiveBackground": "#18221460",
    "tab.inactiveForeground": "#F6F8F480",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#3E7D3A",
    "list.activeSelectionBackground": "#3E7D3A30",
