    "terminal.foreground": "#F6F8F4",
    "terminal.ansiBlack": "#4B3628",
    "terminal.ansiRed": "#DDEBCF",
    "terminal.ansiGreen": "#3E7D3A",
    "terminal.ansiYellow": "#B6D7A8",
    "terminal.ansiBlue": "#2E5E2B",
    "terminal.ansiMagenta": "#DDEBCF",
    "terminal.ansiCyan": "#B6D7A8",
    "terminal.ansiWhite": "#F6F8F4",
    "input.background": "#182214",
    "input.foreground": "#F6F8F4",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F6F8F460",
    "button.background": "#3E7D3A",
    "button.foreground": "#4B3628",
    "button.hoverBackground": "#3E7D3Add"
