    "statusBar.background": "#0C4D5A",
    "statusBar.foreground": "#F7F5EF",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#0C4D5A",
    "titleBar.activeBackground": "#0C4D5A",
