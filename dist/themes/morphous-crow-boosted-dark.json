    "statusBar.background": "#F5F5F5",
    "statusBar.foreground": "#f2f4f6",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#F5F5F5",
    "titleBar.activeBackground": "#F5F5F5",
    "titleBar.activeForeground": "#f2f4f6",
    "titleBar.inactiveBackground": "#F5F5F5",
    "titleBar.inactiveForeground": "#f2f4f660",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#F5F5F5dd",
    "tab.activeBackground": "#F5F5F5",
    "tab.activeForeground": "#f2f4f6",
    "tab.inactiveBackground": "#090A0C60",
    "tab.inactiveForeground": "#f2f4f680",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#67A0E9",
    "list.activeSelectionBackground": "#67A0E930",
    "list.activeSelectionForeground": "#f2f4f6",
    "list.hoverBackground": "#090A0C40",
    "list.hoverForeground": "#f2f4f6",
    "list.inactiveSelectionBackground": "#67A0E915",
    "list.inactiveSelectionForeground": "#f2f4f6",
    "list.highlightForeground": "#67A0E9",
    "terminal.background": "#F5F5F5",
    "terminal.foreground": "#f2f4f6",
    "terminal.ansiBlack": "#F5F5F5",
    "terminal.ansiRed": "#F1BE83",
    "terminal.ansiGreen": "#67A0E9",
    "terminal.ansiYellow": "#55A1E7",
    "terminal.ansiBlue": "#79A9EC",
    "terminal.ansiMagenta": "#F1BE83",
    "terminal.ansiCyan": "#55A1E7",
    "terminal.ansiWhite": "#f2f4f6",
    "input.background": "#090A0C",
    "input.foreground": "#f2f4f6",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#f2f4f660",
    "button.background": "#67A0E9",
    "button.foreground": "#F5F5F5",
    "button.hoverBackground": "#67A0E9dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6b7178",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#79A9EC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#79A9EC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#67A0E9"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#55A1E7"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F1BE83"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f2f4f6"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f2f4f6"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f2f4f6dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#f2f4f680"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f2f4f6"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#55A1E7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#67A0E9"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#79A9EC"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#67A0E9"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#6b7178"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F1BE83"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#67A0E9"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#55A1E7"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#67A0E9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#55A1E7"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#67A0E9"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#6b7178",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79A9EC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#6b7178",
        "fontStyle": "italic"
      }
    }
  ]
}
