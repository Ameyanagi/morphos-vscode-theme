{
  "name": "Morphous Ant Trail (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#6d4b32",
    "foreground": "#171510",
    "widget.border": "#00000015",
    "selection.background": "#9a765225",
    "editor.background": "#eee4d1",
    "editor.foreground": "#171510",
    "editor.lineHighlightBackground": "#b7a58f50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#6d4b32",
    "editor.selectionBackground": "#9a765225",
    "editor.inactiveSelectionBackground": "#9a76522580",
    "editorLineNumber.foreground": "#b7a58f80",
    "editorLineNumber.activeForeground": "#6d4b32",
    "sideBar.background": "#b7a58f",
    "sideBar.foreground": "#171510",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#b7a58f80",
    "sideBarSectionHeader.foreground": "#171510",
    "sideBarTitle.foreground": "#6d4b32",
    "activityBar.background": "#eee4d1",
    "activityBar.foreground": "#6d4b32",
    "activityBar.inactiveForeground": "#17151060",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#6d4b32",
    "activityBarBadge.foreground": "#eee4d1",
    "statusBar.background": "#eee4d1",
    "statusBar.foreground": "#171510",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#eee4d1",
    "titleBar.activeBackground": "#eee4d1",
    "titleBar.activeForeground": "#171510",
    "titleBar.inactiveBackground": "#eee4d1",
    "titleBar.inactiveForeground": "#17151060",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#b7a58faa",
    "tab.activeBackground": "#eee4d1",
    "tab.activeForeground": "#171510",
    "tab.inactiveBackground": "#eee4d160",
    "tab.inactiveForeground": "#17151080",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#6d4b32",
    "list.activeSelectionBackground": "#6d4b3230",
    "list.activeSelectionForeground": "#171510",
    "list.hoverBackground": "#b7a58f40",
    "list.hoverForeground": "#171510",
    "list.inactiveSelectionBackground": "#6d4b3215",
    "list.inactiveSelectionForeground": "#171510",
    "list.highlightForeground": "#6d4b32",
    "terminal.background": "#eee4d1",
    "terminal.foreground": "#171510",
    "terminal.ansiBlack": "#171510",
    "terminal.ansiRed": "#8aa05f",
    "terminal.ansiGreen": "#6d4b32",
    "terminal.ansiYellow": "#5f7c45",
    "terminal.ansiBlue": "#9a7652",
    "terminal.ansiMagenta": "#8aa05f",
    "terminal.ansiCyan": "#5f7c45",
    "terminal.ansiWhite": "#171510",
    "input.background": "#b7a58f",
    "input.foreground": "#171510",
    "input.border": "#00000015",
    "input.placeholderForeground": "#17151060",
    "button.background": "#6d4b32",
    "button.foreground": "#eee4d1",
    "button.hoverBackground": "#6d4b32dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#b7a58f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#9a7652",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9a7652",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6d4b32"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#5f7c45"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#8aa05f"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#171510"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#171510"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#171510dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#17151080"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#171510"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#5f7c45",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#6d4b32"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#9a7652"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6d4b32"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#b7a58f"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#8aa05f"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6d4b32"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#5f7c45"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6d4b32",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#5f7c45"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#6d4b32"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#b7a58f",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#9a7652"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#b7a58f",
        "fontStyle": "italic"
      }
    }
  ]
}
