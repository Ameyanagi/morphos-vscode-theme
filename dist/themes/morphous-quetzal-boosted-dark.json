    "terminal.ansiRed": "#F1838C",
    "terminal.ansiGreen": "#67E9C4",
    "terminal.ansiYellow": "#E7BB55",
    "terminal.ansiBlue": "#79ECCF",
    "terminal.ansiMagenta": "#F1838C",
    "terminal.ansiCyan": "#E7BB55",
    "terminal.ansiWhite": "#f4f2e8",
