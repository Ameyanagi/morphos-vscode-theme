    "terminal.ansiGreen": "#F472B6",
    "terminal.ansiYellow": "#F2B705",
    "terminal.ansiBlue": "#6AA84F",
    "terminal.ansiMagenta": "#F89BC8",
    "terminal.ansiCyan": "#F2B705",
    "terminal.ansiWhite": "#FAFAF8",
