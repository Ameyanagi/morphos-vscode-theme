    "statusBar.background": "#0F1A24",
    "statusBar.foreground": "#f3f0e6",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#0F1A24",
    "titleBar.activeBackground": "#0F1A24",
    "titleBar.activeForeground": "#f3f0e6",
    "titleBar.inactiveBackground": "#0F1A24",
    "titleBar.inactiveForeground": "#f3f0e660",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#0F1A24dd",
    "tab.activeBackground": "#0F1A24",
    "tab.activeForeground": "#f3f0e6",
    "tab.inactiveBackground": "#1D282F60",
    "tab.inactiveForeground": "#f3f0e680",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#67B7E9",
    "list.activeSelectionBackground": "#67B7E930",
    "list.activeSelectionForeground": "#f3f0e6",
    "list.hoverBackground": "#1D282F40",
    "list.hoverForeground": "#f3f0e6",
    "list.inactiveSelectionBackground": "#67B7E915",
    "list.inactiveSelectionForeground": "#f3f0e6",
    "list.highlightForeground": "#67B7E9",
    "terminal.background": "#0F1A24",
    "terminal.foreground": "#f3f0e6",
    "terminal.ansiBlack": "#0F1A24",
    "terminal.ansiRed": "#F1A283",
    "terminal.ansiGreen": "#67B7E9",
    "terminal.ansiYellow": "#55D6E7",
    "terminal.ansiBlue": "#ECC979",
    "terminal.ansiMagenta": "#F1A283",
    "terminal.ansiCyan": "#55D6E7",
    "terminal.ansiWhite": "#f3f0e6",
    "input.background": "#1D282F",
    "input.foreground": "#f3f0e6",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#f3f0e660",
    "button.background": "#67B7E9",
    "button.foreground": "#0F1A24",
    "button.hoverBackground": "#67B7E9dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#d8d0bd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#ECC979",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ECC979",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#67B7E9"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#55D6E7"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F1A283"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f3f0e6"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f3f0e6"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f3f0e6dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#f3f0e680"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f3f0e6"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#55D6E7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#67B7E9"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ECC979"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#67B7E9"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#d8d0bd"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F1A283"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#67B7E9"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#55D6E7"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#67B7E9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#55D6E7"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#67B7E9"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#d8d0bd",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECC979"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#d8d0bd",
        "fontStyle": "italic"
      }
    }
  ]
}
