    "activityBarBadge.foreground": "#2B3440",
    "statusBar.background": "#2B3440",
    "statusBar.foreground": "#F8F9FB",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#2B3440",
    "titleBar.activeBackground": "#2B3440",
    "titleBar.activeForeground": "#F8F9FB",
    "titleBar.inactiveBackground": "#2B3440",
    "titleBar.inactiveForeground": "#F8F9FB60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#2B3440dd",
    "tab.activeBackground": "#2B3440",
    "tab.activeForeground": "#F8F9FB",
    "tab.inactiveBackground": "#2B344060",
    "tab.inactiveForeground": "#F8F9FB80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#B9CBDD",
    "list.activeSelectionBackground": "#B9CBDD30",
    "list.activeSelectionForeground": "#F8F9FB",
    "list.hoverBackground": "#2B344040",
    "list.hoverForeground": "#F8F9FB",
    "list.inactiveSelectionBackground": "#B9CBDD15",
    "list.inactiveSelectionForeground": "#F8F9FB",
    "list.highlightForeground": "#B9CBDD",
    "terminal.background": "#2B3440",
    "terminal.foreground": "#F8F9FB",
    "terminal.ansiBlack": "#2B3440",
    "terminal.ansiRed": "#E9CFCF",
    "terminal.ansiGreen": "#B9CBDD",
    "terminal.ansiYellow": "#E6C3D7",
    "terminal.ansiBlue": "#D6E6EE",
    "terminal.ansiMagenta": "#E9CFCF",
    "terminal.ansiCyan": "#E6C3D7",
    "terminal.ansiWhite": "#F8F9FB",
    "input.background": "#2B3440",
    "input.foreground": "#F8F9FB",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F8F9FB60",
    "button.background": "#B9CBDD",
    "button.foreground": "#2B3440",
    "button.hoverBackground": "#B9CBDDdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#E9DFCF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#D6E6EE",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D6E6EE",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#B9CBDD"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#E6C3D7"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#E9CFCF"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F8F9FB"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F8F9FB"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F8F9FBdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F8F9FB80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F8F9FB"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#E6C3D7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#B9CBDD"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#D6E6EE"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B9CBDD"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#E9DFCF"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#E9CFCF"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#B9CBDD"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E6C3D7"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#B9CBDD",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E6C3D7"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#B9CBDD"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E9DFCF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#D6E6EE"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E9DFCF",
        "fontStyle": "italic"
      }
    }
  ]
}
