    "terminal.ansiRed": "#DBF183",
    "terminal.ansiGreen": "#67E990",
    "terminal.ansiYellow": "#55E7E7",
    "terminal.ansiBlue": "#79EC98",
    "terminal.ansiMagenta": "#DBF183",
    "terminal.ansiCyan": "#55E7E7",
    "terminal.ansiWhite": "#F3E9D7",
    "input.background": "#111410",
