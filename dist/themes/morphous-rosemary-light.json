    "terminal.ansiGreen": "#2F5E3F",
    "terminal.ansiYellow": "#A5AEDC",
    "terminal.ansiBlue": "#A5B69C",
    "terminal.ansiMagenta": "#A5AEDC",
    "terminal.ansiCyan": "#A5AEDC",
    "terminal.ansiWhite": "#1A2E1F",
    "input.background": "#C7CDEB",
    "input.foreground": "#1A2E1F",
