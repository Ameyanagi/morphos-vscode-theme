    "titleBar.inactiveBackground": "#FFF8EE",
    "titleBar.inactiveForeground": "#28161260",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFDF6aa",
    "tab.activeBackground": "#FFF8EE",
