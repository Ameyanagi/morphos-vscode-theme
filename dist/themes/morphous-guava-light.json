    "statusBar.background": "#FFF8EE",
    "statusBar.foreground": "#281612",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FFF8EE",
    "titleBar.activeBackground": "#FFF8EE",
