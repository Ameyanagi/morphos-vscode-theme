    "input.foreground": "#281612",
    "input.border": "#00000015",
    "input.placeholderForeground": "#28161260",
    "button.background": "#F26FA1",
    "button.foreground": "#FFF8EE",
    "button.hoverBackground": "#F26FA1dd"
