{
  "name": "Morphous Monstera (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#0F3D2E",
    "foreground": "#081310",
    "widget.border": "#00000015",
    "selection.background": "#DDE6D825",
    "editor.background": "#F7F9F7",
    "editor.foreground": "#081310",
    "editor.lineHighlightBackground": "#EEF2EE50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#0F3D2E",
    "editor.selectionBackground": "#DDE6D825",
    "editor.inactiveSelectionBackground": "#DDE6D82580",
    "editorLineNumber.foreground": "#6F8F7A80",
    "editorLineNumber.activeForeground": "#0F3D2E",
    "sideBar.background": "#EEF2EE",
    "sideBar.foreground": "#081310",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#EEF2EE80",
    "sideBarSectionHeader.foreground": "#081310",
    "sideBarTitle.foreground": "#0F3D2E",
    "activityBar.background": "#F7F9F7",
    "activityBar.foreground": "#0F3D2E",
    "activityBar.inactiveForeground": "#08131060",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#0F3D2E",
    "activityBarBadge.foreground": "#F7F9F7",
    "statusBar.background": "#F7F9F7",
    "statusBar.foreground": "#081310",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7F9F7",
    "titleBar.activeBackground": "#F7F9F7",
    "titleBar.activeForeground": "#081310",
    "titleBar.inactiveBackground": "#F7F9F7",
    "titleBar.inactiveForeground": "#08131060",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#EEF2EEaa",
    "tab.activeBackground": "#F7F9F7",
    "tab.activeForeground": "#081310",
    "tab.inactiveBackground": "#F7F9F760",
    "tab.inactiveForeground": "#08131080",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#0F3D2E",
    "list.activeSelectionBackground": "#0F3D2E30",
    "list.activeSelectionForeground": "#081310",
    "list.hoverBackground": "#EEF2EE40",
    "list.hoverForeground": "#081310",
    "list.inactiveSelectionBackground": "#0F3D2E15",
    "list.inactiveSelectionForeground": "#081310",
    "list.highlightForeground": "#0F3D2E",
    "terminal.background": "#F7F9F7",
    "terminal.foreground": "#081310",
    "terminal.ansiBlack": "#081310",
    "terminal.ansiRed": "#C6B66E",
    "terminal.ansiGreen": "#0F3D2E",
    "terminal.ansiYellow": "#A7E06E",
    "terminal.ansiBlue": "#DDE6D8",
    "terminal.ansiMagenta": "#C6B66E",
    "terminal.ansiCyan": "#A7E06E",
    "terminal.ansiWhite": "#081310",
    "input.background": "#EEF2EE",
    "input.foreground": "#081310",
    "input.border": "#00000015",
    "input.placeholderForeground": "#08131060",
    "button.background": "#0F3D2E",
    "button.foreground": "#F7F9F7",
    "button.hoverBackground": "#0F3D2Edd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6F8F7A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#DDE6D8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#DDE6D8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#0F3D2E"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A7E06E"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#C6B66E"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#081310"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#081310"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#081310dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#08131080"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#081310"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A7E06E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#0F3D2E"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#DDE6D8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#0F3D2E"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#6F8F7A"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#C6B66E"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#0F3D2E"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A7E06E"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#0F3D2E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A7E06E"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#0F3D2E"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#6F8F7A",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#DDE6D8"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#6F8F7A",
        "fontStyle": "italic"
      }
    }
  ]
}
