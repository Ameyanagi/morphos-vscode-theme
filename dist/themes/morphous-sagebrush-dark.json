{
  "name": "Morphous Sagebrush (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#A5AEA0",
    "foreground": "#F6F2EE",
    "widget.border": "#ffffff15",
    "selection.background": "#C4C0B035",
    "editor.background": "#202A2C",
    "editor.foreground": "#F6F2EE",
    "editor.lineHighlightBackground": "#3E3A3340",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#A5AEA0",
    "editor.selectionBackground": "#C4C0B035",
    "editor.inactiveSelectionBackground": "#C4C0B03580",
    "editorLineNumber.foreground": "#B9B3A580",
    "editorLineNumber.activeForeground": "#A5AEA0",
    "sideBar.background": "#3E3A33",
    "sideBar.foreground": "#F6F2EE",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#202A2C80",
    "sideBarSectionHeader.foreground": "#F6F2EE",
    "sideBarTitle.foreground": "#A5AEA0",
    "activityBar.background": "#202A2C",
    "activityBar.foreground": "#A5AEA0",
    "activityBar.inactiveForeground": "#F6F2EE60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#A5AEA0",
    "activityBarBadge.foreground": "#202A2C",
    "statusBar.background": "#202A2C",
    "statusBar.foreground": "#F6F2EE",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#202A2C",
    "titleBar.activeBackground": "#202A2C",
    "titleBar.activeForeground": "#F6F2EE",
    "titleBar.inactiveBackground": "#202A2C",
    "titleBar.inactiveForeground": "#F6F2EE60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#202A2Cdd",
    "tab.activeBackground": "#202A2C",
    "tab.activeForeground": "#F6F2EE",
    "tab.inactiveBackground": "#3E3A3360",
    "tab.inactiveForeground": "#F6F2EE80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#A5AEA0",
    "list.activeSelectionBackground": "#A5AEA030",
    "list.activeSelectionForeground": "#F6F2EE",
    "list.hoverBackground": "#3E3A3340",
    "list.hoverForeground": "#F6F2EE",
    "list.inactiveSelectionBackground": "#A5AEA015",
    "list.inactiveSelectionForeground": "#F6F2EE",
    "list.highlightForeground": "#A5AEA0",
    "terminal.background": "#202A2C",
    "terminal.foreground": "#F6F2EE",
    "terminal.ansiBlack": "#202A2C",
    "terminal.ansiRed": "#556B66",
    "terminal.ansiGreen": "#A5AEA0",
    "terminal.ansiYellow": "#C8AA7A",
    "terminal.ansiBlue": "#C4C0B0",
    "terminal.ansiMagenta": "#556B66",
    "terminal.ansiCyan": "#C8AA7A",
    "terminal.ansiWhite": "#F6F2EE",
    "input.background": "#3E3A33",
    "input.foreground": "#F6F2EE",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F6F2EE60",
    "button.background": "#A5AEA0",
    "button.foreground": "#202A2C",
    "button.hoverBackground": "#A5AEA0dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B9B3A5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#C4C0B0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C4C0B0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#A5AEA0"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#C8AA7A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#556B66"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F6F2EE"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F6F2EE"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F6F2EEdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F6F2EE80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F6F2EE"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#C8AA7A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#A5AEA0"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#C4C0B0"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A5AEA0"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#B9B3A5"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#556B66"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#A5AEA0"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#C8AA7A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#A5AEA0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C8AA7A"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#A5AEA0"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#B9B3A5",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#C4C0B0"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#B9B3A5",
        "fontStyle": "italic"
      }
    }
  ]
}
