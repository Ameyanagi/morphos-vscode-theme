    "activityBar.inactiveForeground": "#2a2f3660",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#254993",
    "activityBarBadge.foreground": "#FCFCFD",
    "statusBar.background": "#FCFCFD",
    "statusBar.foreground": "#2a2f36",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FCFCFD",
    "titleBar.activeBackground": "#FCFCFD",
    "titleBar.activeForeground": "#2a2f36",
    "titleBar.inactiveBackground": "#FCFCFD",
    "titleBar.inactiveForeground": "#2a2f3660",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F3F6FCaa",
    "tab.activeBackground": "#FCFCFD",
    "tab.activeForeground": "#2a2f36",
    "tab.inactiveBackground": "#FCFCFD60",
    "tab.inactiveForeground": "#2a2f3680",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#254993",
    "list.activeSelectionBackground": "#25499330",
    "list.activeSelectionForeground": "#2a2f36",
    "list.hoverBackground": "#F3F6FC40",
    "list.hoverForeground": "#2a2f36",
    "list.inactiveSelectionBackground": "#25499315",
    "list.inactiveSelectionForeground": "#2a2f36",
    "list.highlightForeground": "#254993",
    "terminal.background": "#FCFCFD",
    "terminal.foreground": "#2a2f36",
    "terminal.ansiBlack": "#2a2f36",
    "terminal.ansiRed": "#194076",
    "terminal.ansiGreen": "#254993",
    "terminal.ansiYellow": "#2954A3",
    "terminal.ansiBlue": "#21832F",
    "terminal.ansiMagenta": "#194076",
    "terminal.ansiCyan": "#2954A3",
    "terminal.ansiWhite": "#2a2f36",
    "input.background": "#F3F6FC",
    "input.foreground": "#2a2f36",
    "input.border": "#00000015",
    "input.placeholderForeground": "#2a2f3660",
    "button.background": "#254993",
    "button.foreground": "#FCFCFD",
    "button.hoverBackground": "#254993dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#c7e1d4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#21832F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#21832F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#254993"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#2954A3"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#194076"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#2a2f36"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#2a2f36"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#2a2f36dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2a2f3680"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#2a2f36"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#2954A3",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#254993"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#21832F"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#254993"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#c7e1d4"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#194076"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#254993"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#2954A3"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#254993",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#2954A3"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#254993"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#c7e1d4",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#21832F"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#c7e1d4",
        "fontStyle": "italic"
      }
    }
  ]
}
