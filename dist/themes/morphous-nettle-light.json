    "tab.inactiveBackground": "#F8FBF860",
    "tab.inactiveForeground": "#10201580",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#1A442E",
    "list.activeSelectionBackground": "#1A442E30",
