    "activityBarBadge.foreground": "#0A1F33",
    "statusBar.background": "#0A1F33",
    "statusBar.foreground": "#F7F8FD",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#0A1F33",
    "titleBar.activeBackground": "#0A1F33",
    "titleBar.activeForeground": "#F7F8FD",
    "titleBar.inactiveBackground": "#0A1F33",
    "titleBar.inactiveForeground": "#F7F8FD60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#0A1F33dd",
    "tab.activeBackground": "#0A1F33",
    "tab.activeForeground": "#F7F8FD",
    "tab.inactiveBackground": "#0A1F3360",
    "tab.inactiveForeground": "#F7F8FD80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#00A9B4",
    "list.activeSelectionBackground": "#00A9B430",
    "list.activeSelectionForeground": "#F7F8FD",
    "list.hoverBackground": "#0A1F3340",
    "list.hoverForeground": "#F7F8FD",
    "list.inactiveSelectionBackground": "#00A9B415",
    "list.inactiveSelectionForeground": "#F7F8FD",
    "list.highlightForeground": "#00A9B4",
    "terminal.background": "#0A1F33",
    "terminal.foreground": "#F7F8FD",
    "terminal.ansiBlack": "#0A1F33",
    "terminal.ansiRed": "#0057FF",
    "terminal.ansiGreen": "#00A9B4",
    "terminal.ansiYellow": "#8CE22A",
    "terminal.ansiBlue": "#FFD23C",
    "terminal.ansiMagenta": "#0057FF",
    "terminal.ansiCyan": "#8CE22A",
    "terminal.ansiWhite": "#F7F8FD",
    "input.background": "#0A1F33",
    "input.foreground": "#F7F8FD",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F7F8FD60",
    "button.background": "#00A9B4",
    "button.foreground": "#0A1F33",
    "button.hoverBackground": "#00A9B4dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#E6F1F7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#FFD23C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFD23C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#00A9B4"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#8CE22A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#0057FF"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F7F8FD"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F7F8FD"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F7F8FDdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F7F8FD80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F7F8FD"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#8CE22A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#00A9B4"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FFD23C"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#00A9B4"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#E6F1F7"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#0057FF"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#00A9B4"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#8CE22A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#00A9B4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8CE22A"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#00A9B4"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E6F1F7",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#FFD23C"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E6F1F7",
        "fontStyle": "italic"
      }
    }
  ]
}
