    "terminal.ansiYellow": "#2E7D32",
    "terminal.ansiBlue": "#FF6F61",
    "terminal.ansiMagenta": "#2E7D32",
    "terminal.ansiCyan": "#2E7D32",
    "terminal.ansiWhite": "#141414",
