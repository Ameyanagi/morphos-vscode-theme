    "selection.background": "#6F8A7325",
    "editor.background": "#F6F7F3",
    "editor.foreground": "#29302B",
    "editor.lineHighlightBackground": "#FBFCF850",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#6B4E3A",
    "editor.selectionBackground": "#6F8A7325",
    "editor.inactiveSelectionBackground": "#6F8A732580",
    "editorLineNumber.foreground": "#C2C7BF80",
    "editorLineNumber.activeForeground": "#6B4E3A",
    "sideBar.background": "#FBFCF8",
    "sideBar.foreground": "#29302B",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FBFCF880",
    "sideBarSectionHeader.foreground": "#29302B",
    "sideBarTitle.foreground": "#6B4E3A",
    "activityBar.background": "#F6F7F3",
    "activityBar.foreground": "#6B4E3A",
    "activityBar.inactiveForeground": "#29302B60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#6B4E3A",
    "activityBarBadge.foreground": "#F6F7F3",
    "statusBar.background": "#F6F7F3",
    "statusBar.foreground": "#29302B",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F6F7F3",
    "titleBar.activeBackground": "#F6F7F3",
    "titleBar.activeForeground": "#29302B",
    "titleBar.inactiveBackground": "#F6F7F3",
    "titleBar.inactiveForeground": "#29302B60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FBFCF8aa",
    "tab.activeBackground": "#F6F7F3",
    "tab.activeForeground": "#29302B",
    "tab.inactiveBackground": "#F6F7F360",
    "tab.inactiveForeground": "#29302B80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#6B4E3A",
    "list.activeSelectionBackground": "#6B4E3A30",
    "list.activeSelectionForeground": "#29302B",
    "list.hoverBackground": "#FBFCF840",
    "list.hoverForeground": "#29302B",
    "list.inactiveSelectionBackground": "#6B4E3A15",
    "list.inactiveSelectionForeground": "#29302B",
    "list.highlightForeground": "#6B4E3A",
    "terminal.background": "#F6F7F3",
    "terminal.foreground": "#29302B",
    "terminal.ansiBlack": "#29302B",
    "terminal.ansiRed": "#C2A27A",
    "terminal.ansiGreen": "#6B4E3A",
    "terminal.ansiYellow": "#B6C2C8",
    "terminal.ansiBlue": "#6F8A73",
    "terminal.ansiMagenta": "#C2A27A",
    "terminal.ansiCyan": "#B6C2C8",
    "terminal.ansiWhite": "#29302B",
    "input.background": "#FBFCF8",
    "input.foreground": "#29302B",
    "input.border": "#00000015",
    "input.placeholderForeground": "#29302B60",
    "button.background": "#6B4E3A",
    "button.foreground": "#F6F7F3",
    "button.hoverBackground": "#6B4E3Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#C2C7BF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#6F8A73",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6F8A73",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6B4E3A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#B6C2C8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#C2A27A"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#29302B"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#29302B"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#29302Bdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#29302B80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#29302B"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#B6C2C8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#6B4E3A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#6F8A73"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6B4E3A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#C2C7BF"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#C2A27A"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6B4E3A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#B6C2C8"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6B4E3A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#B6C2C8"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#6B4E3A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#C2C7BF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6F8A73"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#C2C7BF",
        "fontStyle": "italic"
      }
    }
  ]
}
