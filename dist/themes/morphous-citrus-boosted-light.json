{
  "name": "Morphous Citrus - Boosted (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#935F25",
    "foreground": "#3A281A",
    "widget.border": "#00000015",
    "selection.background": "#83672125",
    "editor.background": "#FFFBF5",
