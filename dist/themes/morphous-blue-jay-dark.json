    "statusBar.background": "#5a4632",
    "statusBar.foreground": "#f6f8fa",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#5a4632",
    "titleBar.activeBackground": "#5a4632",
