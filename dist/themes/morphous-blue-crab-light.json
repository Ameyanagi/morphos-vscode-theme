    "terminal.ansiYellow": "#8a8f4c",
    "terminal.ansiBlue": "#5c8f8b",
    "terminal.ansiMagenta": "#c8954a",
    "terminal.ansiCyan": "#8a8f4c",
    "terminal.ansiWhite": "#0e1b2b",
    "input.background": "#f5f2e8",
