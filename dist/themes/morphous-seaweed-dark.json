      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#47523A",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#2C5F63"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#47523A",
        "fontStyle": "italic"
      }
    }
