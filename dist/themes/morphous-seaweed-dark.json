    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F7FAF8"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
