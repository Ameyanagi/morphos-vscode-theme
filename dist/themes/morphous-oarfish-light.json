{
  "name": "Morphous Oarfish (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#e6393d",
    "foreground": "#081a2e",
    "widget.border": "#00000015",
    "selection.background": "#a7bcd125",
    "editor.background": "#fafbfc",
    "editor.foreground": "#081a2e",
    "editor.lineHighlightBackground": "#f1f3f650",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#e6393d",
    "editor.selectionBackground": "#a7bcd125",
    "editor.inactiveSelectionBackground": "#a7bcd12580",
    "editorLineNumber.foreground": "#e6eaee80",
    "editorLineNumber.activeForeground": "#e6393d",
    "sideBar.background": "#f1f3f6",
    "sideBar.foreground": "#081a2e",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#f1f3f680",
    "sideBarSectionHeader.foreground": "#081a2e",
    "sideBarTitle.foreground": "#e6393d",
    "activityBar.background": "#fafbfc",
    "activityBar.foreground": "#e6393d",
    "activityBar.inactiveForeground": "#081a2e60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#e6393d",
    "activityBarBadge.foreground": "#fafbfc",
    "statusBar.background": "#fafbfc",
    "statusBar.foreground": "#081a2e",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#fafbfc",
    "titleBar.activeBackground": "#fafbfc",
    "titleBar.activeForeground": "#081a2e",
    "titleBar.inactiveBackground": "#fafbfc",
    "titleBar.inactiveForeground": "#081a2e60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#f1f3f6aa",
    "tab.activeBackground": "#fafbfc",
    "tab.activeForeground": "#081a2e",
    "tab.inactiveBackground": "#fafbfc60",
    "tab.inactiveForeground": "#081a2e80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#e6393d",
    "list.activeSelectionBackground": "#e6393d30",
    "list.activeSelectionForeground": "#081a2e",
    "list.hoverBackground": "#f1f3f640",
    "list.hoverForeground": "#081a2e",
    "list.inactiveSelectionBackground": "#e6393d15",
    "list.inactiveSelectionForeground": "#081a2e",
    "list.highlightForeground": "#e6393d",
    "terminal.background": "#fafbfc",
    "terminal.foreground": "#081a2e",
    "terminal.ansiBlack": "#081a2e",
    "terminal.ansiRed": "#ff4d4f",
    "terminal.ansiGreen": "#e6393d",
    "terminal.ansiYellow": "#d6dfe8",
    "terminal.ansiBlue": "#a7bcd1",
    "terminal.ansiMagenta": "#ff4d4f",
    "terminal.ansiCyan": "#d6dfe8",
    "terminal.ansiWhite": "#081a2e",
    "input.background": "#f1f3f6",
    "input.foreground": "#081a2e",
    "input.border": "#00000015",
    "input.placeholderForeground": "#081a2e60",
    "button.background": "#e6393d",
    "button.foreground": "#fafbfc",
    "button.hoverBackground": "#e6393ddd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#e6eaee",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#a7bcd1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a7bcd1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#e6393d"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#d6dfe8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#ff4d4f"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#081a2e"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#081a2e"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#081a2edd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#081a2e80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#081a2e"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#d6dfe8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#e6393d"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#a7bcd1"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#e6393d"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#e6eaee"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ff4d4f"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#e6393d"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#d6dfe8"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#e6393d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#d6dfe8"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#e6393d"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#e6eaee",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#a7bcd1"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#e6eaee",
        "fontStyle": "italic"
      }
    }
  ]
}
