{
  "name": "Morphous Hummingbird Wing - Boosted (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#25938A",
    "foreground": "#1B1F22",
    "widget.border": "#00000015",
    "selection.background": "#21836C25",
    "editor.background": "#FCFDFC",
    "editor.foreground": "#1B1F22",
    "editor.lineHighlightBackground": "#F9F6F650",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#25938A",
    "editor.selectionBackground": "#21836C25",
    "editor.inactiveSelectionBackground": "#21836C2580",
    "editorLineNumber.foreground": "#D5D9DC80",
    "editorLineNumber.activeForeground": "#25938A",
    "sideBar.background": "#F9F6F6",
    "sideBar.foreground": "#1B1F22",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F9F6F680",
    "sideBarSectionHeader.foreground": "#1B1F22",
    "sideBarTitle.foreground": "#25938A",
    "activityBar.background": "#FCFDFC",
    "activityBar.foreground": "#25938A",
    "activityBar.inactiveForeground": "#1B1F2260",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#25938A",
    "activityBarBadge.foreground": "#FCFDFC",
    "statusBar.background": "#FCFDFC",
    "statusBar.foreground": "#1B1F22",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FCFDFC",
    "titleBar.activeBackground": "#FCFDFC",
    "titleBar.activeForeground": "#1B1F22",
    "titleBar.inactiveBackground": "#FCFDFC",
    "titleBar.inactiveForeground": "#1B1F2260",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F9F6F6aa",
    "tab.activeBackground": "#FCFDFC",
    "tab.activeForeground": "#1B1F22",
    "tab.inactiveBackground": "#FCFDFC60",
    "tab.inactiveForeground": "#1B1F2280",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#25938A",
    "list.activeSelectionBackground": "#25938A30",
    "list.activeSelectionForeground": "#1B1F22",
    "list.hoverBackground": "#F9F6F640",
    "list.hoverForeground": "#1B1F22",
    "list.inactiveSelectionBackground": "#25938A15",
    "list.inactiveSelectionForeground": "#1B1F22",
    "list.highlightForeground": "#25938A",
    "terminal.background": "#FCFDFC",
    "terminal.foreground": "#1B1F22",
    "terminal.ansiBlack": "#1B1F22",
    "terminal.ansiRed": "#761935",
    "terminal.ansiGreen": "#25938A",
    "terminal.ansiYellow": "#29A381",
    "terminal.ansiBlue": "#21836C",
    "terminal.ansiMagenta": "#761935",
    "terminal.ansiCyan": "#29A381",
    "terminal.ansiWhite": "#1B1F22",
    "input.background": "#F9F6F6",
    "input.foreground": "#1B1F22",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1B1F2260",
    "button.background": "#25938A",
    "button.foreground": "#FCFDFC",
    "button.hoverBackground": "#25938Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D5D9DC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#21836C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#21836C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#25938A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#29A381"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#761935"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1B1F22"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1B1F22"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1B1F22dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1B1F2280"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1B1F22"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#29A381",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#25938A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#21836C"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#25938A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D5D9DC"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#761935"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#25938A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#29A381"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#25938A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#29A381"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#25938A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D5D9DC",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#21836C"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D5D9DC",
        "fontStyle": "italic"
      }
    }
  ]
}
