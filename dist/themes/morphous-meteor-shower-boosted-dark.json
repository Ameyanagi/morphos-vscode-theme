    "terminal.ansiGreen": "#E9BC67",
    "terminal.ansiYellow": "#E75555",
    "terminal.ansiBlue": "#9879EC",
    "terminal.ansiMagenta": "#839DF1",
    "terminal.ansiCyan": "#E75555",
    "terminal.ansiWhite": "#f7f8ff",
