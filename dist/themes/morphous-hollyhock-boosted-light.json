    "titleBar.inactiveForeground": "#1E181860",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFBF0aa",
    "tab.activeBackground": "#FEFDFB",
    "tab.activeForeground": "#1E1818",
    "tab.inactiveBackground": "#FEFDFB60",
