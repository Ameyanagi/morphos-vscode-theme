      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#0f7a4a"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#b56d3c"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#0f7a4a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#b56d3c"
      }
