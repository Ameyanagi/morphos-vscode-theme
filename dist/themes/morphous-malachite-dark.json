        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f3fbf5"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f3fbf5dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
