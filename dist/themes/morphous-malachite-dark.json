      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#a6d8bd",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#72c99b"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#a6d8bd",
        "fontStyle": "italic"
      }
