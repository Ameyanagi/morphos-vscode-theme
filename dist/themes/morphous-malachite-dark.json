        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#b56d3c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#0f7a4a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#72c99b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
