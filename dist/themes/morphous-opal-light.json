{
  "name": "Morphous Opal (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#1677FF",
    "foreground": "#182124",
    "widget.border": "#00000015",
    "selection.background": "#20D88F25",
    "editor.background": "#F8FBF7",
    "editor.foreground": "#182124",
    "editor.lineHighlightBackground": "#DDE7E250",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#1677FF",
    "editor.selectionBackground": "#20D88F25",
    "editor.inactiveSelectionBackground": "#20D88F2580",
    "editorLineNumber.foreground": "#B7793E80",
    "editorLineNumber.activeForeground": "#1677FF",
    "sideBar.background": "#DDE7E2",
    "sideBar.foreground": "#182124",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#DDE7E280",
    "sideBarSectionHeader.foreground": "#182124",
    "sideBarTitle.foreground": "#1677FF",
    "activityBar.background": "#F8FBF7",
    "activityBar.foreground": "#1677FF",
    "activityBar.inactiveForeground": "#18212460",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#1677FF",
    "activityBarBadge.foreground": "#F8FBF7",
    "statusBar.background": "#F8FBF7",
    "statusBar.foreground": "#182124",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F8FBF7",
    "titleBar.activeBackground": "#F8FBF7",
    "titleBar.activeForeground": "#182124",
    "titleBar.inactiveBackground": "#F8FBF7",
    "titleBar.inactiveForeground": "#18212460",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#DDE7E2aa",
    "tab.activeBackground": "#F8FBF7",
    "tab.activeForeground": "#182124",
    "tab.inactiveBackground": "#F8FBF760",
    "tab.inactiveForeground": "#18212480",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#1677FF",
    "list.activeSelectionBackground": "#1677FF30",
    "list.activeSelectionForeground": "#182124",
    "list.hoverBackground": "#DDE7E240",
    "list.hoverForeground": "#182124",
    "list.inactiveSelectionBackground": "#1677FF15",
    "list.inactiveSelectionForeground": "#182124",
    "list.highlightForeground": "#1677FF",
    "terminal.background": "#F8FBF7",
    "terminal.foreground": "#182124",
    "terminal.ansiBlack": "#182124",
    "terminal.ansiRed": "#60E6F2",
    "terminal.ansiGreen": "#1677FF",
    "terminal.ansiYellow": "#FF7A24",
    "terminal.ansiBlue": "#20D88F",
    "terminal.ansiMagenta": "#60E6F2",
    "terminal.ansiCyan": "#FF7A24",
    "terminal.ansiWhite": "#182124",
    "input.background": "#DDE7E2",
    "input.foreground": "#182124",
    "input.border": "#00000015",
    "input.placeholderForeground": "#18212460",
    "button.background": "#1677FF",
    "button.foreground": "#F8FBF7",
    "button.hoverBackground": "#1677FFdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B7793E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#20D88F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#20D88F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#1677FF"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#FF7A24"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#60E6F2"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#182124"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#182124"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#182124dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#18212480"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#182124"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#FF7A24",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#1677FF"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#20D88F"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1677FF"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#B7793E"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#60E6F2"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#1677FF"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#FF7A24"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#1677FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#FF7A24"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#1677FF"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#B7793E",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#20D88F"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#B7793E",
        "fontStyle": "italic"
      }
    }
  ]
}
