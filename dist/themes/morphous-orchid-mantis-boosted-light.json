{
  "name": "Morphous Orchid Mantis - Boosted (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#932544",
    "foreground": "#F2EFEF",
    "widget.border": "#00000015",
    "selection.background": "#83214E25",
    "editor.background": "#FDFCFC",
    "editor.foreground": "#F2EFEF",
    "editor.lineHighlightBackground": "#F8F7F750",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#932544",
    "editor.selectionBackground": "#83214E25",
    "editor.inactiveSelectionBackground": "#83214E2580",
    "editorLineNumber.foreground": "#E6E2E780",
    "editorLineNumber.activeForeground": "#932544",
    "sideBar.background": "#F8F7F7",
    "sideBar.foreground": "#F2EFEF",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F8F7F780",
    "sideBarSectionHeader.foreground": "#F2EFEF",
    "sideBarTitle.foreground": "#932544",
    "activityBar.background": "#FDFCFC",
    "activityBar.foreground": "#932544",
    "activityBar.inactiveForeground": "#F2EFEF60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#932544",
    "activityBarBadge.foreground": "#FDFCFC",
    "statusBar.background": "#FDFCFC",
    "statusBar.foreground": "#F2EFEF",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FDFCFC",
    "titleBar.activeBackground": "#FDFCFC",
    "titleBar.activeForeground": "#F2EFEF",
    "titleBar.inactiveBackground": "#FDFCFC",
    "titleBar.inactiveForeground": "#F2EFEF60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F8F7F7aa",
    "tab.activeBackground": "#FDFCFC",
    "tab.activeForeground": "#F2EFEF",
    "tab.inactiveBackground": "#FDFCFC60",
    "tab.inactiveForeground": "#F2EFEF80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#932544",
    "list.activeSelectionBackground": "#93254430",
    "list.activeSelectionForeground": "#F2EFEF",
    "list.hoverBackground": "#F8F7F740",
    "list.hoverForeground": "#F2EFEF",
    "list.inactiveSelectionBackground": "#93254415",
    "list.inactiveSelectionForeground": "#F2EFEF",
    "list.highlightForeground": "#932544",
    "terminal.background": "#FDFCFC",
    "terminal.foreground": "#F2EFEF",
    "terminal.ansiBlack": "#F2EFEF",
    "terminal.ansiRed": "#765D19",
    "terminal.ansiGreen": "#932544",
    "terminal.ansiYellow": "#78A329",
    "terminal.ansiBlue": "#83214E",
    "terminal.ansiMagenta": "#765D19",
    "terminal.ansiCyan": "#78A329",
    "terminal.ansiWhite": "#F2EFEF",
    "input.background": "#F8F7F7",
    "input.foreground": "#F2EFEF",
    "input.border": "#00000015",
    "input.placeholderForeground": "#F2EFEF60",
    "button.background": "#932544",
    "button.foreground": "#FDFCFC",
    "button.hoverBackground": "#932544dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#E6E2E7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#83214E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#83214E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#932544"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#78A329"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#765D19"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F2EFEF"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F2EFEF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F2EFEFdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F2EFEF80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F2EFEF"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#78A329",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#932544"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#83214E"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#932544"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#E6E2E7"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#765D19"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#932544"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#78A329"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#932544",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#78A329"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#932544"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E6E2E7",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#83214E"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E6E2E7",
        "fontStyle": "italic"
      }
    }
  ]
}
