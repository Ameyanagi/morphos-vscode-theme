    "terminal.ansiGreen": "#4f7d58",
    "terminal.ansiYellow": "#d9ad3b",
    "terminal.ansiBlue": "#fffaf0",
    "terminal.ansiMagenta": "#5f9a92",
    "terminal.ansiCyan": "#d9ad3b",
    "terminal.ansiWhite": "#1f2c2a",
