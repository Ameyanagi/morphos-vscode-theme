    "terminal.ansiRed": "#FFB3C9",
    "terminal.ansiGreen": "#FFD873",
    "terminal.ansiYellow": "#7FD7F4",
    "terminal.ansiBlue": "#BDEBFF",
    "terminal.ansiMagenta": "#FFB3C9",
    "terminal.ansiCyan": "#7FD7F4",
    "terminal.ansiWhite": "#182A44",
