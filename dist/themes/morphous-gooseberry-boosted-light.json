    "terminal.ansiRed": "#764419",
    "terminal.ansiGreen": "#819325",
    "terminal.ansiYellow": "#85A329",
    "terminal.ansiBlue": "#458321",
    "terminal.ansiMagenta": "#764419",
    "terminal.ansiCyan": "#85A329",
    "terminal.ansiWhite": "#3A352E",
