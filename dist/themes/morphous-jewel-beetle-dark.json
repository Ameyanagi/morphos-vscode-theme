        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#0b66c3",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#00a86b"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#d6a83a"
      }
