    "activityBar.inactiveForeground": "#F7FCFF60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#0D47FF",
    "activityBarBadge.foreground": "#0B0B0F",
    "statusBar.background": "#0B0B0F",
    "statusBar.foreground": "#F7FCFF",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#0B0B0F",
    "titleBar.activeBackground": "#0B0B0F",
    "titleBar.activeForeground": "#F7FCFF",
    "titleBar.inactiveBackground": "#0B0B0F",
    "titleBar.inactiveForeground": "#F7FCFF60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#0B0B0Fdd",
    "tab.activeBackground": "#0B0B0F",
    "tab.activeForeground": "#F7FCFF",
    "tab.inactiveBackground": "#00102660",
    "tab.inactiveForeground": "#F7FCFF80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#0D47FF",
    "list.activeSelectionBackground": "#0D47FF30",
    "list.activeSelectionForeground": "#F7FCFF",
    "list.hoverBackground": "#00102640",
    "list.hoverForeground": "#F7FCFF",
    "list.inactiveSelectionBackground": "#0D47FF15",
    "list.inactiveSelectionForeground": "#F7FCFF",
    "list.highlightForeground": "#0D47FF",
    "terminal.background": "#0B0B0F",
    "terminal.foreground": "#F7FCFF",
    "terminal.ansiBlack": "#0B0B0F",
    "terminal.ansiRed": "#22D3EE",
    "terminal.ansiGreen": "#0D47FF",
    "terminal.ansiYellow": "#00B5B8",
    "terminal.ansiBlue": "#FFD600",
    "terminal.ansiMagenta": "#22D3EE",
    "terminal.ansiCyan": "#00B5B8",
    "terminal.ansiWhite": "#F7FCFF",
    "input.background": "#001026",
    "input.foreground": "#F7FCFF",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F7FCFF60",
    "button.background": "#0D47FF",
    "button.foreground": "#0B0B0F",
    "button.hoverBackground": "#0D47FFdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#CFFAFA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#FFD600",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFD600",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#0D47FF"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#00B5B8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#22D3EE"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F7FCFF"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F7FCFF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F7FCFFdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F7FCFF80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F7FCFF"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#00B5B8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#0D47FF"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FFD600"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#0D47FF"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#CFFAFA"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#22D3EE"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#0D47FF"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#00B5B8"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#0D47FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#00B5B8"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#0D47FF"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#CFFAFA",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#FFD600"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#CFFAFA",
        "fontStyle": "italic"
      }
    }
  ]
}
