    "selection.background": "#E7DCC635",
    "editor.background": "#7A5A45",
    "editor.foreground": "#F6F4EE",
    "editor.lineHighlightBackground": "#12161C40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#B44A3A",
    "editor.selectionBackground": "#E7DCC635",
    "editor.inactiveSelectionBackground": "#E7DCC63580",
    "editorLineNumber.foreground": "#C8B79080",
    "editorLineNumber.activeForeground": "#B44A3A",
    "sideBar.background": "#12161C",
    "sideBar.foreground": "#F6F4EE",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#7A5A4580",
    "sideBarSectionHeader.foreground": "#F6F4EE",
