    "activityBar.background": "#7A5A45",
    "activityBar.foreground": "#B44A3A",
    "activityBar.inactiveForeground": "#F6F4EE60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#B44A3A",
    "activityBarBadge.foreground": "#7A5A45",
    "statusBar.background": "#7A5A45",
    "statusBar.foreground": "#F6F4EE",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#7A5A45",
    "titleBar.activeBackground": "#7A5A45",
    "titleBar.activeForeground": "#F6F4EE",
    "titleBar.inactiveBackground": "#7A5A45",
    "titleBar.inactiveForeground": "#F6F4EE60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#7A5A45dd",
    "tab.activeBackground": "#7A5A45",
    "tab.activeForeground": "#F6F4EE",
    "tab.inactiveBackground": "#12161C60",
    "tab.inactiveForeground": "#F6F4EE80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#B44A3A",
    "list.activeSelectionBackground": "#B44A3A30",
    "list.activeSelectionForeground": "#F6F4EE",
    "list.hoverBackground": "#12161C40",
