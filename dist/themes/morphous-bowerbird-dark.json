    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#131815dd",
    "tab.activeBackground": "#131815",
    "tab.activeForeground": "#f7f0df",
    "tab.inactiveBackground": "#1f272260",
