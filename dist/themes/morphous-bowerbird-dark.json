    "terminal.ansiRed": "#59a9df",
    "terminal.ansiGreen": "#1469c8",
    "terminal.ansiYellow": "#5f8f61",
    "terminal.ansiBlue": "#8a5d37",
    "terminal.ansiMagenta": "#59a9df",
    "terminal.ansiCyan": "#5f8f61",
    "terminal.ansiWhite": "#f7f0df",
    "input.background": "#1f2722",
