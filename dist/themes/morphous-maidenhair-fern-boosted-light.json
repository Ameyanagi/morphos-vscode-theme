    "statusBar.background": "#FDFEFB",
    "statusBar.foreground": "#0E0F0E",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FDFEFB",
    "titleBar.activeBackground": "#FDFEFB",
