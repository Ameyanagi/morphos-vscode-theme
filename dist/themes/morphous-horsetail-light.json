{
  "name": "Morphous Horsetail (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#1E4D3A",
    "foreground": "#141414",
    "widget.border": "#00000015",
    "selection.background": "#3F7A4A25",
    "editor.background": "#ECEDE7",
    "editor.foreground": "#141414",
    "editor.lineHighlightBackground": "#A58A6A50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#1E4D3A",
    "editor.selectionBackground": "#3F7A4A25",
    "editor.inactiveSelectionBackground": "#3F7A4A2580",
    "editorLineNumber.foreground": "#D9DDD680",
    "editorLineNumber.activeForeground": "#1E4D3A",
    "sideBar.background": "#A58A6A",
    "sideBar.foreground": "#141414",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#A58A6A80",
    "sideBarSectionHeader.foreground": "#141414",
    "sideBarTitle.foreground": "#1E4D3A",
    "activityBar.background": "#ECEDE7",
    "activityBar.foreground": "#1E4D3A",
    "activityBar.inactiveForeground": "#14141460",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#1E4D3A",
    "activityBarBadge.foreground": "#ECEDE7",
    "statusBar.background": "#ECEDE7",
    "statusBar.foreground": "#141414",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#ECEDE7",
    "titleBar.activeBackground": "#ECEDE7",
    "titleBar.activeForeground": "#141414",
    "titleBar.inactiveBackground": "#ECEDE7",
    "titleBar.inactiveForeground": "#14141460",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#A58A6Aaa",
    "tab.activeBackground": "#ECEDE7",
    "tab.activeForeground": "#141414",
    "tab.inactiveBackground": "#ECEDE760",
    "tab.inactiveForeground": "#14141480",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#1E4D3A",
    "list.activeSelectionBackground": "#1E4D3A30",
    "list.activeSelectionForeground": "#141414",
    "list.hoverBackground": "#A58A6A40",
    "list.hoverForeground": "#141414",
    "list.inactiveSelectionBackground": "#1E4D3A15",
    "list.inactiveSelectionForeground": "#141414",
    "list.highlightForeground": "#1E4D3A",
    "terminal.background": "#ECEDE7",
    "terminal.foreground": "#141414",
    "terminal.ansiBlack": "#141414",
    "terminal.ansiRed": "#6BA661",
    "terminal.ansiGreen": "#1E4D3A",
    "terminal.ansiYellow": "#6BA661",
    "terminal.ansiBlue": "#3F7A4A",
    "terminal.ansiMagenta": "#6BA661",
    "terminal.ansiCyan": "#6BA661",
    "terminal.ansiWhite": "#141414",
    "input.background": "#A58A6A",
    "input.foreground": "#141414",
    "input.border": "#00000015",
    "input.placeholderForeground": "#14141460",
    "button.background": "#1E4D3A",
    "button.foreground": "#ECEDE7",
    "button.hoverBackground": "#1E4D3Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D9DDD6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#3F7A4A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#3F7A4A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#1E4D3A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#6BA661"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#6BA661"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#141414"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#141414"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#141414dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#14141480"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#141414"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#6BA661",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#1E4D3A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#3F7A4A"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1E4D3A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D9DDD6"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#6BA661"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#1E4D3A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#6BA661"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#1E4D3A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#6BA661"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#1E4D3A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D9DDD6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#3F7A4A"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D9DDD6",
        "fontStyle": "italic"
      }
    }
  ]
}
