    "statusBar.background": "#F7F5F1",
    "statusBar.foreground": "#2A2018",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7F5F1",
    "titleBar.activeBackground": "#F7F5F1",
    "titleBar.activeForeground": "#2A2018",
    "titleBar.inactiveBackground": "#F7F5F1",
    "titleBar.inactiveForeground": "#2A201860",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFCF7aa",
    "tab.activeBackground": "#F7F5F1",
    "tab.activeForeground": "#2A2018",
    "tab.inactiveBackground": "#F7F5F160",
    "tab.inactiveForeground": "#2A201880",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#7A5638",
    "list.activeSelectionBackground": "#7A563830",
    "list.activeSelectionForeground": "#2A2018",
    "list.hoverBackground": "#FFFCF740",
