{
  "name": "Morphous White Peach - Boosted (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#E9677B",
    "foreground": "#FFF6EE",
    "widget.border": "#ffffff15",
    "selection.background": "#ECC27935",
    "editor.background": "#3A2822",
