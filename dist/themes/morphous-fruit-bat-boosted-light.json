    "terminal.ansiGreen": "#936925",
    "terminal.ansiYellow": "#A3298F",
    "terminal.ansiBlue": "#832172",
    "terminal.ansiMagenta": "#19763D",
    "terminal.ansiCyan": "#A3298F",
    "terminal.ansiWhite": "#0B0B0E",
