    "statusBar.background": "#FEFDFB",
    "statusBar.foreground": "#2E291F",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FEFDFB",
    "titleBar.activeBackground": "#FEFDFB",
