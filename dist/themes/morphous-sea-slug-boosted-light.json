        "meta.object.member"
      ],
      "settings": {
        "foreground": "#0b1020"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#0b1020dd",
        "fontStyle": "italic"
