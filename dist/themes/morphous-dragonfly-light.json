{
  "name": "Morphous Dragonfly (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#43a6c6",
    "foreground": "#20262a",
    "widget.border": "#00000015",
    "selection.background": "#5f7f4b25",
    "editor.background": "#f4faf8",
    "editor.foreground": "#20262a",
    "editor.lineHighlightBackground": "#dceff250",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#43a6c6",
    "editor.selectionBackground": "#5f7f4b25",
    "editor.inactiveSelectionBackground": "#5f7f4b2580",
    "editorLineNumber.foreground": "#94a79a80",
    "editorLineNumber.activeForeground": "#43a6c6",
    "sideBar.background": "#dceff2",
    "sideBar.foreground": "#20262a",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#dceff280",
    "sideBarSectionHeader.foreground": "#20262a",
    "sideBarTitle.foreground": "#43a6c6",
    "activityBar.background": "#f4faf8",
    "activityBar.foreground": "#43a6c6",
    "activityBar.inactiveForeground": "#20262a60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#43a6c6",
    "activityBarBadge.foreground": "#f4faf8",
    "statusBar.background": "#f4faf8",
    "statusBar.foreground": "#20262a",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#f4faf8",
    "titleBar.activeBackground": "#f4faf8",
    "titleBar.activeForeground": "#20262a",
    "titleBar.inactiveBackground": "#f4faf8",
    "titleBar.inactiveForeground": "#20262a60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#dceff2aa",
    "tab.activeBackground": "#f4faf8",
    "tab.activeForeground": "#20262a",
    "tab.inactiveBackground": "#f4faf860",
    "tab.inactiveForeground": "#20262a80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#43a6c6",
    "list.activeSelectionBackground": "#43a6c630",
    "list.activeSelectionForeground": "#20262a",
    "list.hoverBackground": "#dceff240",
    "list.hoverForeground": "#20262a",
    "list.inactiveSelectionBackground": "#43a6c615",
    "list.inactiveSelectionForeground": "#20262a",
    "list.highlightForeground": "#43a6c6",
    "terminal.background": "#f4faf8",
    "terminal.foreground": "#20262a",
    "terminal.ansiBlack": "#20262a",
    "terminal.ansiRed": "#c69b4a",
    "terminal.ansiGreen": "#43a6c6",
    "terminal.ansiYellow": "#8bd4e8",
    "terminal.ansiBlue": "#5f7f4b",
    "terminal.ansiMagenta": "#c69b4a",
    "terminal.ansiCyan": "#8bd4e8",
    "terminal.ansiWhite": "#20262a",
    "input.background": "#dceff2",
    "input.foreground": "#20262a",
    "input.border": "#00000015",
    "input.placeholderForeground": "#20262a60",
    "button.background": "#43a6c6",
    "button.foreground": "#f4faf8",
    "button.hoverBackground": "#43a6c6dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#94a79a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#5f7f4b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5f7f4b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#43a6c6"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#8bd4e8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c69b4a"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#20262a"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#20262a"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#20262add",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#20262a80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#20262a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#8bd4e8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#43a6c6"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#5f7f4b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#43a6c6"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#94a79a"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c69b4a"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#43a6c6"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#8bd4e8"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#43a6c6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8bd4e8"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#43a6c6"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#94a79a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#5f7f4b"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#94a79a",
        "fontStyle": "italic"
      }
    }
  ]
}
