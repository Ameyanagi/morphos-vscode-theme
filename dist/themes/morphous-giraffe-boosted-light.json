{
  "name": "Morphous Giraffe - Boosted (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#936325",
    "foreground": "#1f1712",
    "widget.border": "#00000015",
    "selection.background": "#83492125",
    "editor.background": "#F9F0E2",
    "editor.foreground": "#1f1712",
    "editor.lineHighlightBackground": "#FFF9EB50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#936325",
    "editor.selectionBackground": "#83492125",
    "editor.inactiveSelectionBackground": "#8349212580",
    "editorLineNumber.foreground": "#d7b47a80",
    "editorLineNumber.activeForeground": "#936325",
    "sideBar.background": "#FFF9EB",
    "sideBar.foreground": "#1f1712",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFF9EB80",
    "sideBarSectionHeader.foreground": "#1f1712",
    "sideBarTitle.foreground": "#936325",
    "activityBar.background": "#F9F0E2",
    "activityBar.foreground": "#936325",
    "activityBar.inactiveForeground": "#1f171260",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#936325",
    "activityBarBadge.foreground": "#F9F0E2",
    "statusBar.background": "#F9F0E2",
    "statusBar.foreground": "#1f1712",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F9F0E2",
    "titleBar.activeBackground": "#F9F0E2",
    "titleBar.activeForeground": "#1f1712",
    "titleBar.inactiveBackground": "#F9F0E2",
    "titleBar.inactiveForeground": "#1f171260",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFF9EBaa",
    "tab.activeBackground": "#F9F0E2",
    "tab.activeForeground": "#1f1712",
    "tab.inactiveBackground": "#F9F0E260",
    "tab.inactiveForeground": "#1f171280",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#936325",
    "list.activeSelectionBackground": "#93632530",
    "list.activeSelectionForeground": "#1f1712",
    "list.hoverBackground": "#FFF9EB40",
    "list.hoverForeground": "#1f1712",
    "list.inactiveSelectionBackground": "#93632515",
    "list.inactiveSelectionForeground": "#1f1712",
    "list.highlightForeground": "#936325",
    "terminal.background": "#F9F0E2",
    "terminal.foreground": "#1f1712",
    "terminal.ansiBlack": "#1f1712",
    "terminal.ansiRed": "#527619",
    "terminal.ansiGreen": "#936325",
    "terminal.ansiYellow": "#297CA3",
    "terminal.ansiBlue": "#834921",
    "terminal.ansiMagenta": "#527619",
    "terminal.ansiCyan": "#297CA3",
    "terminal.ansiWhite": "#1f1712",
    "input.background": "#FFF9EB",
    "input.foreground": "#1f1712",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1f171260",
    "button.background": "#936325",
    "button.foreground": "#F9F0E2",
    "button.hoverBackground": "#936325dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#d7b47a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#834921",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#834921",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#936325"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#297CA3"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#527619"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1f1712"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1f1712"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1f1712dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1f171280"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1f1712"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#297CA3",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#936325"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#834921"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#936325"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#d7b47a"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#527619"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#936325"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#297CA3"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#936325",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#297CA3"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#936325"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#d7b47a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#834921"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#d7b47a",
        "fontStyle": "italic"
      }
    }
  ]
}
