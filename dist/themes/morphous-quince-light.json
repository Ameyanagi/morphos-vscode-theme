{
  "name": "Morphous Quince (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#e6c13a",
    "foreground": "#2e241a",
    "widget.border": "#00000015",
    "selection.background": "#d8ae2325",
    "editor.background": "#faf7ec",
    "editor.foreground": "#2e241a",
    "editor.lineHighlightBackground": "#f2ede050",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#e6c13a",
    "editor.selectionBackground": "#d8ae2325",
    "editor.inactiveSelectionBackground": "#d8ae232580",
    "editorLineNumber.foreground": "#e6d1b380",
    "editorLineNumber.activeForeground": "#e6c13a",
    "sideBar.background": "#f2ede0",
    "sideBar.foreground": "#2e241a",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#f2ede080",
    "sideBarSectionHeader.foreground": "#2e241a",
    "sideBarTitle.foreground": "#e6c13a",
    "activityBar.background": "#faf7ec",
    "activityBar.foreground": "#e6c13a",
    "activityBar.inactiveForeground": "#2e241a60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#e6c13a",
    "activityBarBadge.foreground": "#faf7ec",
    "statusBar.background": "#faf7ec",
    "statusBar.foreground": "#2e241a",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#faf7ec",
    "titleBar.activeBackground": "#faf7ec",
    "titleBar.activeForeground": "#2e241a",
    "titleBar.inactiveBackground": "#faf7ec",
    "titleBar.inactiveForeground": "#2e241a60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#f2ede0aa",
    "tab.activeBackground": "#faf7ec",
    "tab.activeForeground": "#2e241a",
    "tab.inactiveBackground": "#faf7ec60",
    "tab.inactiveForeground": "#2e241a80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#e6c13a",
    "list.activeSelectionBackground": "#e6c13a30",
    "list.activeSelectionForeground": "#2e241a",
    "list.hoverBackground": "#f2ede040",
    "list.hoverForeground": "#2e241a",
    "list.inactiveSelectionBackground": "#e6c13a15",
    "list.inactiveSelectionForeground": "#2e241a",
    "list.highlightForeground": "#e6c13a",
    "terminal.background": "#faf7ec",
    "terminal.foreground": "#2e241a",
    "terminal.ansiBlack": "#2e241a",
    "terminal.ansiRed": "#8a9b62",
    "terminal.ansiGreen": "#e6c13a",
    "terminal.ansiYellow": "#5e7a49",
    "terminal.ansiBlue": "#d8ae23",
    "terminal.ansiMagenta": "#8a9b62",
    "terminal.ansiCyan": "#5e7a49",
    "terminal.ansiWhite": "#2e241a",
    "input.background": "#f2ede0",
    "input.foreground": "#2e241a",
    "input.border": "#00000015",
    "input.placeholderForeground": "#2e241a60",
    "button.background": "#e6c13a",
    "button.foreground": "#faf7ec",
    "button.hoverBackground": "#e6c13add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#e6d1b3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#d8ae23",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d8ae23",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#e6c13a"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#5e7a49"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#8a9b62"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#2e241a"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#2e241a"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#2e241add",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2e241a80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#2e241a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#5e7a49",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#e6c13a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#d8ae23"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#e6c13a"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#e6d1b3"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#8a9b62"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#e6c13a"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#5e7a49"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#e6c13a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#5e7a49"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#e6c13a"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#e6d1b3",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#d8ae23"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#e6d1b3",
        "fontStyle": "italic"
      }
    }
  ]
}
