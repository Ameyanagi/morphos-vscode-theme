{
  "name": "Morphous Harpy Eagle (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#2b2f2f",
    "foreground": "#f4f5f1",
    "widget.border": "#ffffff15",
    "selection.background": "#d9ddd935",
    "editor.background": "#101313",
    "editor.foreground": "#f4f5f1",
    "editor.lineHighlightBackground": "#171a1a40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#2b2f2f",
    "editor.selectionBackground": "#d9ddd935",
    "editor.inactiveSelectionBackground": "#d9ddd93580",
    "editorLineNumber.foreground": "#d9ddd980",
    "editorLineNumber.activeForeground": "#2b2f2f",
    "sideBar.background": "#171a1a",
    "sideBar.foreground": "#f4f5f1",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#10131380",
    "sideBarSectionHeader.foreground": "#f4f5f1",
    "sideBarTitle.foreground": "#2b2f2f",
    "activityBar.background": "#101313",
    "activityBar.foreground": "#2b2f2f",
    "activityBar.inactiveForeground": "#f4f5f160",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#2b2f2f",
    "activityBarBadge.foreground": "#101313",
    "statusBar.background": "#101313",
    "statusBar.foreground": "#f4f5f1",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#101313",
    "titleBar.activeBackground": "#101313",
    "titleBar.activeForeground": "#f4f5f1",
    "titleBar.inactiveBackground": "#101313",
    "titleBar.inactiveForeground": "#f4f5f160",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#101313dd",
    "tab.activeBackground": "#101313",
    "tab.activeForeground": "#f4f5f1",
    "tab.inactiveBackground": "#171a1a60",
    "tab.inactiveForeground": "#f4f5f180",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#2b2f2f",
    "list.activeSelectionBackground": "#2b2f2f30",
    "list.activeSelectionForeground": "#f4f5f1",
    "list.hoverBackground": "#171a1a40",
    "list.hoverForeground": "#f4f5f1",
    "list.inactiveSelectionBackground": "#2b2f2f15",
    "list.inactiveSelectionForeground": "#f4f5f1",
    "list.highlightForeground": "#2b2f2f",
    "terminal.background": "#101313",
    "terminal.foreground": "#f4f5f1",
    "terminal.ansiBlack": "#101313",
    "terminal.ansiRed": "#55745c",
    "terminal.ansiGreen": "#2b2f2f",
    "terminal.ansiYellow": "#1f4a36",
    "terminal.ansiBlue": "#d9ddd9",
    "terminal.ansiMagenta": "#55745c",
    "terminal.ansiCyan": "#1f4a36",
    "terminal.ansiWhite": "#f4f5f1",
    "input.background": "#171a1a",
    "input.foreground": "#f4f5f1",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#f4f5f160",
    "button.background": "#2b2f2f",
    "button.foreground": "#101313",
    "button.hoverBackground": "#2b2f2fdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#d9ddd9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#d9ddd9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d9ddd9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#2b2f2f"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#1f4a36"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#55745c"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f4f5f1"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f4f5f1"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f4f5f1dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#f4f5f180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f4f5f1"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#1f4a36",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#2b2f2f"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#d9ddd9"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2b2f2f"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#d9ddd9"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#55745c"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#2b2f2f"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#1f4a36"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#2b2f2f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#1f4a36"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#2b2f2f"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#d9ddd9",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#d9ddd9"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#d9ddd9",
        "fontStyle": "italic"
      }
    }
  ]
}
