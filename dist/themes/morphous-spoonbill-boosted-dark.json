    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#d9e4df",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECA779"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#d9e4df",
        "fontStyle": "italic"
      }
