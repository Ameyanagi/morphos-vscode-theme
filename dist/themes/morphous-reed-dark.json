    "titleBar.inactiveBackground": "#6b5c4e",
    "titleBar.inactiveForeground": "#f4f2ea60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#6b5c4edd",
    "tab.activeBackground": "#6b5c4e",
    "tab.activeForeground": "#f4f2ea",
    "tab.inactiveBackground": "#2f312a60",
    "tab.inactiveForeground": "#f4f2ea80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#697b48",
    "list.activeSelectionBackground": "#697b4830",
    "list.activeSelectionForeground": "#f4f2ea",
