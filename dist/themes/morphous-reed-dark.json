    "statusBar.background": "#6b5c4e",
    "statusBar.foreground": "#f4f2ea",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#6b5c4e",
    "titleBar.activeBackground": "#6b5c4e",
