{
  "name": "Morphous Lily of the Valley (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#4F7B4A",
    "foreground": "#F7F8F4",
    "widget.border": "#ffffff15",
    "selection.background": "#E6F1E635",
    "editor.background": "#386339",
    "editor.foreground": "#F7F8F4",
    "editor.lineHighlightBackground": "#2B2F2D40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#4F7B4A",
    "editor.selectionBackground": "#E6F1E635",
    "editor.inactiveSelectionBackground": "#E6F1E63580",
    "editorLineNumber.foreground": "#D7DED680",
    "editorLineNumber.activeForeground": "#4F7B4A",
    "sideBar.background": "#2B2F2D",
    "sideBar.foreground": "#F7F8F4",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#38633980",
    "sideBarSectionHeader.foreground": "#F7F8F4",
    "sideBarTitle.foreground": "#4F7B4A",
    "activityBar.background": "#386339",
    "activityBar.foreground": "#4F7B4A",
    "activityBar.inactiveForeground": "#F7F8F460",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#4F7B4A",
    "activityBarBadge.foreground": "#386339",
    "statusBar.background": "#386339",
    "statusBar.foreground": "#F7F8F4",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#386339",
    "titleBar.activeBackground": "#386339",
    "titleBar.activeForeground": "#F7F8F4",
    "titleBar.inactiveBackground": "#386339",
    "titleBar.inactiveForeground": "#F7F8F460",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#386339dd",
    "tab.activeBackground": "#386339",
    "tab.activeForeground": "#F7F8F4",
    "tab.inactiveBackground": "#2B2F2D60",
    "tab.inactiveForeground": "#F7F8F480",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#4F7B4A",
    "list.activeSelectionBackground": "#4F7B4A30",
    "list.activeSelectionForeground": "#F7F8F4",
    "list.hoverBackground": "#2B2F2D40",
    "list.hoverForeground": "#F7F8F4",
    "list.inactiveSelectionBackground": "#4F7B4A15",
    "list.inactiveSelectionForeground": "#F7F8F4",
    "list.highlightForeground": "#4F7B4A",
    "terminal.background": "#386339",
    "terminal.foreground": "#F7F8F4",
    "terminal.ansiBlack": "#386339",
    "terminal.ansiRed": "#6E564E",
    "terminal.ansiGreen": "#4F7B4A",
    "terminal.ansiYellow": "#7BAE6B",
    "terminal.ansiBlue": "#E6F1E6",
    "terminal.ansiMagenta": "#6E564E",
    "terminal.ansiCyan": "#7BAE6B",
    "terminal.ansiWhite": "#F7F8F4",
    "input.background": "#2B2F2D",
    "input.foreground": "#F7F8F4",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F7F8F460",
    "button.background": "#4F7B4A",
    "button.foreground": "#386339",
    "button.hoverBackground": "#4F7B4Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D7DED6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#E6F1E6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E6F1E6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4F7B4A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#7BAE6B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#6E564E"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F7F8F4"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F7F8F4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F7F8F4dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F7F8F480"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F7F8F4"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#7BAE6B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#4F7B4A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#E6F1E6"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4F7B4A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D7DED6"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#6E564E"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#4F7B4A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#7BAE6B"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#4F7B4A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#7BAE6B"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#4F7B4A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D7DED6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#E6F1E6"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D7DED6",
        "fontStyle": "italic"
      }
    }
  ]
}
