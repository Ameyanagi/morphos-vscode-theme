    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#5F6A36",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#4CC1B3"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#5F6A36",
        "fontStyle": "italic"
      }
