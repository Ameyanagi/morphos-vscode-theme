    "statusBar.background": "#4A1218",
    "statusBar.foreground": "#FFF7F5",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#4A1218",
    "titleBar.activeBackground": "#4A1218",
    "titleBar.activeForeground": "#FFF7F5",
