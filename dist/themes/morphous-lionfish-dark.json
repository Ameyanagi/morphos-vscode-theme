    "terminal.ansiRed": "#3AA6A6",
    "terminal.ansiGreen": "#D62828",
    "terminal.ansiYellow": "#F0A000",
    "terminal.ansiBlue": "#FDE7E6",
    "terminal.ansiMagenta": "#3AA6A6",
    "terminal.ansiCyan": "#F0A000",
    "terminal.ansiWhite": "#FFF7F5",
