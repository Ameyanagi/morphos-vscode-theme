    "terminal.ansiGreen": "#8A3E9B",
    "terminal.ansiYellow": "#B66DD1",
    "terminal.ansiBlue": "#B8C4B5",
    "terminal.ansiMagenta": "#6F7F69",
    "terminal.ansiCyan": "#B66DD1",
    "terminal.ansiWhite": "#F7F7F3",
    "input.background": "#2A1531",
