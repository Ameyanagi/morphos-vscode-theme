    "terminal.ansiYellow": "#55AFE7",
    "terminal.ansiBlue": "#79C6EC",
    "terminal.ansiMagenta": "#F18383",
    "terminal.ansiCyan": "#55AFE7",
    "terminal.ansiWhite": "#F7FAFD",
