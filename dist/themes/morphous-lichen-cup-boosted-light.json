    "terminal.ansiRed": "#763919",
    "terminal.ansiGreen": "#7F9325",
    "terminal.ansiYellow": "#6CA329",
    "terminal.ansiBlue": "#648321",
    "terminal.ansiMagenta": "#763919",
    "terminal.ansiCyan": "#6CA329",
    "terminal.ansiWhite": "#2C2F2B",
    "input.background": "#DDDDD9",
