    "activityBar.inactiveForeground": "#F7F3EA60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#5A9FB8",
    "activityBarBadge.foreground": "#8B5E54",
    "statusBar.background": "#8B5E54",
    "statusBar.foreground": "#F7F3EA",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#8B5E54",
    "titleBar.activeBackground": "#8B5E54",
    "titleBar.activeForeground": "#F7F3EA",
    "titleBar.inactiveBackground": "#8B5E54",
    "titleBar.inactiveForeground": "#F7F3EA60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#8B5E54dd",
    "tab.activeBackground": "#8B5E54",
    "tab.activeForeground": "#F7F3EA",
    "tab.inactiveBackground": "#11212860",
    "tab.inactiveForeground": "#F7F3EA80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#5A9FB8",
    "list.activeSelectionBackground": "#5A9FB830",
    "list.activeSelectionForeground": "#F7F3EA",
    "list.hoverBackground": "#11212840",
    "list.hoverForeground": "#F7F3EA",
    "list.inactiveSelectionBackground": "#5A9FB815",
    "list.inactiveSelectionForeground": "#F7F3EA",
    "list.highlightForeground": "#5A9FB8",
    "terminal.background": "#8B5E54",
    "terminal.foreground": "#F7F3EA",
    "terminal.ansiBlack": "#8B5E54",
    "terminal.ansiRed": "#5F9E66",
    "terminal.ansiGreen": "#5A9FB8",
    "terminal.ansiYellow": "#D08A3B",
    "terminal.ansiBlue": "#9CC0D9",
    "terminal.ansiMagenta": "#5F9E66",
    "terminal.ansiCyan": "#D08A3B",
    "terminal.ansiWhite": "#F7F3EA",
    "input.background": "#112128",
    "input.foreground": "#F7F3EA",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F7F3EA60",
    "button.background": "#5A9FB8",
    "button.foreground": "#8B5E54",
    "button.hoverBackground": "#5A9FB8dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#CFC6B6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#9CC0D9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9CC0D9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#5A9FB8"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#D08A3B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#5F9E66"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F7F3EA"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F7F3EA"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F7F3EAdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F7F3EA80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F7F3EA"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#D08A3B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#5A9FB8"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#9CC0D9"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#5A9FB8"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#CFC6B6"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#5F9E66"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#5A9FB8"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#D08A3B"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#5A9FB8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D08A3B"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#5A9FB8"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#CFC6B6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#9CC0D9"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#CFC6B6",
        "fontStyle": "italic"
      }
    }
  ]
}
