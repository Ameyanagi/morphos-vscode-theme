{
  "name": "Morphous Skink - Boosted (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#679DE9",
    "foreground": "#FBF8F0",
    "widget.border": "#ffffff15",
    "selection.background": "#ECB37935",
    "editor.background": "#040506",
