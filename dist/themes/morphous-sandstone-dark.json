    "terminal.ansiRed": "#e0b66f",
    "terminal.ansiGreen": "#c9795f",
    "terminal.ansiYellow": "#b98d6c",
    "terminal.ansiBlue": "#d6a24c",
    "terminal.ansiMagenta": "#e0b66f",
    "terminal.ansiCyan": "#b98d6c",
    "terminal.ansiWhite": "#fbf3e8",
