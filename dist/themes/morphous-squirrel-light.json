    "terminal.ansiRed": "#8a906c",
    "terminal.ansiGreen": "#c8954f",
    "terminal.ansiYellow": "#56643a",
    "terminal.ansiBlue": "#ead7b6",
    "terminal.ansiMagenta": "#8a906c",
    "terminal.ansiCyan": "#56643a",
    "terminal.ansiWhite": "#241810",
