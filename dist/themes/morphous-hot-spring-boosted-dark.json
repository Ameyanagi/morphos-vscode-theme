    "activityBar.background": "#0A3D48",
    "activityBar.foreground": "#67B1E9",
    "activityBar.inactiveForeground": "#F7F5EF60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#67B1E9",
