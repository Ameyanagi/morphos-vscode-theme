{
  "name": "Morphous Oriole - Boosted (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#E9A667",
    "foreground": "#FAF8F2",
    "widget.border": "#ffffff15",
    "selection.background": "#79EC8135",
    "editor.background": "#1F1F1F",
    "editor.foreground": "#FAF8F2",
    "editor.lineHighlightBackground": "#0A0A0A40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#E9A667",
    "editor.selectionBackground": "#79EC8135",
    "editor.inactiveSelectionBackground": "#79EC813580",
    "editorLineNumber.foreground": "#7A685880",
    "editorLineNumber.activeForeground": "#E9A667",
    "sideBar.background": "#0A0A0A",
    "sideBar.foreground": "#FAF8F2",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#1F1F1F80",
    "sideBarSectionHeader.foreground": "#FAF8F2",
    "sideBarTitle.foreground": "#E9A667",
    "activityBar.background": "#1F1F1F",
    "activityBar.foreground": "#E9A667",
    "activityBar.inactiveForeground": "#FAF8F260",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E9A667",
    "activityBarBadge.foreground": "#1F1F1F",
    "statusBar.background": "#1F1F1F",
    "statusBar.foreground": "#FAF8F2",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#1F1F1F",
    "titleBar.activeBackground": "#1F1F1F",
    "titleBar.activeForeground": "#FAF8F2",
    "titleBar.inactiveBackground": "#1F1F1F",
    "titleBar.inactiveForeground": "#FAF8F260",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#1F1F1Fdd",
    "tab.activeBackground": "#1F1F1F",
    "tab.activeForeground": "#FAF8F2",
    "tab.inactiveBackground": "#0A0A0A60",
    "tab.inactiveForeground": "#FAF8F280",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E9A667",
    "list.activeSelectionBackground": "#E9A66730",
    "list.activeSelectionForeground": "#FAF8F2",
    "list.hoverBackground": "#0A0A0A40",
    "list.hoverForeground": "#FAF8F2",
    "list.inactiveSelectionBackground": "#E9A66715",
    "list.inactiveSelectionForeground": "#FAF8F2",
    "list.highlightForeground": "#E9A667",
    "terminal.background": "#1F1F1F",
    "terminal.foreground": "#FAF8F2",
    "terminal.ansiBlack": "#1F1F1F",
    "terminal.ansiRed": "#F1CE83",
    "terminal.ansiGreen": "#E9A667",
    "terminal.ansiYellow": "#E7C255",
    "terminal.ansiBlue": "#79EC81",
    "terminal.ansiMagenta": "#F1CE83",
    "terminal.ansiCyan": "#E7C255",
    "terminal.ansiWhite": "#FAF8F2",
    "input.background": "#0A0A0A",
    "input.foreground": "#FAF8F2",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#FAF8F260",
    "button.background": "#E9A667",
    "button.foreground": "#1F1F1F",
    "button.hoverBackground": "#E9A667dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A6858",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#79EC81",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#79EC81",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E9A667"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#E7C255"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F1CE83"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#FAF8F2"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#FAF8F2"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FAF8F2dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#FAF8F280"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FAF8F2"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#E7C255",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E9A667"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#79EC81"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E9A667"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#7A6858"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F1CE83"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E9A667"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E7C255"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E9A667",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E7C255"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E9A667"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7A6858",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79EC81"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7A6858",
        "fontStyle": "italic"
      }
    }
  ]
}
