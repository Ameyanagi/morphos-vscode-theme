    "titleBar.inactiveForeground": "#20181260",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFF8EAaa",
    "tab.activeBackground": "#F7F0DF",
    "tab.activeForeground": "#201812",
    "tab.inactiveBackground": "#F7F0DF60",
