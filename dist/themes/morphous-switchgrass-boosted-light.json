    "activityBar.inactiveForeground": "#282A2660",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#934B25",
    "activityBarBadge.foreground": "#FEFDFB",
    "statusBar.background": "#FEFDFB",
    "statusBar.foreground": "#282A26",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FEFDFB",
    "titleBar.activeBackground": "#FEFDFB",
    "titleBar.activeForeground": "#282A26",
    "titleBar.inactiveBackground": "#FEFDFB",
    "titleBar.inactiveForeground": "#282A2660",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F8F6F1aa",
    "tab.activeBackground": "#FEFDFB",
    "tab.activeForeground": "#282A26",
    "tab.inactiveBackground": "#FEFDFB60",
    "tab.inactiveForeground": "#282A2680",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#934B25",
    "list.activeSelectionBackground": "#934B2530",
    "list.activeSelectionForeground": "#282A26",
    "list.hoverBackground": "#F8F6F140",
    "list.hoverForeground": "#282A26",
    "list.inactiveSelectionBackground": "#934B2515",
    "list.inactiveSelectionForeground": "#282A26",
    "list.highlightForeground": "#934B25",
    "terminal.background": "#FEFDFB",
    "terminal.foreground": "#282A26",
    "terminal.ansiBlack": "#282A26",
    "terminal.ansiRed": "#3E7619",
    "terminal.ansiGreen": "#934B25",
    "terminal.ansiYellow": "#A37229",
    "terminal.ansiBlue": "#2F8321",
    "terminal.ansiMagenta": "#3E7619",
    "terminal.ansiCyan": "#A37229",
    "terminal.ansiWhite": "#282A26",
    "input.background": "#F8F6F1",
    "input.foreground": "#282A26",
    "input.border": "#00000015",
    "input.placeholderForeground": "#282A2660",
    "button.background": "#934B25",
    "button.foreground": "#FEFDFB",
    "button.hoverBackground": "#934B25dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D9D2C2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#2F8321",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#2F8321",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#934B25"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A37229"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#3E7619"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#282A26"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#282A26"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#282A26dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#282A2680"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#282A26"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A37229",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#934B25"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#2F8321"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#934B25"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D9D2C2"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#3E7619"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#934B25"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A37229"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#934B25",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A37229"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#934B25"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D9D2C2",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#2F8321"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D9D2C2",
        "fontStyle": "italic"
      }
    }
  ]
}
