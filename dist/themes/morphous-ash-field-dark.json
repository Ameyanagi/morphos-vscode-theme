    "activityBar.inactiveForeground": "#f3f1ec60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#c24a2a",
    "activityBarBadge.foreground": "#2a2d31",
    "statusBar.background": "#2a2d31",
    "statusBar.foreground": "#f3f1ec",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#2a2d31",
    "titleBar.activeBackground": "#2a2d31",
    "titleBar.activeForeground": "#f3f1ec",
    "titleBar.inactiveBackground": "#2a2d31",
    "titleBar.inactiveForeground": "#f3f1ec60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#2a2d31dd",
    "tab.activeBackground": "#2a2d31",
    "tab.activeForeground": "#f3f1ec",
    "tab.inactiveBackground": "#1a1c1f60",
    "tab.inactiveForeground": "#f3f1ec80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#c24a2a",
    "list.activeSelectionBackground": "#c24a2a30",
    "list.activeSelectionForeground": "#f3f1ec",
    "list.hoverBackground": "#1a1c1f40",
    "list.hoverForeground": "#f3f1ec",
    "list.inactiveSelectionBackground": "#c24a2a15",
    "list.inactiveSelectionForeground": "#f3f1ec",
    "list.highlightForeground": "#c24a2a",
    "terminal.background": "#2a2d31",
    "terminal.foreground": "#f3f1ec",
    "terminal.ansiBlack": "#2a2d31",
    "terminal.ansiRed": "#e2793a",
    "terminal.ansiGreen": "#c24a2a",
    "terminal.ansiYellow": "#e2793a",
    "terminal.ansiBlue": "#1a1c1f",
    "terminal.ansiMagenta": "#e2793a",
    "terminal.ansiCyan": "#e2793a",
    "terminal.ansiWhite": "#f3f1ec",
    "input.background": "#1a1c1f",
    "input.foreground": "#f3f1ec",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#f3f1ec60",
    "button.background": "#c24a2a",
    "button.foreground": "#2a2d31",
    "button.hoverBackground": "#c24a2add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a9a791",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#1a1c1f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1a1c1f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#c24a2a"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#e2793a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#e2793a"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f3f1ec"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f3f1ec"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f3f1ecdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#f3f1ec80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f3f1ec"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#e2793a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#c24a2a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#1a1c1f"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c24a2a"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#a9a791"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#e2793a"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#c24a2a"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#e2793a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#c24a2a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#e2793a"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#c24a2a"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#a9a791",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#1a1c1f"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#a9a791",
        "fontStyle": "italic"
      }
    }
  ]
}
