    "editor.inactiveSelectionBackground": "#1a1c1f3580",
    "editorLineNumber.foreground": "#a9a79180",
    "editorLineNumber.activeForeground": "#c24a2a",
    "sideBar.background": "#1a1c1f",
    "sideBar.foreground": "#f3f1ec",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#2a2d3180",
    "sideBarSectionHeader.foreground": "#f3f1ec",
    "sideBarTitle.foreground": "#c24a2a",
    "activityBar.background": "#2a2d31",
