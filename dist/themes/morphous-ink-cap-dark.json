{
  "name": "Morphous Ink Cap (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#6B6B66",
    "foreground": "#F6F6F4",
    "widget.border": "#ffffff15",
    "selection.background": "#EEE9DF35",
    "editor.background": "#08080C",
    "editor.foreground": "#F6F6F4",
    "editor.lineHighlightBackground": "#0F0F0E40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#6B6B66",
    "editor.selectionBackground": "#EEE9DF35",
    "editor.inactiveSelectionBackground": "#EEE9DF3580",
    "editorLineNumber.foreground": "#C9C6BE80",
    "editorLineNumber.activeForeground": "#6B6B66",
    "sideBar.background": "#0F0F0E",
    "sideBar.foreground": "#F6F6F4",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#08080C80",
    "sideBarSectionHeader.foreground": "#F6F6F4",
    "sideBarTitle.foreground": "#6B6B66",
    "activityBar.background": "#08080C",
    "activityBar.foreground": "#6B6B66",
    "activityBar.inactiveForeground": "#F6F6F460",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#6B6B66",
    "activityBarBadge.foreground": "#08080C",
    "statusBar.background": "#08080C",
    "statusBar.foreground": "#F6F6F4",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#08080C",
    "titleBar.activeBackground": "#08080C",
    "titleBar.activeForeground": "#F6F6F4",
    "titleBar.inactiveBackground": "#08080C",
    "titleBar.inactiveForeground": "#F6F6F460",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#08080Cdd",
    "tab.activeBackground": "#08080C",
    "tab.activeForeground": "#F6F6F4",
    "tab.inactiveBackground": "#0F0F0E60",
    "tab.inactiveForeground": "#F6F6F480",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#6B6B66",
    "list.activeSelectionBackground": "#6B6B6630",
    "list.activeSelectionForeground": "#F6F6F4",
    "list.hoverBackground": "#0F0F0E40",
    "list.hoverForeground": "#F6F6F4",
    "list.inactiveSelectionBackground": "#6B6B6615",
    "list.inactiveSelectionForeground": "#F6F6F4",
    "list.highlightForeground": "#6B6B66",
    "terminal.background": "#08080C",
    "terminal.foreground": "#F6F6F4",
    "terminal.ansiBlack": "#08080C",
    "terminal.ansiRed": "#FAFAF6",
    "terminal.ansiGreen": "#6B6B66",
    "terminal.ansiYellow": "#8A8F84",
    "terminal.ansiBlue": "#EEE9DF",
    "terminal.ansiMagenta": "#FAFAF6",
    "terminal.ansiCyan": "#8A8F84",
    "terminal.ansiWhite": "#F6F6F4",
    "input.background": "#0F0F0E",
    "input.foreground": "#F6F6F4",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F6F6F460",
    "button.background": "#6B6B66",
    "button.foreground": "#08080C",
    "button.hoverBackground": "#6B6B66dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#C9C6BE",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#EEE9DF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#EEE9DF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6B6B66"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#8A8F84"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#FAFAF6"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F6F6F4"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F6F6F4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F6F6F4dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F6F6F480"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F6F6F4"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#8A8F84",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#6B6B66"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#EEE9DF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6B6B66"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#C9C6BE"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#FAFAF6"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6B6B66"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#8A8F84"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6B6B66",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8A8F84"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#6B6B66"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#C9C6BE",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#EEE9DF"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#C9C6BE",
        "fontStyle": "italic"
      }
    }
  ]
}
