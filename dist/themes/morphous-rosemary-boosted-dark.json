    "terminal.ansiRed": "#8395F1",
    "terminal.ansiGreen": "#67E993",
    "terminal.ansiYellow": "#556EE7",
    "terminal.ansiBlue": "#A1EC79",
    "terminal.ansiMagenta": "#8395F1",
    "terminal.ansiCyan": "#556EE7",
    "terminal.ansiWhite": "#F6F4EC",
