    "terminal.ansiRed": "#F1B383",
    "terminal.ansiGreen": "#677BE9",
    "terminal.ansiYellow": "#5DE755",
    "terminal.ansiBlue": "#79ABEC",
    "terminal.ansiMagenta": "#F1B383",
    "terminal.ansiCyan": "#5DE755",
    "terminal.ansiWhite": "#FAF7EF",
