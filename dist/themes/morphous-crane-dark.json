{
  "name": "Morphous Crane (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#C8102E",
    "foreground": "#FFFFFF",
    "widget.border": "#ffffff15",
    "selection.background": "#D7D3CC35",
    "editor.background": "#2B2B2F",
    "editor.foreground": "#FFFFFF",
    "editor.lineHighlightBackground": "#080B0D40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#C8102E",
    "editor.selectionBackground": "#D7D3CC35",
    "editor.inactiveSelectionBackground": "#D7D3CC3580",
    "editorLineNumber.foreground": "#9b9b9580",
    "editorLineNumber.activeForeground": "#C8102E",
    "sideBar.background": "#080B0D",
    "sideBar.foreground": "#FFFFFF",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#2B2B2F80",
    "sideBarSectionHeader.foreground": "#FFFFFF",
    "sideBarTitle.foreground": "#C8102E",
    "activityBar.background": "#2B2B2F",
    "activityBar.foreground": "#C8102E",
    "activityBar.inactiveForeground": "#FFFFFF60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#C8102E",
    "activityBarBadge.foreground": "#2B2B2F",
    "statusBar.background": "#2B2B2F",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#2B2B2F",
    "titleBar.activeBackground": "#2B2B2F",
    "titleBar.activeForeground": "#FFFFFF",
    "titleBar.inactiveBackground": "#2B2B2F",
    "titleBar.inactiveForeground": "#FFFFFF60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#2B2B2Fdd",
    "tab.activeBackground": "#2B2B2F",
    "tab.activeForeground": "#FFFFFF",
    "tab.inactiveBackground": "#080B0D60",
    "tab.inactiveForeground": "#FFFFFF80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#C8102E",
    "list.activeSelectionBackground": "#C8102E30",
    "list.activeSelectionForeground": "#FFFFFF",
    "list.hoverBackground": "#080B0D40",
    "list.hoverForeground": "#FFFFFF",
    "list.inactiveSelectionBackground": "#C8102E15",
    "list.inactiveSelectionForeground": "#FFFFFF",
    "list.highlightForeground": "#C8102E",
    "terminal.background": "#2B2B2F",
    "terminal.foreground": "#FFFFFF",
    "terminal.ansiBlack": "#2B2B2F",
    "terminal.ansiRed": "#B8B2A6",
    "terminal.ansiGreen": "#C8102E",
    "terminal.ansiYellow": "#E9E7E3",
    "terminal.ansiBlue": "#D7D3CC",
    "terminal.ansiMagenta": "#B8B2A6",
    "terminal.ansiCyan": "#E9E7E3",
    "terminal.ansiWhite": "#FFFFFF",
    "input.background": "#080B0D",
    "input.foreground": "#FFFFFF",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#FFFFFF60",
    "button.background": "#C8102E",
    "button.foreground": "#2B2B2F",
    "button.hoverBackground": "#C8102Edd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9b9b95",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#D7D3CC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D7D3CC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#C8102E"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#E9E7E3"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#B8B2A6"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFFFFFdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#FFFFFF80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#E9E7E3",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#C8102E"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#D7D3CC"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C8102E"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9b9b95"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#B8B2A6"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#C8102E"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E9E7E3"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#C8102E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E9E7E3"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#C8102E"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9b9b95",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#D7D3CC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9b9b95",
        "fontStyle": "italic"
      }
    }
  ]
}
