    "statusBar.background": "#33443A",
    "statusBar.foreground": "#F6F0E6",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#33443A",
    "titleBar.activeBackground": "#33443A",
    "titleBar.activeForeground": "#F6F0E6",
    "titleBar.inactiveBackground": "#33443A",
    "titleBar.inactiveForeground": "#F6F0E660",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#33443Add",
    "tab.activeBackground": "#33443A",
    "tab.activeForeground": "#F6F0E6",
    "tab.inactiveBackground": "#1C252860",
    "tab.inactiveForeground": "#F6F0E680",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#D56E58",
