    "terminal.ansiGreen": "#5A522E",
    "terminal.ansiYellow": "#F26A18",
    "terminal.ansiBlue": "#6A7A4A",
    "terminal.ansiMagenta": "#E6A21A",
    "terminal.ansiCyan": "#F26A18",
    "terminal.ansiWhite": "#1A1B16",
