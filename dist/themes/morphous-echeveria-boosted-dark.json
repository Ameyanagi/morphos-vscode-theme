    "terminal.ansiRed": "#F18383",
    "terminal.ansiGreen": "#67A8E9",
    "terminal.ansiYellow": "#E755A8",
    "terminal.ansiBlue": "#79C6EC",
    "terminal.ansiMagenta": "#F18383",
    "terminal.ansiCyan": "#E755A8",
    "terminal.ansiWhite": "#F8F9FB",
