    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#ece9df80",
    "sideBarSectionHeader.foreground": "#17191a",
    "sideBarTitle.foreground": "#f25f45",
    "activityBar.background": "#f8f7f1",
