    "terminal.ansiYellow": "#A37E29",
    "terminal.ansiBlue": "#216F83",
    "terminal.ansiMagenta": "#763619",
    "terminal.ansiCyan": "#A37E29",
    "terminal.ansiWhite": "#0F141A",
