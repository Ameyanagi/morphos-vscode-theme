    "list.highlightForeground": "#6B8E2E",
    "terminal.background": "#F7F7F5",
    "terminal.foreground": "#1A1A1A",
    "terminal.ansiBlack": "#1A1A1A",
    "terminal.ansiRed": "#4F3A2B",
    "terminal.ansiGreen": "#6B8E2E",
    "terminal.ansiYellow": "#EBDCC6",
    "terminal.ansiBlue": "#E9E7E4",
    "terminal.ansiMagenta": "#4F3A2B",
    "terminal.ansiCyan": "#EBDCC6",
    "terminal.ansiWhite": "#1A1A1A",
    "input.background": "#FFFFFF",
    "input.foreground": "#1A1A1A",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1A1A1A60",
    "button.background": "#6B8E2E",
    "button.foreground": "#F7F7F5",
    "button.hoverBackground": "#6B8E2Edd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B7C1B1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#E9E7E4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E9E7E4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6B8E2E"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#EBDCC6"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#4F3A2B"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1A1A1A"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1A1A1A"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1A1A1Add",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1A1A1A80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1A1A1A"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#EBDCC6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#6B8E2E"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#E9E7E4"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6B8E2E"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#B7C1B1"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#4F3A2B"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6B8E2E"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#EBDCC6"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6B8E2E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#EBDCC6"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#6B8E2E"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#B7C1B1",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#E9E7E4"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#B7C1B1",
        "fontStyle": "italic"
      }
    }
  ]
}
