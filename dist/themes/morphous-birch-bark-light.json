    "editor.inactiveSelectionBackground": "#E9E7E42580",
    "editorLineNumber.foreground": "#B7C1B180",
    "editorLineNumber.activeForeground": "#6B8E2E",
    "sideBar.background": "#FFFFFF",
    "sideBar.foreground": "#1A1A1A",
    "sideBar.border": "#00000015",
