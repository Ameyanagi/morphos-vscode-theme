    "terminal.ansiYellow": "#E76955",
    "terminal.ansiBlue": "#C8EC79",
    "terminal.ansiMagenta": "#C9F183",
    "terminal.ansiCyan": "#E76955",
    "terminal.ansiWhite": "#f4f1e8",
