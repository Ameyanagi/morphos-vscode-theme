    "activityBar.inactiveForeground": "#f4f7f160",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#88E967",
    "activityBarBadge.foreground": "#040C0A",
    "statusBar.background": "#040C0A",
    "statusBar.foreground": "#f4f7f1",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#040C0A",
    "titleBar.activeBackground": "#040C0A",
    "titleBar.activeForeground": "#f4f7f1",
    "titleBar.inactiveBackground": "#040C0A",
    "titleBar.inactiveForeground": "#f4f7f160",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#040C0Add",
    "tab.activeBackground": "#040C0A",
    "tab.activeForeground": "#f4f7f1",
    "tab.inactiveBackground": "#0C221B60",
    "tab.inactiveForeground": "#f4f7f180",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#88E967",
    "list.activeSelectionBackground": "#88E96730",
    "list.activeSelectionForeground": "#f4f7f1",
    "list.hoverBackground": "#0C221B40",
    "list.hoverForeground": "#f4f7f1",
    "list.inactiveSelectionBackground": "#88E96715",
    "list.inactiveSelectionForeground": "#f4f7f1",
    "list.highlightForeground": "#88E967",
    "terminal.background": "#040C0A",
    "terminal.foreground": "#f4f7f1",
    "terminal.ansiBlack": "#040C0A",
    "terminal.ansiRed": "#F1E383",
    "terminal.ansiGreen": "#88E967",
    "terminal.ansiYellow": "#99E755",
    "terminal.ansiBlue": "#EC9F79",
    "terminal.ansiMagenta": "#F1E383",
    "terminal.ansiCyan": "#99E755",
    "terminal.ansiWhite": "#f4f7f1",
    "input.background": "#0C221B",
    "input.foreground": "#f4f7f1",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#f4f7f160",
    "button.background": "#88E967",
    "button.foreground": "#040C0A",
    "button.hoverBackground": "#88E967dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8b8171",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#EC9F79",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#EC9F79",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#88E967"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#99E755"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F1E383"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f4f7f1"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f4f7f1"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f4f7f1dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#f4f7f180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f4f7f1"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#99E755",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#88E967"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#EC9F79"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#88E967"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#8b8171"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F1E383"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#88E967"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#99E755"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#88E967",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#99E755"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#88E967"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8b8171",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#EC9F79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8b8171",
        "fontStyle": "italic"
      }
    }
  ]
}
