    "terminal.ansiRed": "#4C7619",
    "terminal.ansiGreen": "#5C9325",
    "terminal.ansiYellow": "#A39729",
    "terminal.ansiBlue": "#834821",
    "terminal.ansiMagenta": "#4C7619",
    "terminal.ansiCyan": "#A39729",
    "terminal.ansiWhite": "#211d19",
