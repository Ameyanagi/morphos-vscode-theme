      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#557692",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#557692"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#557692",
        "fontStyle": "italic"
      }
    }
  ]
