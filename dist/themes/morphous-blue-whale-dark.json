      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#305A7A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#4EA6C7"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#305A7A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#4EA6C7"
      }
    },
    {
      "scope": [
