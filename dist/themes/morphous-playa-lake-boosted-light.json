    "terminal.ansiBlack": "#2f322b",
    "terminal.ansiRed": "#765819",
    "terminal.ansiGreen": "#257293",
    "terminal.ansiYellow": "#A37E29",
    "terminal.ansiBlue": "#588321",
    "terminal.ansiMagenta": "#765819",
    "terminal.ansiCyan": "#A37E29",
    "terminal.ansiWhite": "#2f322b",
