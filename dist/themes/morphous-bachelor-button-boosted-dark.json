        "foreground": "#F1CE83"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6770E9"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E7CC55"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6770E9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E7CC55"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
