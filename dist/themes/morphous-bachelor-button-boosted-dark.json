      "settings": {
        "foreground": "#6770E9"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#B9B5A7",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79A7EC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#B9B5A7",
        "fontStyle": "italic"
      }
    }
