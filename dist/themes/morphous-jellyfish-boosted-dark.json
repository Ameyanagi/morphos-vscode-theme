    "sideBarTitle.foreground": "#A467E9",
    "activityBar.background": "#122A4A",
    "activityBar.foreground": "#A467E9",
    "activityBar.inactiveForeground": "#eef8fb60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#A467E9",
    "activityBarBadge.foreground": "#122A4A",
    "statusBar.background": "#122A4A",
    "statusBar.foreground": "#eef8fb",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#122A4A",
    "titleBar.activeBackground": "#122A4A",
    "titleBar.activeForeground": "#eef8fb",
    "titleBar.inactiveBackground": "#122A4A",
    "titleBar.inactiveForeground": "#eef8fb60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#122A4Add",
    "tab.activeBackground": "#122A4A",
    "tab.activeForeground": "#eef8fb",
    "tab.inactiveBackground": "#0A101960",
    "tab.inactiveForeground": "#eef8fb80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#A467E9",
    "list.activeSelectionBackground": "#A467E930",
    "list.activeSelectionForeground": "#eef8fb",
    "list.hoverBackground": "#0A101940",
    "list.hoverForeground": "#eef8fb",
    "list.inactiveSelectionBackground": "#A467E915",
    "list.inactiveSelectionForeground": "#eef8fb",
    "list.highlightForeground": "#A467E9",
    "terminal.background": "#122A4A",
    "terminal.foreground": "#eef8fb",
    "terminal.ansiBlack": "#122A4A",
    "terminal.ansiRed": "#A283F1",
    "terminal.ansiGreen": "#A467E9",
    "terminal.ansiYellow": "#5592E7",
    "terminal.ansiBlue": "#79DDEC",
    "terminal.ansiMagenta": "#A283F1",
    "terminal.ansiCyan": "#5592E7",
    "terminal.ansiWhite": "#eef8fb",
    "input.background": "#0A1019",
    "input.foreground": "#eef8fb",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#eef8fb60",
    "button.background": "#A467E9",
    "button.foreground": "#122A4A",
    "button.hoverBackground": "#A467E9dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8ab9c8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#79DDEC",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#79DDEC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#A467E9"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#5592E7"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#A283F1"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#eef8fb"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#eef8fb"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#eef8fbdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#eef8fb80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#eef8fb"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#5592E7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#A467E9"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#79DDEC"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A467E9"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#8ab9c8"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#A283F1"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#A467E9"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#5592E7"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#A467E9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#5592E7"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#A467E9"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8ab9c8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79DDEC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8ab9c8",
        "fontStyle": "italic"
      }
    }
  ]
}
