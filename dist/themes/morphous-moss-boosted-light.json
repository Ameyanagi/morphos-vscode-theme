{
  "name": "Morphous Moss - Boosted (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#469325",
    "foreground": "#1d2118",
    "widget.border": "#00000015",
    "selection.background": "#5B832125",
    "editor.background": "#F8FBF4",
