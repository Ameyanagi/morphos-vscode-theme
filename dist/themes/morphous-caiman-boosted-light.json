    "tab.inactiveBackground": "#F7F5EE60",
    "tab.inactiveForeground": "#0F111380",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#937925",
    "list.activeSelectionBackground": "#93792530",
    "list.activeSelectionForeground": "#0F1113",
