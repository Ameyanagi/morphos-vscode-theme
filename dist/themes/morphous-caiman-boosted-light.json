    "titleBar.inactiveBackground": "#F7F5EE",
    "titleBar.inactiveForeground": "#0F111360",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#DDD9CBaa",
    "tab.activeBackground": "#F7F5EE",
