    "terminal.ansiYellow": "#E7A555",
    "terminal.ansiBlue": "#BCEC79",
    "terminal.ansiMagenta": "#F1C983",
    "terminal.ansiCyan": "#E7A555",
    "terminal.ansiWhite": "#f6f1e8",
