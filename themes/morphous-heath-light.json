    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#7B58A6",
    "terminal.ansiYellow": "#B08AA2",
    "terminal.ansiBlue": "#5D7055",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#B08AA2",
    "terminal.ansiWhite": "#2A231F",
