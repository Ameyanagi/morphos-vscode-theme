    "terminal.ansiRed": "#A7895A",
    "terminal.ansiGreen": "#F0C000",
    "terminal.ansiYellow": "#5C6838",
    "terminal.ansiBlue": "#6B4A2C",
    "terminal.ansiMagenta": "#A7895A",
    "terminal.ansiCyan": "#5C6838",
    "terminal.ansiWhite": "#0E0E10",
