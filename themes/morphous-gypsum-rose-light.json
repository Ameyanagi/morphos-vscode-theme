    "tab.activeForeground": "#2f261f",
    "tab.inactiveBackground": "#f6efe360",
    "tab.inactiveForeground": "#2f261f80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#c99a6a",
    "list.activeSelectionBackground": "#c99a6a30",
    "list.activeSelectionForeground": "#2f261f",
