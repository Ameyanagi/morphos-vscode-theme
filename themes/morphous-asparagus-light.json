    "editor.inactiveSelectionBackground": "#6FAE5E2580",
    "editorLineNumber.foreground": "#D9E3D380",
    "editorLineNumber.activeForeground": "#2E5E2F",
    "sideBar.background": "#F3EFE2",
    "sideBar.foreground": "#1E1B17",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F3EFE280",
    "sideBarSectionHeader.foreground": "#1E1B17",
    "sideBarTitle.foreground": "#2E5E2F",
    "activityBar.background": "#F7FAF3",
