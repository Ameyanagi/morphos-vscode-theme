    "activityBar.inactiveForeground": "#1E1B1760",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#2E5E2F",
    "activityBarBadge.foreground": "#F7FAF3",
    "statusBar.background": "#F7FAF3",
    "statusBar.foreground": "#1E1B17",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7FAF3",
    "titleBar.activeBackground": "#F7FAF3",
    "titleBar.activeForeground": "#1E1B17",
    "titleBar.inactiveBackground": "#F7FAF3",
    "titleBar.inactiveForeground": "#1E1B1760",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F3EFE2aa",
    "tab.activeBackground": "#F7FAF3",
    "tab.activeForeground": "#1E1B17",
    "tab.inactiveBackground": "#F7FAF360",
    "tab.inactiveForeground": "#1E1B1780",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#2E5E2F",
    "list.activeSelectionBackground": "#2E5E2F30",
    "list.activeSelectionForeground": "#1E1B17",
    "list.hoverBackground": "#F3EFE240",
    "list.hoverForeground": "#1E1B17",
    "list.inactiveSelectionBackground": "#2E5E2F15",
    "list.inactiveSelectionForeground": "#1E1B17",
    "list.highlightForeground": "#2E5E2F",
    "terminal.background": "#F7FAF3",
    "terminal.foreground": "#1E1B17",
    "terminal.ansiBlack": "#1E1B17",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#2E5E2F",
    "terminal.ansiYellow": "#6E4A6F",
    "terminal.ansiBlue": "#6FAE5E",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#6E4A6F",
    "terminal.ansiWhite": "#1E1B17",
    "input.background": "#F3EFE2",
    "input.foreground": "#1E1B17",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1E1B1760",
    "button.background": "#2E5E2F",
    "button.foreground": "#F7FAF3",
    "button.hoverBackground": "#2E5E2Fdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D9E3D3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#6FAE5E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6FAE5E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#2E5E2F"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#6E4A6F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1E1B17"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1E1B17"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1E1B17dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1E1B1780"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1E1B17"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#6E4A6F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#2E5E2F"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#6FAE5E"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2E5E2F"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D9E3D3"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#2E5E2F"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#6E4A6F"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#2E5E2F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#6E4A6F"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#2E5E2F"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D9E3D3",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6FAE5E"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D9E3D3",
        "fontStyle": "italic"
      }
    }
  ]
}