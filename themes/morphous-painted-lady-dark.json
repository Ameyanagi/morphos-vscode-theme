    "selection.background": "#FFB36A35",
    "editor.background": "#3A3A3A",
    "editor.foreground": "#FBF6EC",
    "editor.lineHighlightBackground": "#1A1A1A40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#F07A1A",
    "editor.selectionBackground": "#FFB36A35",
    "editor.inactiveSelectionBackground": "#FFB36A3580",
    "editorLineNumber.foreground": "#F6D9A680",
    "editorLineNumber.activeForeground": "#F07A1A",
    "sideBar.background": "#1A1A1A",
    "sideBar.foreground": "#FBF6EC",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#3A3A3A80",
    "sideBarSectionHeader.foreground": "#FBF6EC",
    "sideBarTitle.foreground": "#F07A1A",
    "activityBar.background": "#3A3A3A",
    "activityBar.foreground": "#F07A1A",
    "activityBar.inactiveForeground": "#FBF6EC60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#F07A1A",
    "activityBarBadge.foreground": "#3A3A3A",
    "statusBar.background": "#3A3A3A",
    "statusBar.foreground": "#FBF6EC",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#3A3A3A",
    "titleBar.activeBackground": "#3A3A3A",
    "titleBar.activeForeground": "#FBF6EC",
    "titleBar.inactiveBackground": "#3A3A3A",
    "titleBar.inactiveForeground": "#FBF6EC60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#3A3A3Add",
    "tab.activeBackground": "#3A3A3A",
    "tab.activeForeground": "#FBF6EC",
    "tab.inactiveBackground": "#1A1A1A60",
    "tab.inactiveForeground": "#FBF6EC80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#F07A1A",
    "list.activeSelectionBackground": "#F07A1A30",
    "list.activeSelectionForeground": "#FBF6EC",
    "list.hoverBackground": "#1A1A1A40",
    "list.hoverForeground": "#FBF6EC",
    "list.inactiveSelectionBackground": "#F07A1A15",
    "list.inactiveSelectionForeground": "#FBF6EC",
    "list.highlightForeground": "#F07A1A",
    "terminal.background": "#3A3A3A",
    "terminal.foreground": "#FBF6EC",
    "terminal.ansiBlack": "#3A3A3A",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#F07A1A",
    "terminal.ansiYellow": "#F5A6B5",
    "terminal.ansiBlue": "#FFB36A",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#F5A6B5",
    "terminal.ansiWhite": "#FBF6EC",
    "input.background": "#1A1A1A",
    "input.foreground": "#FBF6EC",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#FBF6EC60",
    "button.background": "#F07A1A",
    "button.foreground": "#3A3A3A",
    "button.hoverBackground": "#F07A1Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#F6D9A6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#FFB36A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFB36A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#F07A1A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#F5A6B5"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#FBF6EC"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#FBF6EC"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FBF6ECdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#FBF6EC80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FBF6EC"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#F5A6B5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#F07A1A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FFB36A"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#F07A1A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#F6D9A6"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#F07A1A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#F5A6B5"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#F07A1A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#F5A6B5"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#F07A1A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#F6D9A6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#FFB36A"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#F6D9A6",
        "fontStyle": "italic"
      }
    }
  ]
}