{
  "name": "Morphous Paper Wasp Nest (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#F2A100",
    "foreground": "#0D0D0C",
    "widget.border": "#00000015",
    "selection.background": "#7c5cff25",
    "editor.background": "#FAF9F6",
    "editor.foreground": "#0D0D0C",
    "editor.lineHighlightBackground": "#F2F1ED50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#F2A100",
    "editor.selectionBackground": "#7c5cff25",
    "editor.inactiveSelectionBackground": "#7c5cff2580",
    "editorLineNumber.foreground": "#9baec080",
    "editorLineNumber.activeForeground": "#F2A100",
    "sideBar.background": "#F2F1ED",
    "sideBar.foreground": "#0D0D0C",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F2F1ED80",
    "sideBarSectionHeader.foreground": "#0D0D0C",
    "sideBarTitle.foreground": "#F2A100",
    "activityBar.background": "#FAF9F6",
    "activityBar.foreground": "#F2A100",
    "activityBar.inactiveForeground": "#0D0D0C60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#F2A100",
    "activityBarBadge.foreground": "#FAF9F6",
    "statusBar.background": "#FAF9F6",
    "statusBar.foreground": "#0D0D0C",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FAF9F6",
    "titleBar.activeBackground": "#FAF9F6",
    "titleBar.activeForeground": "#0D0D0C",
    "titleBar.inactiveBackground": "#FAF9F6",
    "titleBar.inactiveForeground": "#0D0D0C60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F2F1EDaa",
    "tab.activeBackground": "#FAF9F6",
    "tab.activeForeground": "#0D0D0C",
    "tab.inactiveBackground": "#FAF9F660",
    "tab.inactiveForeground": "#0D0D0C80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#F2A100",
    "list.activeSelectionBackground": "#F2A10030",
    "list.activeSelectionForeground": "#0D0D0C",
    "list.hoverBackground": "#F2F1ED40",
    "list.hoverForeground": "#0D0D0C",
    "list.inactiveSelectionBackground": "#F2A10015",
    "list.inactiveSelectionForeground": "#0D0D0C",
    "list.highlightForeground": "#F2A100",
    "terminal.background": "#FAF9F6",
    "terminal.foreground": "#0D0D0C",
    "terminal.ansiBlack": "#0D0D0C",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#F2A100",
    "terminal.ansiYellow": "#86e7ef",
    "terminal.ansiBlue": "#7c5cff",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#86e7ef",
    "terminal.ansiWhite": "#0D0D0C",
    "input.background": "#F2F1ED",
    "input.foreground": "#0D0D0C",
    "input.border": "#00000015",
    "input.placeholderForeground": "#0D0D0C60",
    "button.background": "#F2A100",
    "button.foreground": "#FAF9F6",
    "button.hoverBackground": "#F2A100dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#7c5cff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7c5cff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#F2A100"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#86e7ef"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#0D0D0C"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#0D0D0C"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#0D0D0Cdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#0D0D0C80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#0D0D0C"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#86e7ef",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#F2A100"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#F2A100"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9baec0"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#F2A100"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#86e7ef"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#F2A100",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#86e7ef"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#F2A100"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    }
  ]
}