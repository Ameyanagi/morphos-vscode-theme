    "terminal.ansiRed": "#5F1976",
    "terminal.ansiGreen": "#6E9325",
    "terminal.ansiYellow": "#A37A29",
    "terminal.ansiBlue": "#835B21",
    "terminal.ansiMagenta": "#5F1976",
    "terminal.ansiCyan": "#A37A29",
    "terminal.ansiWhite": "#2a261b",
