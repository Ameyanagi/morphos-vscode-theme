{
  "name": "Morphous Grasshopper (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#6D7F3A",
    "foreground": "#2E331E",
    "widget.border": "#00000015",
    "selection.background": "#C6A27A25",
    "editor.background": "#FAF7EF",
    "editor.foreground": "#2E331E",
    "editor.lineHighlightBackground": "#F6EEDC50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#6D7F3A",
    "editor.selectionBackground": "#C6A27A25",
    "editor.inactiveSelectionBackground": "#C6A27A2580",
    "editorLineNumber.foreground": "#DCC69A80",
    "editorLineNumber.activeForeground": "#6D7F3A",
    "sideBar.background": "#F6EEDC",
    "sideBar.foreground": "#2E331E",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F6EEDC80",
    "sideBarSectionHeader.foreground": "#2E331E",
    "sideBarTitle.foreground": "#6D7F3A",
    "activityBar.background": "#FAF7EF",
    "activityBar.foreground": "#6D7F3A",
    "activityBar.inactiveForeground": "#2E331E60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#6D7F3A",
    "activityBarBadge.foreground": "#FAF7EF",
    "statusBar.background": "#FAF7EF",
    "statusBar.foreground": "#2E331E",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FAF7EF",
    "titleBar.activeBackground": "#FAF7EF",
    "titleBar.activeForeground": "#2E331E",
    "titleBar.inactiveBackground": "#FAF7EF",
    "titleBar.inactiveForeground": "#2E331E60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F6EEDCaa",
    "tab.activeBackground": "#FAF7EF",
    "tab.activeForeground": "#2E331E",
    "tab.inactiveBackground": "#FAF7EF60",
    "tab.inactiveForeground": "#2E331E80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#6D7F3A",
    "list.activeSelectionBackground": "#6D7F3A30",
    "list.activeSelectionForeground": "#2E331E",
    "list.hoverBackground": "#F6EEDC40",
    "list.hoverForeground": "#2E331E",
    "list.inactiveSelectionBackground": "#6D7F3A15",
    "list.inactiveSelectionForeground": "#2E331E",
    "list.highlightForeground": "#6D7F3A",
    "terminal.background": "#FAF7EF",
    "terminal.foreground": "#2E331E",
    "terminal.ansiBlack": "#2E331E",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#6D7F3A",
    "terminal.ansiYellow": "#D8B46F",
    "terminal.ansiBlue": "#C6A27A",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#D8B46F",
    "terminal.ansiWhite": "#2E331E",
    "input.background": "#F6EEDC",
    "input.foreground": "#2E331E",
    "input.border": "#00000015",
    "input.placeholderForeground": "#2E331E60",
    "button.background": "#6D7F3A",
    "button.foreground": "#FAF7EF",
    "button.hoverBackground": "#6D7F3Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#DCC69A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#C6A27A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C6A27A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6D7F3A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#D8B46F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#2E331E"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#2E331E"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#2E331Edd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2E331E80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#2E331E"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#D8B46F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#6D7F3A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#C6A27A"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6D7F3A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#DCC69A"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6D7F3A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#D8B46F"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6D7F3A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D8B46F"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#6D7F3A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#DCC69A",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#C6A27A"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#DCC69A",
        "fontStyle": "italic"
      }
    }
  ]
}