    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFF0F980",
    "sideBarSectionHeader.foreground": "#1A1620",
    "sideBarTitle.foreground": "#822593",
    "activityBar.background": "#FFFCFA",
    "activityBar.foreground": "#822593",
    "activityBar.inactiveForeground": "#1A162060",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#822593",
    "activityBarBadge.foreground": "#FFFCFA",
    "statusBar.background": "#FFFCFA",
    "statusBar.foreground": "#1A1620",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FFFCFA",
    "titleBar.activeBackground": "#FFFCFA",
    "titleBar.activeForeground": "#1A1620",
    "titleBar.inactiveBackground": "#FFFCFA",
    "titleBar.inactiveForeground": "#1A162060",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFF0F9aa",
    "tab.activeBackground": "#FFFCFA",
    "tab.activeForeground": "#1A1620",
    "tab.inactiveBackground": "#FFFCFA60",
    "tab.inactiveForeground": "#1A162080",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#822593",
    "list.activeSelectionBackground": "#82259330",
    "list.activeSelectionForeground": "#1A1620",
    "list.hoverBackground": "#FFF0F940",
    "list.hoverForeground": "#1A1620",
    "list.inactiveSelectionBackground": "#82259315",
    "list.inactiveSelectionForeground": "#1A1620",
    "list.highlightForeground": "#822593",
    "terminal.background": "#FFFCFA",
    "terminal.foreground": "#1A1620",
    "terminal.ansiBlack": "#1A1620",
    "terminal.ansiRed": "#5F7619",
    "terminal.ansiGreen": "#822593",
    "terminal.ansiYellow": "#A32974",
    "terminal.ansiBlue": "#792183",
    "terminal.ansiMagenta": "#5F7619",
    "terminal.ansiCyan": "#A32974",
    "terminal.ansiWhite": "#1A1620",
    "input.background": "#FFF0F9",
    "input.foreground": "#1A1620",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1A162060",
    "button.background": "#822593",
    "button.foreground": "#FFFCFA",
    "button.hoverBackground": "#822593dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#EEE7DE",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#792183",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#792183",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#822593"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A32974"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#5F7619"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1A1620"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1A1620"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1A1620dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1A162080"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1A1620"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A32974",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#822593"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#792183"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#822593"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#EEE7DE"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#5F7619"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#822593"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A32974"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#822593",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A32974"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#822593"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#EEE7DE",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#792183"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#EEE7DE",
        "fontStyle": "italic"
      }
    }
  ]
}