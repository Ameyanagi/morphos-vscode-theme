    "terminal.ansiRed": "#526a38",
    "terminal.ansiGreen": "#68783a",
    "terminal.ansiYellow": "#c6a74b",
    "terminal.ansiBlue": "#a8ad8f",
    "terminal.ansiMagenta": "#526a38",
    "terminal.ansiCyan": "#c6a74b",
    "terminal.ansiWhite": "#1b1d14",
