    "terminal.ansiYellow": "#85A329",
    "terminal.ansiBlue": "#218321",
    "terminal.ansiMagenta": "#766819",
    "terminal.ansiCyan": "#85A329",
    "terminal.ansiWhite": "#0B1320",
