    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFFBE880",
    "sideBarSectionHeader.foreground": "#1C2433",
    "sideBarTitle.foreground": "#FFF483",
    "activityBar.background": "#FEF7DE",
    "activityBar.foreground": "#FFF483",
    "activityBar.inactiveForeground": "#1C243360",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#FFF483",
    "activityBarBadge.foreground": "#FEF7DE",
    "statusBar.background": "#FEF7DE",
    "statusBar.foreground": "#1C2433",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FEF7DE",
    "titleBar.activeBackground": "#FEF7DE",
    "titleBar.activeForeground": "#1C2433",
    "titleBar.inactiveBackground": "#FEF7DE",
    "titleBar.inactiveForeground": "#1C243360",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFBE8aa",
    "tab.activeBackground": "#FEF7DE",
    "tab.activeForeground": "#1C2433",
    "tab.inactiveBackground": "#FEF7DE60",
    "tab.inactiveForeground": "#1C243380",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#FFF483",
    "list.activeSelectionBackground": "#FFF48330",
    "list.activeSelectionForeground": "#1C2433",
    "list.hoverBackground": "#FFFBE840",
    "list.hoverForeground": "#1C2433",
    "list.inactiveSelectionBackground": "#FFF48315",
    "list.inactiveSelectionForeground": "#1C2433",
    "list.highlightForeground": "#FFF483",
    "terminal.background": "#FEF7DE",
    "terminal.foreground": "#1C2433",
    "terminal.ansiBlack": "#1C2433",
    "terminal.ansiRed": "#F2C94C",
    "terminal.ansiGreen": "#FFF483",
    "terminal.ansiYellow": "#55688E",
    "terminal.ansiBlue": "#7BA358",
    "terminal.ansiMagenta": "#F2C94C",
    "terminal.ansiCyan": "#55688E",
    "terminal.ansiWhite": "#1C2433",
    "input.background": "#FFFBE8",
    "input.foreground": "#1C2433",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1C243360",
    "button.background": "#FFF483",
    "button.foreground": "#FEF7DE",
    "button.hoverBackground": "#FFF483dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A9C29A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#7BA358",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7BA358",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#FFF483"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#55688E"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F2C94C"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1C2433"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1C2433"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1C2433dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1C243380"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1C2433"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#55688E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#FFF483"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7BA358"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFF483"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#A9C29A"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F2C94C"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#FFF483"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#55688E"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#FFF483",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#55688E"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#FFF483"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#A9C29A",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7BA358"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#A9C29A",
        "fontStyle": "italic"
      }
    }
  ]
}