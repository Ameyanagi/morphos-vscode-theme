    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#3D2A2480",
    "sideBarSectionHeader.foreground": "#FFF6F8",
    "sideBarTitle.foreground": "#E96795",
    "activityBar.background": "#3D2A24",
    "activityBar.foreground": "#E96795",
    "activityBar.inactiveForeground": "#FFF6F860",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E96795",
    "activityBarBadge.foreground": "#3D2A24",
    "statusBar.background": "#3D2A24",
    "statusBar.foreground": "#FFF6F8",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#3D2A24",
    "titleBar.activeBackground": "#3D2A24",
    "titleBar.activeForeground": "#FFF6F8",
    "titleBar.inactiveBackground": "#3D2A24",
    "titleBar.inactiveForeground": "#FFF6F860",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#3D2A24dd",
    "tab.activeBackground": "#3D2A24",
    "tab.activeForeground": "#FFF6F8",
    "tab.inactiveBackground": "#1F171460",
    "tab.inactiveForeground": "#FFF6F880",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E96795",
    "list.activeSelectionBackground": "#E9679530",
    "list.activeSelectionForeground": "#FFF6F8",
    "list.hoverBackground": "#1F171440",
    "list.hoverForeground": "#FFF6F8",
    "list.inactiveSelectionBackground": "#E9679515",
    "list.inactiveSelectionForeground": "#FFF6F8",
    "list.highlightForeground": "#E96795",
    "terminal.background": "#3D2A24",
    "terminal.foreground": "#FFF6F8",
    "terminal.ansiBlack": "#3D2A24",
    "terminal.ansiRed": "#A8F183",
    "terminal.ansiGreen": "#E96795",
    "terminal.ansiYellow": "#E7558B",
    "terminal.ansiBlue": "#EC9F79",
    "terminal.ansiMagenta": "#A8F183",
    "terminal.ansiCyan": "#E7558B",
    "terminal.ansiWhite": "#FFF6F8",
    "input.background": "#1F1714",
    "input.foreground": "#FFF6F8",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#FFF6F860",
    "button.background": "#E96795",
    "button.foreground": "#3D2A24",
    "button.hoverBackground": "#E96795dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#EBF3FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#EC9F79",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#EC9F79",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E96795"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#E7558B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#A8F183"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#FFF6F8"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#FFF6F8"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFF6F8dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#FFF6F880"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FFF6F8"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#E7558B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E96795"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#EC9F79"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E96795"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#EBF3FF"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#A8F183"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E96795"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E7558B"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E96795",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E7558B"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E96795"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#EBF3FF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#EC9F79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#EBF3FF",
        "fontStyle": "italic"
      }
    }
  ]
}