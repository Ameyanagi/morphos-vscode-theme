{
  "name": "Morphous Ginkgo (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#E1B400",
    "foreground": "#2D302A",
    "widget.border": "#00000015",
    "selection.background": "#7c5cff25",
    "editor.background": "#F7F5EF",
    "editor.foreground": "#2D302A",
    "editor.lineHighlightBackground": "#DAD6CC50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#E1B400",
    "editor.selectionBackground": "#7c5cff25",
    "editor.inactiveSelectionBackground": "#7c5cff2580",
    "editorLineNumber.foreground": "#6F6A6480",
    "editorLineNumber.activeForeground": "#E1B400",
    "sideBar.background": "#DAD6CC",
    "sideBar.foreground": "#2D302A",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#DAD6CC80",
    "sideBarSectionHeader.foreground": "#2D302A",
    "sideBarTitle.foreground": "#E1B400",
    "activityBar.background": "#F7F5EF",
    "activityBar.foreground": "#E1B400",
    "activityBar.inactiveForeground": "#2D302A60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#E1B400",
    "activityBarBadge.foreground": "#F7F5EF",
    "statusBar.background": "#F7F5EF",
    "statusBar.foreground": "#2D302A",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7F5EF",
    "titleBar.activeBackground": "#F7F5EF",
    "titleBar.activeForeground": "#2D302A",
    "titleBar.inactiveBackground": "#F7F5EF",
    "titleBar.inactiveForeground": "#2D302A60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#DAD6CCaa",
    "tab.activeBackground": "#F7F5EF",
    "tab.activeForeground": "#2D302A",
    "tab.inactiveBackground": "#F7F5EF60",
    "tab.inactiveForeground": "#2D302A80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#E1B400",
    "list.activeSelectionBackground": "#E1B40030",
    "list.activeSelectionForeground": "#2D302A",
    "list.hoverBackground": "#DAD6CC40",
    "list.hoverForeground": "#2D302A",
    "list.inactiveSelectionBackground": "#E1B40015",
    "list.inactiveSelectionForeground": "#2D302A",
    "list.highlightForeground": "#E1B400",
    "terminal.background": "#F7F5EF",
    "terminal.foreground": "#2D302A",
    "terminal.ansiBlack": "#2D302A",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#E1B400",
    "terminal.ansiYellow": "#B7C64A",
    "terminal.ansiBlue": "#7c5cff",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#B7C64A",
    "terminal.ansiWhite": "#2D302A",
    "input.background": "#DAD6CC",
    "input.foreground": "#2D302A",
    "input.border": "#00000015",
    "input.placeholderForeground": "#2D302A60",
    "button.background": "#E1B400",
    "button.foreground": "#F7F5EF",
    "button.hoverBackground": "#E1B400dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6F6A64",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#7c5cff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7c5cff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E1B400"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#B7C64A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#2D302A"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#2D302A"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#2D302Add",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2D302A80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#2D302A"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#B7C64A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E1B400"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E1B400"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#6F6A64"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E1B400"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#B7C64A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E1B400",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#B7C64A"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E1B400"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#6F6A64",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#6F6A64",
        "fontStyle": "italic"
      }
    }
  ]
}