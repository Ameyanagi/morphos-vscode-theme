{
  "name": "Morphous Giraffe (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#c98832",
    "foreground": "#f6ead6",
    "widget.border": "#ffffff15",
    "selection.background": "#7a3f1635",
    "editor.background": "#2c1d15",
    "editor.foreground": "#f6ead6",
    "editor.lineHighlightBackground": "#1f171240",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#c98832",
    "editor.selectionBackground": "#7a3f1635",
    "editor.inactiveSelectionBackground": "#7a3f163580",
    "editorLineNumber.foreground": "#d7b47a80",
    "editorLineNumber.activeForeground": "#c98832",
    "sideBar.background": "#1f1712",
    "sideBar.foreground": "#f6ead6",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#2c1d1580",
    "sideBarSectionHeader.foreground": "#f6ead6",
    "sideBarTitle.foreground": "#c98832",
    "activityBar.background": "#2c1d15",
    "activityBar.foreground": "#c98832",
    "activityBar.inactiveForeground": "#f6ead660",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#c98832",
    "activityBarBadge.foreground": "#2c1d15",
    "statusBar.background": "#2c1d15",
    "statusBar.foreground": "#f6ead6",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#2c1d15",
    "titleBar.activeBackground": "#2c1d15",
    "titleBar.activeForeground": "#f6ead6",
    "titleBar.inactiveBackground": "#2c1d15",
    "titleBar.inactiveForeground": "#f6ead660",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#2c1d15dd",
    "tab.activeBackground": "#2c1d15",
    "tab.activeForeground": "#f6ead6",
    "tab.inactiveBackground": "#1f171260",
    "tab.inactiveForeground": "#f6ead680",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#c98832",
    "list.activeSelectionBackground": "#c9883230",
    "list.activeSelectionForeground": "#f6ead6",
    "list.hoverBackground": "#1f171240",
    "list.hoverForeground": "#f6ead6",
    "list.inactiveSelectionBackground": "#c9883215",
    "list.inactiveSelectionForeground": "#f6ead6",
    "list.highlightForeground": "#c98832",
    "terminal.background": "#2c1d15",
    "terminal.foreground": "#f6ead6",
    "terminal.ansiBlack": "#2c1d15",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#c98832",
    "terminal.ansiYellow": "#8fc6df",
    "terminal.ansiBlue": "#7a3f16",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#8fc6df",
    "terminal.ansiWhite": "#f6ead6",
    "input.background": "#1f1712",
    "input.foreground": "#f6ead6",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#f6ead660",
    "button.background": "#c98832",
    "button.foreground": "#2c1d15",
    "button.hoverBackground": "#c98832dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#d7b47a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#7a3f16",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7a3f16",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#c98832"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#8fc6df"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f6ead6"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f6ead6"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f6ead6dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#f6ead680"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f6ead6"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#8fc6df",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#c98832"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7a3f16"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c98832"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#d7b47a"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#c98832"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#8fc6df"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#c98832",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8fc6df"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#c98832"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#d7b47a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7a3f16"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#d7b47a",
        "fontStyle": "italic"
      }
    }
  ]
}