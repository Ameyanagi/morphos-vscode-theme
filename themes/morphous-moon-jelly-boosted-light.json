    "statusBar.background": "#FBFCFE",
    "statusBar.foreground": "#122033",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FBFCFE",
    "titleBar.activeBackground": "#FBFCFE",
