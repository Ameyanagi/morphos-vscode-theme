        "foreground": "#007A7A"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#0083A6"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#26DCC2"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#0083A6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#26DCC2"
      }
