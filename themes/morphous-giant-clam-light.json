    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#0083A6"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E9E4F1",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#00D4E3"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E9E4F1",
        "fontStyle": "italic"
      }
    }
