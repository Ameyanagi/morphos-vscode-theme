      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E23612"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#FF8A1A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E23612",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#FF8A1A"
      }
