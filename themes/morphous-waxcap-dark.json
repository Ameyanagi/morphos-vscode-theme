        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#FF8A1A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E23612"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
