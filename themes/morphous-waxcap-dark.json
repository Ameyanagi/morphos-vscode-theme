      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#4B4F31",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#4B4F31",
        "fontStyle": "italic"
      }
    }
