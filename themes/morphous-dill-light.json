    "statusBar.background": "#F7F5E8",
    "statusBar.foreground": "#243026",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7F5E8",
    "titleBar.activeBackground": "#F7F5E8",
