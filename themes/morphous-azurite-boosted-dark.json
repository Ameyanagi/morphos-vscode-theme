    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7996EC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#606a78",
        "fontStyle": "italic"
