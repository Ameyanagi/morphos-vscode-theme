    "terminal.ansiRed": "#F1E7D2",
    "terminal.ansiGreen": "#C69A63",
    "terminal.ansiYellow": "#D2B17A",
    "terminal.ansiBlue": "#6B7F4A",
    "terminal.ansiMagenta": "#F1E7D2",
    "terminal.ansiCyan": "#D2B17A",
    "terminal.ansiWhite": "#1E150E",
