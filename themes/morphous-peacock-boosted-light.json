    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#25938F",
    "activityBarBadge.foreground": "#FCFDFC",
    "statusBar.background": "#FCFDFC",
    "statusBar.foreground": "#081220",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FCFDFC",
    "titleBar.activeBackground": "#FCFDFC",
    "titleBar.activeForeground": "#081220",
    "titleBar.inactiveBackground": "#FCFDFC",
    "titleBar.inactiveForeground": "#08122060",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F6F8F7aa",
    "tab.activeBackground": "#FCFDFC",
    "tab.activeForeground": "#081220",
    "tab.inactiveBackground": "#FCFDFC60",
    "tab.inactiveForeground": "#08122080",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#25938F",
    "list.activeSelectionBackground": "#25938F30",
    "list.activeSelectionForeground": "#081220",
    "list.hoverBackground": "#F6F8F740",
    "list.hoverForeground": "#081220",
    "list.inactiveSelectionBackground": "#25938F15",
    "list.inactiveSelectionForeground": "#081220",
    "list.highlightForeground": "#25938F",
    "terminal.background": "#FCFDFC",
    "terminal.foreground": "#081220",
    "terminal.ansiBlack": "#081220",
    "terminal.ansiRed": "#764E19",
    "terminal.ansiGreen": "#25938F",
    "terminal.ansiYellow": "#29A368",
    "terminal.ansiBlue": "#214183",
    "terminal.ansiMagenta": "#764E19",
    "terminal.ansiCyan": "#29A368",
    "terminal.ansiWhite": "#081220",
    "input.background": "#F6F8F7",
    "input.foreground": "#081220",
    "input.border": "#00000015",
    "input.placeholderForeground": "#08122060",
    "button.background": "#25938F",
    "button.foreground": "#FCFDFC",
    "button.hoverBackground": "#25938Fdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#214183",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#214183",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#25938F"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#29A368"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#764E19"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#081220"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#081220"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#081220dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#08122080"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#081220"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#29A368",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#25938F"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#214183"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#25938F"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9baec0"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#764E19"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#25938F"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#29A368"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#25938F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#29A368"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#25938F"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#214183"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    }
  ]
}