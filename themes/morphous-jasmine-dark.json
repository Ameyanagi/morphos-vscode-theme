{
  "name": "Morphous Jasmine (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#2E7D5A",
    "foreground": "#FFFFFF",
    "widget.border": "#ffffff15",
    "selection.background": "#FFF7E535",
    "editor.background": "#0F1E2E",
    "editor.foreground": "#FFFFFF",
    "editor.lineHighlightBackground": "#33415540",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#2E7D5A",
    "editor.selectionBackground": "#FFF7E535",
    "editor.inactiveSelectionBackground": "#FFF7E53580",
    "editorLineNumber.foreground": "#6A7F4A80",
    "editorLineNumber.activeForeground": "#2E7D5A",
    "sideBar.background": "#334155",
    "sideBar.foreground": "#FFFFFF",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#0F1E2E80",
    "sideBarSectionHeader.foreground": "#FFFFFF",
    "sideBarTitle.foreground": "#2E7D5A",
    "activityBar.background": "#0F1E2E",
    "activityBar.foreground": "#2E7D5A",
    "activityBar.inactiveForeground": "#FFFFFF60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#2E7D5A",
    "activityBarBadge.foreground": "#0F1E2E",
    "statusBar.background": "#0F1E2E",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#0F1E2E",
    "titleBar.activeBackground": "#0F1E2E",
    "titleBar.activeForeground": "#FFFFFF",
    "titleBar.inactiveBackground": "#0F1E2E",
    "titleBar.inactiveForeground": "#FFFFFF60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#0F1E2Edd",
    "tab.activeBackground": "#0F1E2E",
    "tab.activeForeground": "#FFFFFF",
    "tab.inactiveBackground": "#33415560",
    "tab.inactiveForeground": "#FFFFFF80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#2E7D5A",
    "list.activeSelectionBackground": "#2E7D5A30",
    "list.activeSelectionForeground": "#FFFFFF",
    "list.hoverBackground": "#33415540",
    "list.hoverForeground": "#FFFFFF",
    "list.inactiveSelectionBackground": "#2E7D5A15",
    "list.inactiveSelectionForeground": "#FFFFFF",
    "list.highlightForeground": "#2E7D5A",
    "terminal.background": "#0F1E2E",
    "terminal.foreground": "#FFFFFF",
    "terminal.ansiBlack": "#0F1E2E",
    "terminal.ansiRed": "#E6C35A",
    "terminal.ansiGreen": "#2E7D5A",
    "terminal.ansiYellow": "#1F5F3B",
    "terminal.ansiBlue": "#FFF7E5",
    "terminal.ansiMagenta": "#E6C35A",
    "terminal.ansiCyan": "#1F5F3B",
    "terminal.ansiWhite": "#FFFFFF",
    "input.background": "#334155",
    "input.foreground": "#FFFFFF",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#FFFFFF60",
    "button.background": "#2E7D5A",
    "button.foreground": "#0F1E2E",
    "button.hoverBackground": "#2E7D5Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6A7F4A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#FFF7E5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFF7E5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#2E7D5A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#1F5F3B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#E6C35A"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFFFFFdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#FFFFFF80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#1F5F3B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#2E7D5A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FFF7E5"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2E7D5A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#6A7F4A"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#E6C35A"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#2E7D5A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#1F5F3B"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#2E7D5A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#1F5F3B"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#2E7D5A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#6A7F4A",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#FFF7E5"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#6A7F4A",
        "fontStyle": "italic"
      }
    }
  ]
}