    "tab.inactiveForeground": "#FDF7FC80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E967AF",
    "list.activeSelectionBackground": "#E967AF30",
    "list.activeSelectionForeground": "#FDF7FC",
    "list.hoverBackground": "#120C1740",
