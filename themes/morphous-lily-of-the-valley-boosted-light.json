    "activityBar.inactiveForeground": "#2B2F2D60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#309325",
    "activityBarBadge.foreground": "#FDFDFC",
    "statusBar.background": "#FDFDFC",
    "statusBar.foreground": "#2B2F2D",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FDFDFC",
    "titleBar.activeBackground": "#FDFDFC",
    "titleBar.activeForeground": "#2B2F2D",
    "titleBar.inactiveBackground": "#FDFDFC",
    "titleBar.inactiveForeground": "#2B2F2D60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F7F7F7aa",
    "tab.activeBackground": "#FDFDFC",
    "tab.activeForeground": "#2B2F2D",
    "tab.inactiveBackground": "#FDFDFC60",
    "tab.inactiveForeground": "#2B2F2D80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#309325",
    "list.activeSelectionBackground": "#30932530",
    "list.activeSelectionForeground": "#2B2F2D",
    "list.hoverBackground": "#F7F7F740",
    "list.hoverForeground": "#2B2F2D",
    "list.inactiveSelectionBackground": "#30932515",
    "list.inactiveSelectionForeground": "#2B2F2D",
    "list.highlightForeground": "#309325",
    "terminal.background": "#FDFDFC",
    "terminal.foreground": "#2B2F2D",
    "terminal.ansiBlack": "#2B2F2D",
    "terminal.ansiRed": "#5F1976",
    "terminal.ansiGreen": "#309325",
    "terminal.ansiYellow": "#45A329",
    "terminal.ansiBlue": "#218321",
    "terminal.ansiMagenta": "#5F1976",
    "terminal.ansiCyan": "#45A329",
    "terminal.ansiWhite": "#2B2F2D",
    "input.background": "#F7F7F7",
    "input.foreground": "#2B2F2D",
    "input.border": "#00000015",
    "input.placeholderForeground": "#2B2F2D60",
    "button.background": "#309325",
    "button.foreground": "#FDFDFC",
    "button.hoverBackground": "#309325dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D7DED6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#218321",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#218321",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#309325"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#45A329"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#2B2F2D"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#2B2F2D"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#2B2F2Ddd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2B2F2D80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#2B2F2D"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#45A329",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#309325"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#218321"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#309325"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D7DED6"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#309325"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#45A329"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#309325",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#45A329"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#309325"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D7DED6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#218321"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D7DED6",
        "fontStyle": "italic"
      }
    }
  ]
}