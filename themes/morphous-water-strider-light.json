    "activityBar.inactiveForeground": "#080D0C60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#2E5E40",
    "activityBarBadge.foreground": "#F6F8F7",
    "statusBar.background": "#F6F8F7",
    "statusBar.foreground": "#080D0C",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F6F8F7",
    "titleBar.activeBackground": "#F6F8F7",
    "titleBar.activeForeground": "#080D0C",
    "titleBar.inactiveBackground": "#F6F8F7",
    "titleBar.inactiveForeground": "#080D0C60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#D8DDE0aa",
    "tab.activeBackground": "#F6F8F7",
    "tab.activeForeground": "#080D0C",
    "tab.inactiveBackground": "#F6F8F760",
    "tab.inactiveForeground": "#080D0C80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#2E5E40",
    "list.activeSelectionBackground": "#2E5E4030",
    "list.activeSelectionForeground": "#080D0C",
