    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#D8DDE080",
    "sideBarSectionHeader.foreground": "#080D0C",
    "sideBarTitle.foreground": "#2E5E40",
    "activityBar.background": "#F6F8F7",
