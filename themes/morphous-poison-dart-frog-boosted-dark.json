        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6790E9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
