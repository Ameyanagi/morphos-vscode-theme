    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#d8c58e80",
    "sideBarSectionHeader.foreground": "#151313",
    "sideBarTitle.foreground": "#f56b16",
    "activityBar.background": "#fbf7ef",
    "activityBar.foreground": "#f56b16",
    "activityBar.inactiveForeground": "#15131360",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#f56b16",
    "activityBarBadge.foreground": "#fbf7ef",
    "statusBar.background": "#fbf7ef",
    "statusBar.foreground": "#151313",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#fbf7ef",
    "titleBar.activeBackground": "#fbf7ef",
    "titleBar.activeForeground": "#151313",
    "titleBar.inactiveBackground": "#fbf7ef",
    "titleBar.inactiveForeground": "#15131360",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#d8c58eaa",
    "tab.activeBackground": "#fbf7ef",
    "tab.activeForeground": "#151313",
    "tab.inactiveBackground": "#fbf7ef60",
    "tab.inactiveForeground": "#15131380",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#f56b16",
    "list.activeSelectionBackground": "#f56b1630",
    "list.activeSelectionForeground": "#151313",
    "list.hoverBackground": "#d8c58e40",
    "list.hoverForeground": "#151313",
    "list.inactiveSelectionBackground": "#f56b1615",
    "list.inactiveSelectionForeground": "#151313",
    "list.highlightForeground": "#f56b16",
    "terminal.background": "#fbf7ef",
    "terminal.foreground": "#151313",
    "terminal.ansiBlack": "#151313",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#f56b16",
    "terminal.ansiYellow": "#7d3f78",
    "terminal.ansiBlue": "#f5b21c",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#7d3f78",
    "terminal.ansiWhite": "#151313",
    "input.background": "#d8c58e",
    "input.foreground": "#151313",
    "input.border": "#00000015",
    "input.placeholderForeground": "#15131360",
    "button.background": "#f56b16",
    "button.foreground": "#fbf7ef",
    "button.hoverBackground": "#f56b16dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#d8d7cf",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#f5b21c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f5b21c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#f56b16"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#7d3f78"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#151313"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#151313"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#151313dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#15131380"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#151313"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#7d3f78",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#f56b16"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#f5b21c"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f56b16"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#d8d7cf"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#f56b16"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#7d3f78"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#f56b16",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#7d3f78"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#f56b16"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#d8d7cf",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#f5b21c"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#d8d7cf",
        "fontStyle": "italic"
      }
    }
  ]
}