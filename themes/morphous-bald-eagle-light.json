    "terminal.ansiYellow": "#D4A017",
    "terminal.ansiBlue": "#2E5E3E",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#D4A017",
    "terminal.ansiWhite": "#382F24",
