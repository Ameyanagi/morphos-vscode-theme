    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#1E40AF",
    "terminal.ansiYellow": "#D4AF37",
    "terminal.ansiBlue": "#385CC4",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#D4AF37",
    "terminal.ansiWhite": "#F7F7F9",
