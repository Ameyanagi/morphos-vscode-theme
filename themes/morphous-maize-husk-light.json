      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E6C478",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#8FA93B"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E6C478",
        "fontStyle": "italic"
      }
