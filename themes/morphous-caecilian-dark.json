{
  "name": "Morphous Caecilian (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#61536f",
    "foreground": "#e2ddd2",
    "widget.border": "#ffffff15",
    "selection.background": "#f4f1ea35",
    "editor.background": "#372d42",
