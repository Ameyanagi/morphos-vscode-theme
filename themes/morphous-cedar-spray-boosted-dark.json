        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#687573"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#83F1AA"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#67E9D1"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E79E55"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#67E9D1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E79E55"
      }
    },
    {
      "scope": [
