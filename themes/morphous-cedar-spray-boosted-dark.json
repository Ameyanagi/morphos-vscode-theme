      ],
      "settings": {
        "foreground": "#67E9D1"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#687573",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79D9EC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#687573",
        "fontStyle": "italic"
      }
    }
