    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#F2F3F4",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79BEEC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#F2F3F4",
        "fontStyle": "italic"
