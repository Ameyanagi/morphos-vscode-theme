{
  "name": "Morphous Seahorse (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#D4A23A",
    "foreground": "#E6F6F4",
    "widget.border": "#ffffff15",
    "selection.background": "#6FAE8A35",
