        "foreground": "#506f9f"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8b8b84",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#536f3d"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8b8b84",
        "fontStyle": "italic"
      }
    }
