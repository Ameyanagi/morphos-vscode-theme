{
  "name": "Morphous Weevil (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#935C25",
    "foreground": "#101b3d",
    "widget.border": "#00000015",
    "selection.background": "#46832125",
    "editor.background": "#F7F3EE",
    "editor.foreground": "#101b3d",
    "editor.lineHighlightBackground": "#FFFBF050",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#935C25",
    "editor.selectionBackground": "#46832125",
    "editor.inactiveSelectionBackground": "#4683212580",
    "editorLineNumber.foreground": "#D6D1C680",
    "editorLineNumber.activeForeground": "#935C25",
    "sideBar.background": "#FFFBF0",
    "sideBar.foreground": "#101b3d",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFFBF080",
    "sideBarSectionHeader.foreground": "#101b3d",
    "sideBarTitle.foreground": "#935C25",
    "activityBar.background": "#F7F3EE",
    "activityBar.foreground": "#935C25",
    "activityBar.inactiveForeground": "#101b3d60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#935C25",
    "activityBarBadge.foreground": "#F7F3EE",
    "statusBar.background": "#F7F3EE",
    "statusBar.foreground": "#101b3d",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7F3EE",
    "titleBar.activeBackground": "#F7F3EE",
    "titleBar.activeForeground": "#101b3d",
    "titleBar.inactiveBackground": "#F7F3EE",
    "titleBar.inactiveForeground": "#101b3d60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFBF0aa",
    "tab.activeBackground": "#F7F3EE",
    "tab.activeForeground": "#101b3d",
    "tab.inactiveBackground": "#F7F3EE60",
    "tab.inactiveForeground": "#101b3d80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#935C25",
    "list.activeSelectionBackground": "#935C2530",
    "list.activeSelectionForeground": "#101b3d",
    "list.hoverBackground": "#FFFBF040",
    "list.hoverForeground": "#101b3d",
    "list.inactiveSelectionBackground": "#935C2515",
    "list.inactiveSelectionForeground": "#101b3d",
    "list.highlightForeground": "#935C25",
    "terminal.background": "#F7F3EE",
    "terminal.foreground": "#101b3d",
    "terminal.ansiBlack": "#101b3d",
    "terminal.ansiRed": "#765819",
    "terminal.ansiGreen": "#935C25",
    "terminal.ansiYellow": "#A37429",
    "terminal.ansiBlue": "#468321",
    "terminal.ansiMagenta": "#765819",
    "terminal.ansiCyan": "#A37429",
    "terminal.ansiWhite": "#101b3d",
    "input.background": "#FFFBF0",
    "input.foreground": "#101b3d",
    "input.border": "#00000015",
    "input.placeholderForeground": "#101b3d60",
    "button.background": "#935C25",
    "button.foreground": "#F7F3EE",
    "button.hoverBackground": "#935C25dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D6D1C6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#468321",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#468321",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#935C25"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A37429"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#765819"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#101b3d"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#101b3d"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#101b3ddd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#101b3d80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#101b3d"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A37429",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#935C25"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#468321"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#935C25"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D6D1C6"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#765819"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#935C25"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A37429"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#935C25",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A37429"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#935C25"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D6D1C6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#468321"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D6D1C6",
        "fontStyle": "italic"
      }
    }
  ]
}