    "terminal.ansiYellow": "#527f92",
    "terminal.ansiBlue": "#c1a47f",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#527f92",
    "terminal.ansiWhite": "#2f261f",
