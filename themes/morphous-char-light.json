    "terminal.ansiRed": "#FF6B3A",
    "terminal.ansiGreen": "#FF666E",
    "terminal.ansiYellow": "#7FB6D6",
    "terminal.ansiBlue": "#A0A8B4",
    "terminal.ansiMagenta": "#FF6B3A",
    "terminal.ansiCyan": "#7FB6D6",
    "terminal.ansiWhite": "#0F1A23",
