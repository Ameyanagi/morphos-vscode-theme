    "terminal.ansiRed": "#B7B8A8",
    "terminal.ansiGreen": "#7B5BA6",
    "terminal.ansiYellow": "#C48ABD",
    "terminal.ansiBlue": "#A078BE",
    "terminal.ansiMagenta": "#B7B8A8",
    "terminal.ansiCyan": "#C48ABD",
    "terminal.ansiWhite": "#F3EEF4",
