        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#E7BB55",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#67C2E9"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#BAEC79"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#67C2E9"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
