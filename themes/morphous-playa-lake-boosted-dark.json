        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#67C2E9"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#d9d2bd",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#BAEC79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#d9d2bd",
        "fontStyle": "italic"
      }
    }
