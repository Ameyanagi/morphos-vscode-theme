      "settings": {
        "foreground": "#8FA083"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#D68773"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#F2D699"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#D68773",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#F2D699"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#D68773"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#EFE6D6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6A4E36"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#EFE6D6",
        "fontStyle": "italic"
      }
    }
