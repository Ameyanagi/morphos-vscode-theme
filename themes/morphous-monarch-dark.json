      "settings": {
        "foreground": "#f8eee0"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#f26a21"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#f2b94b"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#f26a21",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#f2b94b"
      }
    },
    {
      "scope": [
