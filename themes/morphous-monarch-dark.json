      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#b79b70",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6f8f4e"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#b79b70",
        "fontStyle": "italic"
      }
    }
