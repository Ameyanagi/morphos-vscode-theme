      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9aa995",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#8CEC79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9aa995",
        "fontStyle": "italic"
      }
    }
