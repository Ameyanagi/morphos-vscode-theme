    "terminal.ansiGreen": "#619325",
    "terminal.ansiYellow": "#A38929",
    "terminal.ansiBlue": "#508321",
    "terminal.ansiMagenta": "#765A19",
    "terminal.ansiCyan": "#A38929",
    "terminal.ansiWhite": "#243026",
