    "terminal.ansiRed": "#D0B77A",
    "terminal.ansiGreen": "#C2642E",
    "terminal.ansiYellow": "#78AED6",
    "terminal.ansiBlue": "#DE8A58",
    "terminal.ansiMagenta": "#D0B77A",
    "terminal.ansiCyan": "#78AED6",
    "terminal.ansiWhite": "#F6E7D8",
