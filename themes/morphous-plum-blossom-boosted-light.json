      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#A88C86",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#832121"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#A88C86",
        "fontStyle": "italic"
      }
    }
