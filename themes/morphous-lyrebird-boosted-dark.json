    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#100C0A80",
    "sideBarSectionHeader.foreground": "#f5f1e8",
    "sideBarTitle.foreground": "#E99D67",
    "activityBar.background": "#100C0A",
