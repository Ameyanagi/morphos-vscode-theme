    "activityBar.inactiveForeground": "#f5f1e860",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E99D67",
    "activityBarBadge.foreground": "#100C0A",
    "statusBar.background": "#100C0A",
    "statusBar.foreground": "#f5f1e8",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#100C0A",
    "titleBar.activeBackground": "#100C0A",
    "titleBar.activeForeground": "#f5f1e8",
    "titleBar.inactiveBackground": "#100C0A",
    "titleBar.inactiveForeground": "#f5f1e860",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#100C0Add",
    "tab.activeBackground": "#100C0A",
    "tab.activeForeground": "#f5f1e8",
    "tab.inactiveBackground": "#21181260",
    "tab.inactiveForeground": "#f5f1e880",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E99D67",
    "list.activeSelectionBackground": "#E99D6730",
    "list.activeSelectionForeground": "#f5f1e8",
    "list.hoverBackground": "#21181240",
    "list.hoverForeground": "#f5f1e8",
    "list.inactiveSelectionBackground": "#E99D6715",
    "list.inactiveSelectionForeground": "#f5f1e8",
    "list.highlightForeground": "#E99D67",
    "terminal.background": "#100C0A",
    "terminal.foreground": "#f5f1e8",
    "terminal.ansiBlack": "#100C0A",
    "terminal.ansiRed": "#D683F1",
    "terminal.ansiGreen": "#E99D67",
    "terminal.ansiYellow": "#B4E755",
    "terminal.ansiBlue": "#ECEC79",
    "terminal.ansiMagenta": "#D683F1",
    "terminal.ansiCyan": "#B4E755",
    "terminal.ansiWhite": "#f5f1e8",
    "input.background": "#211812",
    "input.foreground": "#f5f1e8",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#f5f1e860",
    "button.background": "#E99D67",
    "button.foreground": "#100C0A",
    "button.hoverBackground": "#E99D67dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a98663",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#ECEC79",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ECEC79",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E99D67"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#B4E755"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#D683F1"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f5f1e8"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f5f1e8"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f5f1e8dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#f5f1e880"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f5f1e8"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#B4E755",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E99D67"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ECEC79"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E99D67"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#a98663"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#D683F1"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E99D67"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#B4E755"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E99D67",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#B4E755"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E99D67"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#a98663",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECEC79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#a98663",
        "fontStyle": "italic"
      }
    }
  ]
}