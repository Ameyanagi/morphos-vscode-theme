    "terminal.ansiBlack": "#4A3D31",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#F26A1A",
    "terminal.ansiYellow": "#4FA7A9",
    "terminal.ansiBlue": "#7c5cff",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#4FA7A9",
    "terminal.ansiWhite": "#4A3D31",
