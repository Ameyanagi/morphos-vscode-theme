{
  "name": "Morphous Pangolin (Dark)",
  "type": "dark",
  "colors": {
    "focusBorder": "#E9A067",
    "foreground": "#F7F4ED",
    "widget.border": "#ffffff15",
    "selection.background": "#ECB47935",
    "editor.background": "#3D2B1F",
    "editor.foreground": "#F7F4ED",
    "editor.lineHighlightBackground": "#090A0B40",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#E9A067",
    "editor.selectionBackground": "#ECB47935",
    "editor.inactiveSelectionBackground": "#ECB4793580",
    "editorLineNumber.foreground": "#8B7A6780",
    "editorLineNumber.activeForeground": "#E9A067",
    "sideBar.background": "#090A0B",
    "sideBar.foreground": "#F7F4ED",
    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#3D2B1F80",
    "sideBarSectionHeader.foreground": "#F7F4ED",
    "sideBarTitle.foreground": "#E9A067",
    "activityBar.background": "#3D2B1F",
    "activityBar.foreground": "#E9A067",
    "activityBar.inactiveForeground": "#F7F4ED60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E9A067",
    "activityBarBadge.foreground": "#3D2B1F",
    "statusBar.background": "#3D2B1F",
    "statusBar.foreground": "#F7F4ED",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#3D2B1F",
    "titleBar.activeBackground": "#3D2B1F",
    "titleBar.activeForeground": "#F7F4ED",
    "titleBar.inactiveBackground": "#3D2B1F",
    "titleBar.inactiveForeground": "#F7F4ED60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#3D2B1Fdd",
    "tab.activeBackground": "#3D2B1F",
    "tab.activeForeground": "#F7F4ED",
    "tab.inactiveBackground": "#090A0B60",
    "tab.inactiveForeground": "#F7F4ED80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E9A067",
    "list.activeSelectionBackground": "#E9A06730",
    "list.activeSelectionForeground": "#F7F4ED",
    "list.hoverBackground": "#090A0B40",
    "list.hoverForeground": "#F7F4ED",
    "list.inactiveSelectionBackground": "#E9A06715",
    "list.inactiveSelectionForeground": "#F7F4ED",
    "list.highlightForeground": "#E9A067",
    "terminal.background": "#3D2B1F",
    "terminal.foreground": "#F7F4ED",
    "terminal.ansiBlack": "#3D2B1F",
    "terminal.ansiRed": "#ABF183",
    "terminal.ansiGreen": "#E9A067",
    "terminal.ansiYellow": "#55E772",
    "terminal.ansiBlue": "#ECB479",
    "terminal.ansiMagenta": "#ABF183",
    "terminal.ansiCyan": "#55E772",
    "terminal.ansiWhite": "#F7F4ED",
    "input.background": "#090A0B",
    "input.foreground": "#F7F4ED",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F7F4ED60",
    "button.background": "#E9A067",
    "button.foreground": "#3D2B1F",
    "button.hoverBackground": "#E9A067dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8B7A67",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#ECB479",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ECB479",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E9A067"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#55E772"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#ABF183"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F7F4ED"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F7F4ED"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F7F4EDdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F7F4ED80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F7F4ED"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#55E772",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E9A067"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ECB479"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E9A067"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#8B7A67"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ABF183"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E9A067"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#55E772"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E9A067",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#55E772"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E9A067"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8B7A67",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECB479"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8B7A67",
        "fontStyle": "italic"
      }
    }
  ]
}