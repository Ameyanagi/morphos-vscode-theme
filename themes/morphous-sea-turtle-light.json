    "terminal.ansiRed": "#d99b76",
    "terminal.ansiGreen": "#6f7f3f",
    "terminal.ansiYellow": "#4f6f42",
    "terminal.ansiBlue": "#2f9aa0",
    "terminal.ansiMagenta": "#d99b76",
    "terminal.ansiCyan": "#4f6f42",
    "terminal.ansiWhite": "#223026",
    "input.background": "#d8d0ae",
