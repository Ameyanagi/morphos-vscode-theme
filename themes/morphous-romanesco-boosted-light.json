    "activityBar.inactiveForeground": "#17200660",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#6E9325",
    "activityBarBadge.foreground": "#FDFCF7",
    "statusBar.background": "#FDFCF7",
    "statusBar.foreground": "#172006",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FDFCF7",
    "titleBar.activeBackground": "#FDFCF7",
    "titleBar.activeForeground": "#172006",
    "titleBar.inactiveBackground": "#FDFCF7",
    "titleBar.inactiveForeground": "#17200660",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFFF0aa",
    "tab.activeBackground": "#FDFCF7",
    "tab.activeForeground": "#172006",
    "tab.inactiveBackground": "#FDFCF760",
    "tab.inactiveForeground": "#17200680",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#6E9325",
    "list.activeSelectionBackground": "#6E932530",
    "list.activeSelectionForeground": "#172006",
    "list.hoverBackground": "#FFFFF040",
    "list.hoverForeground": "#172006",
    "list.inactiveSelectionBackground": "#6E932515",
    "list.inactiveSelectionForeground": "#172006",
    "list.highlightForeground": "#6E9325",
    "terminal.background": "#FDFCF7",
    "terminal.foreground": "#172006",
    "terminal.ansiBlack": "#172006",
    "terminal.ansiRed": "#527619",
    "terminal.ansiGreen": "#6E9325",
    "terminal.ansiYellow": "#7AA329",
    "terminal.ansiBlue": "#628321",
    "terminal.ansiMagenta": "#527619",
    "terminal.ansiCyan": "#7AA329",
    "terminal.ansiWhite": "#172006",
    "input.background": "#FFFFF0",
    "input.foreground": "#172006",
    "input.border": "#00000015",
    "input.placeholderForeground": "#17200660",
    "button.background": "#6E9325",
    "button.foreground": "#FDFCF7",
    "button.hoverBackground": "#6E9325dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#E7E1C8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#628321",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#628321",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6E9325"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#7AA329"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#527619"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#172006"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#172006"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#172006dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#17200680"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#172006"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#7AA329",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#6E9325"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#628321"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6E9325"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#E7E1C8"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#527619"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6E9325"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#7AA329"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6E9325",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#7AA329"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#6E9325"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E7E1C8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#628321"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E7E1C8",
        "fontStyle": "italic"
      }
    }
  ]
}