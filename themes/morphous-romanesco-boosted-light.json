    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFFFF080",
    "sideBarSectionHeader.foreground": "#172006",
    "sideBarTitle.foreground": "#6E9325",
    "activityBar.background": "#FDFCF7",
