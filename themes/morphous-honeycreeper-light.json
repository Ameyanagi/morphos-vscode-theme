    "statusBar.background": "#f8f5ec",
    "statusBar.foreground": "#171717",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#f8f5ec",
    "titleBar.activeBackground": "#f8f5ec",
