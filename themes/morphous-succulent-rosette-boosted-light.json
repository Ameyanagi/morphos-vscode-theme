    "tab.inactiveBackground": "#FCFDFC60",
    "tab.inactiveForeground": "#2E4B4680",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#259379",
    "list.activeSelectionBackground": "#25937930",
