      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#687C93",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#216283"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#687C93",
        "fontStyle": "italic"
      }
    }
