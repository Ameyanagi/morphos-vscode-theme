    "terminal.ansiGreen": "#b80f1a",
    "terminal.ansiYellow": "#f2e7e2",
    "terminal.ansiBlue": "#2f5b2c",
    "terminal.ansiMagenta": "#6b4a2f",
    "terminal.ansiCyan": "#f2e7e2",
    "terminal.ansiWhite": "#2b1e1a",
