      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E6EEF2",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#79B8EC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E6EEF2",
        "fontStyle": "italic"
      }
