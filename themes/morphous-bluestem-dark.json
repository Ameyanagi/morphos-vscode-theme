    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#EDE6D6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#C7A25A"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#EDE6D6",
        "fontStyle": "italic"
      }
