    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#7a563080",
    "sideBarSectionHeader.foreground": "#FFFBD6",
    "sideBarTitle.foreground": "#A8E063",
    "activityBar.background": "#7a5630",
    "activityBar.foreground": "#A8E063",
    "activityBar.inactiveForeground": "#FFFBD660",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#A8E063",
    "activityBarBadge.foreground": "#7a5630",
    "statusBar.background": "#7a5630",
    "statusBar.foreground": "#FFFBD6",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#7a5630",
    "titleBar.activeBackground": "#7a5630",
    "titleBar.activeForeground": "#FFFBD6",
    "titleBar.inactiveBackground": "#7a5630",
    "titleBar.inactiveForeground": "#FFFBD660",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#7a5630dd",
    "tab.activeBackground": "#7a5630",
    "tab.activeForeground": "#FFFBD6",
    "tab.inactiveBackground": "#11111160",
    "tab.inactiveForeground": "#FFFBD680",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#A8E063",
    "list.activeSelectionBackground": "#A8E06330",
    "list.activeSelectionForeground": "#FFFBD6",
    "list.hoverBackground": "#11111140",
    "list.hoverForeground": "#FFFBD6",
    "list.inactiveSelectionBackground": "#A8E06315",
    "list.inactiveSelectionForeground": "#FFFBD6",
    "list.highlightForeground": "#A8E063",
    "terminal.background": "#7a5630",
    "terminal.foreground": "#FFFBD6",
    "terminal.ansiBlack": "#7a5630",
    "terminal.ansiRed": "#67B34D",
    "terminal.ansiGreen": "#A8E063",
    "terminal.ansiYellow": "#FFFBD6",
    "terminal.ansiBlue": "#67B34D",
    "terminal.ansiMagenta": "#67B34D",
    "terminal.ansiCyan": "#FFFBD6",
    "terminal.ansiWhite": "#FFFBD6",
    "input.background": "#111111",
    "input.foreground": "#FFFBD6",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#FFFBD660",
    "button.background": "#A8E063",
    "button.foreground": "#7a5630",
    "button.hoverBackground": "#A8E063dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#74a64a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#67B34D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#67B34D",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#A8E063"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#FFFBD6"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#67B34D"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#FFFBD6"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#FFFBD6"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFFBD6dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#FFFBD680"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FFFBD6"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#FFFBD6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#A8E063"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#67B34D"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A8E063"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#74a64a"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#67B34D"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#A8E063"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#FFFBD6"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#A8E063",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#FFFBD6"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#A8E063"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#74a64a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#67B34D"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#74a64a",
        "fontStyle": "italic"
      }
    }
  ]
}