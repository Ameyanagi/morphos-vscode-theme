    "terminal.ansiRed": "#2E7032",
    "terminal.ansiGreen": "#FF6A3D",
    "terminal.ansiYellow": "#00BCD4",
    "terminal.ansiBlue": "#0097A2",
    "terminal.ansiMagenta": "#2E7032",
    "terminal.ansiCyan": "#00BCD4",
    "terminal.ansiWhite": "#FFF7E8",
