      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#687078",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#FF8A1A"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#687078",
        "fontStyle": "italic"
      }
    }
