      "settings": {
        "foreground": "#4A4F57"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#FF6A00"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#FF6A00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "scope": [
