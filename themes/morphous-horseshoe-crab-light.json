      ],
      "settings": {
        "foreground": "#786146"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#c8c2b6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#9fb7ae"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#c8c2b6",
        "fontStyle": "italic"
      }
    }
