    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F9EFE680",
    "sideBarSectionHeader.foreground": "#2a211f",
    "sideBarTitle.foreground": "#932556",
    "activityBar.background": "#FFFBFA",
    "activityBar.foreground": "#932556",
    "activityBar.inactiveForeground": "#2a211f60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#932556",
    "activityBarBadge.foreground": "#FFFBFA",
    "statusBar.background": "#FFFBFA",
    "statusBar.foreground": "#2a211f",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FFFBFA",
    "titleBar.activeBackground": "#FFFBFA",
    "titleBar.activeForeground": "#2a211f",
    "titleBar.inactiveBackground": "#FFFBFA",
    "titleBar.inactiveForeground": "#2a211f60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F9EFE6aa",
    "tab.activeBackground": "#FFFBFA",
    "tab.activeForeground": "#2a211f",
    "tab.inactiveBackground": "#FFFBFA60",
    "tab.inactiveForeground": "#2a211f80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#932556",
    "list.activeSelectionBackground": "#93255630",
    "list.activeSelectionForeground": "#2a211f",
    "list.hoverBackground": "#F9EFE640",
    "list.hoverForeground": "#2a211f",
    "list.inactiveSelectionBackground": "#93255615",
    "list.inactiveSelectionForeground": "#2a211f",
    "list.highlightForeground": "#932556",
    "terminal.background": "#FFFBFA",
    "terminal.foreground": "#2a211f",
    "terminal.ansiBlack": "#2a211f",
    "terminal.ansiRed": "#5F1976",
    "terminal.ansiGreen": "#932556",
    "terminal.ansiYellow": "#296AA3",
    "terminal.ansiBlue": "#218360",
    "terminal.ansiMagenta": "#5F1976",
    "terminal.ansiCyan": "#296AA3",
    "terminal.ansiWhite": "#2a211f",
    "input.background": "#F9EFE6",
    "input.foreground": "#2a211f",
    "input.border": "#00000015",
    "input.placeholderForeground": "#2a211f60",
    "button.background": "#932556",
    "button.foreground": "#FFFBFA",
    "button.hoverBackground": "#932556dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#c9deda",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#218360",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#218360",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#932556"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#296AA3"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#2a211f"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#2a211f"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#2a211fdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2a211f80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#2a211f"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#296AA3",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#932556"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#218360"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#932556"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#c9deda"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#932556"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#296AA3"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#932556",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#296AA3"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#932556"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#c9deda",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#218360"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#c9deda",
        "fontStyle": "italic"
      }
    }
  ]
}