    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#b98d73",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#EC9879"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#b98d73",
        "fontStyle": "italic"
      }
