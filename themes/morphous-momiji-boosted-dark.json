    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#fbf6ef"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
