      ],
      "settings": {
        "foreground": "#fbf6ef"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#fbf6efdd",
        "fontStyle": "italic"
      }
