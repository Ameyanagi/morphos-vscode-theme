    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#5d564d",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECC879"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#5d564d",
        "fontStyle": "italic"
      }
