    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#E96788",
    "activityBarBadge.foreground": "#1F050B",
    "statusBar.background": "#1F050B",
    "statusBar.foreground": "#fbf8f7",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#1F050B",
    "titleBar.activeBackground": "#1F050B",
    "titleBar.activeForeground": "#fbf8f7",
    "titleBar.inactiveBackground": "#1F050B",
    "titleBar.inactiveForeground": "#fbf8f760",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#1F050Bdd",
    "tab.activeBackground": "#1F050B",
    "tab.activeForeground": "#fbf8f7",
    "tab.inactiveBackground": "#11040660",
    "tab.inactiveForeground": "#fbf8f780",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#E96788",
    "list.activeSelectionBackground": "#E9678830",
    "list.activeSelectionForeground": "#fbf8f7",
    "list.hoverBackground": "#11040640",
    "list.hoverForeground": "#fbf8f7",
    "list.inactiveSelectionBackground": "#E9678815",
    "list.inactiveSelectionForeground": "#fbf8f7",
    "list.highlightForeground": "#E96788",
    "terminal.background": "#1F050B",
    "terminal.foreground": "#fbf8f7",
    "terminal.ansiBlack": "#1F050B",
    "terminal.ansiRed": "#F18399",
    "terminal.ansiGreen": "#E96788",
    "terminal.ansiYellow": "#E7557A",
    "terminal.ansiBlue": "#EC798E",
    "terminal.ansiMagenta": "#F18399",
    "terminal.ansiCyan": "#E7557A",
    "terminal.ansiWhite": "#fbf8f7",
    "input.background": "#110406",
    "input.foreground": "#fbf8f7",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#fbf8f760",
    "button.background": "#E96788",
    "button.foreground": "#1F050B",
    "button.hoverBackground": "#E96788dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#68646a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#EC798E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#EC798E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E96788"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#E7557A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F18399"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#fbf8f7"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#fbf8f7"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#fbf8f7dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#fbf8f780"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#fbf8f7"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#E7557A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E96788"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#EC798E"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E96788"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#68646a"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F18399"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#E96788"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#E7557A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#E96788",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E7557A"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#E96788"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#68646a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#EC798E"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#68646a",
        "fontStyle": "italic"
      }
    }
  ]
}