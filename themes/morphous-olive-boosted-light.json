    "terminal.ansiYellow": "#A38529",
    "terminal.ansiBlue": "#728321",
    "terminal.ansiMagenta": "#497619",
    "terminal.ansiCyan": "#A38529",
    "terminal.ansiWhite": "#1b1d14",
