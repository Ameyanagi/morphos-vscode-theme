    "titleBar.inactiveForeground": "#2b282660",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#E0DBD7aa",
    "tab.activeBackground": "#FDFDFC",
    "tab.activeForeground": "#2b2826",
