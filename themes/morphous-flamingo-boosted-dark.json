    "terminal.ansiRed": "#F19583",
    "terminal.ansiGreen": "#E96786",
    "terminal.ansiYellow": "#55C7E7",
    "terminal.ansiBlue": "#EC8A79",
    "terminal.ansiMagenta": "#F19583",
    "terminal.ansiCyan": "#55C7E7",
    "terminal.ansiWhite": "#fff7f2",
