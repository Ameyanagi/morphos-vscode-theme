      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8e8883",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#94EC79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8e8883",
        "fontStyle": "italic"
      }
    }
