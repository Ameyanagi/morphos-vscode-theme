    "tab.inactiveBackground": "#FCFBF860",
    "tab.inactiveForeground": "#28313680",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#255C93",
    "list.activeSelectionBackground": "#255C9330",
    "list.activeSelectionForeground": "#283136",
