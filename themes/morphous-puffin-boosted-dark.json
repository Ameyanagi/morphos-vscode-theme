    "terminal.ansiGreen": "#E97B67",
    "terminal.ansiYellow": "#55BEE7",
    "terminal.ansiBlue": "#ECB379",
    "terminal.ansiMagenta": "#83E1F1",
    "terminal.ansiCyan": "#55BEE7",
    "terminal.ansiWhite": "#f8f7f1",
