    "activityBarBadge.foreground": "#4a3c46",
    "statusBar.background": "#4a3c46",
    "statusBar.foreground": "#f0e6e2",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#4a3c46",
    "titleBar.activeBackground": "#4a3c46",
    "titleBar.activeForeground": "#f0e6e2",
    "titleBar.inactiveBackground": "#4a3c46",
    "titleBar.inactiveForeground": "#f0e6e260",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#4a3c46dd",
    "tab.activeBackground": "#4a3c46",
    "tab.activeForeground": "#f0e6e2",
    "tab.inactiveBackground": "#1d142760",
    "tab.inactiveForeground": "#f0e6e280",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#9f3150",
    "list.activeSelectionBackground": "#9f315030",
    "list.activeSelectionForeground": "#f0e6e2",
    "list.hoverBackground": "#1d142740",
