    "activityBar.inactiveForeground": "#1E221660",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#679325",
    "activityBarBadge.foreground": "#FAF7F0",
    "statusBar.background": "#FAF7F0",
    "statusBar.foreground": "#1E2216",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FAF7F0",
    "titleBar.activeBackground": "#FAF7F0",
    "titleBar.activeForeground": "#1E2216",
    "titleBar.inactiveBackground": "#FAF7F0",
    "titleBar.inactiveForeground": "#1E221660",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FCF9F3aa",
    "tab.activeBackground": "#FAF7F0",
    "tab.activeForeground": "#1E2216",
    "tab.inactiveBackground": "#FAF7F060",
    "tab.inactiveForeground": "#1E221680",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#679325",
    "list.activeSelectionBackground": "#67932530",
    "list.activeSelectionForeground": "#1E2216",
    "list.hoverBackground": "#FCF9F340",
    "list.hoverForeground": "#1E2216",
    "list.inactiveSelectionBackground": "#67932515",
    "list.inactiveSelectionForeground": "#1E2216",
    "list.highlightForeground": "#679325",
    "terminal.background": "#FAF7F0",
    "terminal.foreground": "#1E2216",
    "terminal.ansiBlack": "#1E2216",
    "terminal.ansiRed": "#765D19",
    "terminal.ansiGreen": "#679325",
    "terminal.ansiYellow": "#A38729",
    "terminal.ansiBlue": "#628321",
    "terminal.ansiMagenta": "#765D19",
    "terminal.ansiCyan": "#A38729",
    "terminal.ansiWhite": "#1E2216",
    "input.background": "#FCF9F3",
    "input.foreground": "#1E2216",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1E221660",
    "button.background": "#679325",
    "button.foreground": "#FAF7F0",
    "button.hoverBackground": "#679325dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D7C6A6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#628321",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#628321",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#679325"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A38729"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#765D19"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1E2216"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1E2216"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1E2216dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1E221680"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1E2216"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A38729",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#679325"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#628321"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#679325"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D7C6A6"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#765D19"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#679325"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A38729"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#679325",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A38729"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#679325"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D7C6A6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#628321"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D7C6A6",
        "fontStyle": "italic"
      }
    }
  ]
}