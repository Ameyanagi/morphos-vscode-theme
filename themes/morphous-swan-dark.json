    "statusBar.background": "#0e1320",
    "statusBar.foreground": "#f6f7f4",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#0e1320",
    "titleBar.activeBackground": "#0e1320",
