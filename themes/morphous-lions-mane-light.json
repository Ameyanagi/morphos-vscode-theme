    "statusBar.background": "#FBF7F1",
    "statusBar.foreground": "#2B1F15",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FBF7F1",
    "titleBar.activeBackground": "#FBF7F1",
