{
  "name": "Morphous Nautilus (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#1E5A7A",
    "foreground": "#0F2131",
    "widget.border": "#00000015",
    "selection.background": "#EADCC525",
    "editor.background": "#F7F3EC",
    "editor.foreground": "#0F2131",
    "editor.lineHighlightBackground": "#FFFFFF50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#1E5A7A",
    "editor.selectionBackground": "#EADCC525",
    "editor.inactiveSelectionBackground": "#EADCC52580",
    "editorLineNumber.foreground": "#F2E7D580",
    "editorLineNumber.activeForeground": "#1E5A7A",
    "sideBar.background": "#FFFFFF",
    "sideBar.foreground": "#0F2131",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFFFFF80",
    "sideBarSectionHeader.foreground": "#0F2131",
    "sideBarTitle.foreground": "#1E5A7A",
    "activityBar.background": "#F7F3EC",
    "activityBar.foreground": "#1E5A7A",
    "activityBar.inactiveForeground": "#0F213160",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#1E5A7A",
    "activityBarBadge.foreground": "#F7F3EC",
    "statusBar.background": "#F7F3EC",
    "statusBar.foreground": "#0F2131",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7F3EC",
    "titleBar.activeBackground": "#F7F3EC",
    "titleBar.activeForeground": "#0F2131",
    "titleBar.inactiveBackground": "#F7F3EC",
    "titleBar.inactiveForeground": "#0F213160",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFFFFaa",
    "tab.activeBackground": "#F7F3EC",
    "tab.activeForeground": "#0F2131",
    "tab.inactiveBackground": "#F7F3EC60",
    "tab.inactiveForeground": "#0F213180",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#1E5A7A",
    "list.activeSelectionBackground": "#1E5A7A30",
    "list.activeSelectionForeground": "#0F2131",
    "list.hoverBackground": "#FFFFFF40",
    "list.hoverForeground": "#0F2131",
    "list.inactiveSelectionBackground": "#1E5A7A15",
    "list.inactiveSelectionForeground": "#0F2131",
    "list.highlightForeground": "#1E5A7A",
    "terminal.background": "#F7F3EC",
    "terminal.foreground": "#0F2131",
    "terminal.ansiBlack": "#0F2131",
    "terminal.ansiRed": "#B6E0EC",
    "terminal.ansiGreen": "#1E5A7A",
    "terminal.ansiYellow": "#C65A2B",
    "terminal.ansiBlue": "#EADCC5",
    "terminal.ansiMagenta": "#B6E0EC",
    "terminal.ansiCyan": "#C65A2B",
    "terminal.ansiWhite": "#0F2131",
    "input.background": "#FFFFFF",
    "input.foreground": "#0F2131",
    "input.border": "#00000015",
    "input.placeholderForeground": "#0F213160",
    "button.background": "#1E5A7A",
    "button.foreground": "#F7F3EC",
    "button.hoverBackground": "#1E5A7Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#F2E7D5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#EADCC5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#EADCC5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#1E5A7A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#C65A2B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#B6E0EC"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#0F2131"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#0F2131"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#0F2131dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#0F213180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#0F2131"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#C65A2B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#1E5A7A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#EADCC5"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1E5A7A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#F2E7D5"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#B6E0EC"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#1E5A7A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#C65A2B"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#1E5A7A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C65A2B"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#1E5A7A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#F2E7D5",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#EADCC5"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#F2E7D5",
        "fontStyle": "italic"
      }
    }
  ]
}