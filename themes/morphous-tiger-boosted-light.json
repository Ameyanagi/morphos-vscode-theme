{
  "name": "Morphous Tiger (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#935325",
    "foreground": "#111111",
    "widget.border": "#00000015",
    "selection.background": "#21833B25",
    "editor.background": "#FBFBF8",
    "editor.foreground": "#111111",
    "editor.lineHighlightBackground": "#DDBB9850",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#935325",
    "editor.selectionBackground": "#21833B25",
    "editor.inactiveSelectionBackground": "#21833B2580",
    "editorLineNumber.foreground": "#e6e2da80",
    "editorLineNumber.activeForeground": "#935325",
    "sideBar.background": "#DDBB98",
    "sideBar.foreground": "#111111",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#DDBB9880",
    "sideBarSectionHeader.foreground": "#111111",
    "sideBarTitle.foreground": "#935325",
    "activityBar.background": "#FBFBF8",
    "activityBar.foreground": "#935325",
    "activityBar.inactiveForeground": "#11111160",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#935325",
    "activityBarBadge.foreground": "#FBFBF8",
    "statusBar.background": "#FBFBF8",
    "statusBar.foreground": "#111111",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FBFBF8",
    "titleBar.activeBackground": "#FBFBF8",
    "titleBar.activeForeground": "#111111",
    "titleBar.inactiveBackground": "#FBFBF8",
    "titleBar.inactiveForeground": "#11111160",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#DDBB98aa",
    "tab.activeBackground": "#FBFBF8",
    "tab.activeForeground": "#111111",
    "tab.inactiveBackground": "#FBFBF860",
    "tab.inactiveForeground": "#11111180",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#935325",
    "list.activeSelectionBackground": "#93532530",
    "list.activeSelectionForeground": "#111111",
    "list.hoverBackground": "#DDBB9840",
    "list.hoverForeground": "#111111",
    "list.inactiveSelectionBackground": "#93532515",
    "list.inactiveSelectionForeground": "#111111",
    "list.highlightForeground": "#935325",
    "terminal.background": "#FBFBF8",
    "terminal.foreground": "#111111",
    "terminal.ansiBlack": "#111111",
    "terminal.ansiRed": "#5F1976",
    "terminal.ansiGreen": "#935325",
    "terminal.ansiYellow": "#A37E29",
    "terminal.ansiBlue": "#21833B",
    "terminal.ansiMagenta": "#5F1976",
    "terminal.ansiCyan": "#A37E29",
    "terminal.ansiWhite": "#111111",
    "input.background": "#DDBB98",
    "input.foreground": "#111111",
    "input.border": "#00000015",
    "input.placeholderForeground": "#11111160",
    "button.background": "#935325",
    "button.foreground": "#FBFBF8",
    "button.hoverBackground": "#935325dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#e6e2da",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#21833B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#21833B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#935325"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A37E29"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#111111dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#11111180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A37E29",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#935325"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#21833B"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#935325"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#e6e2da"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#935325"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A37E29"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#935325",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A37E29"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#935325"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#e6e2da",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#21833B"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#e6e2da",
        "fontStyle": "italic"
      }
    }
  ]
}