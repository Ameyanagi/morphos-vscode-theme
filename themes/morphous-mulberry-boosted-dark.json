      "settings": {
        "foreground": "#F1C083"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#B567E9"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#83E755"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#B567E9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#83E755"
      }
    },
    {
      "scope": [
        "string.other.link.title",
