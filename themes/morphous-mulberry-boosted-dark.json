      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#785b86",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#CF79EC"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#785b86",
        "fontStyle": "italic"
      }
    }
