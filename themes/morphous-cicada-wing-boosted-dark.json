      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7b7566",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECD179"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7b7566",
        "fontStyle": "italic"
      }
    }
