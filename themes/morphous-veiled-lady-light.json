    "terminal.ansiGreen": "#686E2E",
    "terminal.ansiYellow": "#B0B9A7",
    "terminal.ansiBlue": "#334036",
    "terminal.ansiMagenta": "#7A6B34",
    "terminal.ansiCyan": "#B0B9A7",
    "terminal.ansiWhite": "#0C130E",
