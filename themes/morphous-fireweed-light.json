    "editor.inactiveSelectionBackground": "#3C8D3A2580",
    "editorLineNumber.foreground": "#858A9180",
    "editorLineNumber.activeForeground": "#D0108A",
    "sideBar.background": "#F4F5F6",
    "sideBar.foreground": "#1C1A1E",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F4F5F680",
