    "terminal.background": "#FFFDFB",
    "terminal.foreground": "#1A1620",
    "terminal.ansiBlack": "#1A1620",
    "terminal.ansiRed": "#A7D61A",
    "terminal.ansiGreen": "#783C82",
    "terminal.ansiYellow": "#F2A6D5",
    "terminal.ansiBlue": "#5E2464",
    "terminal.ansiMagenta": "#A7D61A",
    "terminal.ansiCyan": "#F2A6D5",
    "terminal.ansiWhite": "#1A1620",
    "input.background": "#FFF5FB",
    "input.foreground": "#1A1620",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1A162060",
    "button.background": "#783C82",
    "button.foreground": "#FFFDFB",
    "button.hoverBackground": "#783C82dd"
