    "statusBar.background": "#FFFDFB",
    "statusBar.foreground": "#1A1620",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FFFDFB",
    "titleBar.activeBackground": "#FFFDFB",
    "titleBar.activeForeground": "#1A1620",
