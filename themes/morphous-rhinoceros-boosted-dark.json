    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#93E967",
    "activityBarBadge.foreground": "#242826",
    "statusBar.background": "#242826",
    "statusBar.foreground": "#f2eee3",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#242826",
    "titleBar.activeBackground": "#242826",
    "titleBar.activeForeground": "#f2eee3",
    "titleBar.inactiveBackground": "#242826",
    "titleBar.inactiveForeground": "#f2eee360",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#242826dd",
    "tab.activeBackground": "#242826",
    "tab.activeForeground": "#f2eee3",
    "tab.inactiveBackground": "#13151460",
    "tab.inactiveForeground": "#f2eee380",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#93E967",
    "list.activeSelectionBackground": "#93E96730",
    "list.activeSelectionForeground": "#f2eee3",
    "list.hoverBackground": "#13151440",
    "list.hoverForeground": "#f2eee3",
    "list.inactiveSelectionBackground": "#93E96715",
    "list.inactiveSelectionForeground": "#f2eee3",
    "list.highlightForeground": "#93E967",
    "terminal.background": "#242826",
    "terminal.foreground": "#f2eee3",
    "terminal.ansiBlack": "#242826",
    "terminal.ansiRed": "#F1DD83",
    "terminal.ansiGreen": "#93E967",
    "terminal.ansiYellow": "#CFE755",
    "terminal.ansiBlue": "#ECC979",
    "terminal.ansiMagenta": "#F1DD83",
    "terminal.ansiCyan": "#CFE755",
    "terminal.ansiWhite": "#f2eee3",
    "input.background": "#131514",
    "input.foreground": "#f2eee3",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#f2eee360",
    "button.background": "#93E967",
    "button.foreground": "#242826",
    "button.hoverBackground": "#93E967dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#ECC979",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ECC979",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#93E967"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#CFE755"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#F1DD83"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f2eee3"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f2eee3"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f2eee3dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#f2eee380"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f2eee3"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#CFE755",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#93E967"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ECC979"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#93E967"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9baec0"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F1DD83"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#93E967"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#CFE755"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#93E967",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#CFE755"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#93E967"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECC979"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    }
  ]
}