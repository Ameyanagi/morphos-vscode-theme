    "terminal.ansiRed": "#90F183",
    "terminal.ansiGreen": "#E9B567",
    "terminal.ansiYellow": "#E76255",
    "terminal.ansiBlue": "#ECBA79",
    "terminal.ansiMagenta": "#90F183",
    "terminal.ansiCyan": "#E76255",
    "terminal.ansiWhite": "#FBF6EE",
