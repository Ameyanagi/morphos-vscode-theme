    "terminal.ansiRed": "#E7B218",
    "terminal.ansiGreen": "#c32878",
    "terminal.ansiYellow": "#E53AA3",
    "terminal.ansiBlue": "#6FAF5E",
    "terminal.ansiMagenta": "#E7B218",
    "terminal.ansiCyan": "#E53AA3",
    "terminal.ansiWhite": "#2b1726",
