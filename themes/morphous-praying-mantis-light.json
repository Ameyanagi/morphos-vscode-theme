{
  "name": "Morphous Praying Mantis (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#6FAF5D",
    "foreground": "#1F241C",
    "widget.border": "#00000015",
    "selection.background": "#D9B38625",
    "editor.background": "#F3F1E7",
    "editor.foreground": "#1F241C",
    "editor.lineHighlightBackground": "#E7E0C650",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#6FAF5D",
    "editor.selectionBackground": "#D9B38625",
    "editor.inactiveSelectionBackground": "#D9B3862580",
    "editorLineNumber.foreground": "#8A946A80",
    "editorLineNumber.activeForeground": "#6FAF5D",
    "sideBar.background": "#E7E0C6",
    "sideBar.foreground": "#1F241C",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#E7E0C680",
    "sideBarSectionHeader.foreground": "#1F241C",
    "sideBarTitle.foreground": "#6FAF5D",
    "activityBar.background": "#F3F1E7",
    "activityBar.foreground": "#6FAF5D",
    "activityBar.inactiveForeground": "#1F241C60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#6FAF5D",
    "activityBarBadge.foreground": "#F3F1E7",
    "statusBar.background": "#F3F1E7",
    "statusBar.foreground": "#1F241C",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F3F1E7",
    "titleBar.activeBackground": "#F3F1E7",
    "titleBar.activeForeground": "#1F241C",
    "titleBar.inactiveBackground": "#F3F1E7",
    "titleBar.inactiveForeground": "#1F241C60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#E7E0C6aa",
    "tab.activeBackground": "#F3F1E7",
    "tab.activeForeground": "#1F241C",
    "tab.inactiveBackground": "#F3F1E760",
    "tab.inactiveForeground": "#1F241C80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#6FAF5D",
    "list.activeSelectionBackground": "#6FAF5D30",
    "list.activeSelectionForeground": "#1F241C",
    "list.hoverBackground": "#E7E0C640",
    "list.hoverForeground": "#1F241C",
    "list.inactiveSelectionBackground": "#6FAF5D15",
    "list.inactiveSelectionForeground": "#1F241C",
    "list.highlightForeground": "#6FAF5D",
    "terminal.background": "#F3F1E7",
    "terminal.foreground": "#1F241C",
    "terminal.ansiBlack": "#1F241C",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#6FAF5D",
    "terminal.ansiYellow": "#86e7ef",
    "terminal.ansiBlue": "#D9B386",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#86e7ef",
    "terminal.ansiWhite": "#1F241C",
    "input.background": "#E7E0C6",
    "input.foreground": "#1F241C",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1F241C60",
    "button.background": "#6FAF5D",
    "button.foreground": "#F3F1E7",
    "button.hoverBackground": "#6FAF5Ddd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A946A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#D9B386",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D9B386",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6FAF5D"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#86e7ef"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#1F241C"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#1F241C"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#1F241Cdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#1F241C80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1F241C"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#86e7ef",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#6FAF5D"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#D9B386"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6FAF5D"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#8A946A"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6FAF5D"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#86e7ef"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#6FAF5D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#86e7ef"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#6FAF5D"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8A946A",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#D9B386"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8A946A",
        "fontStyle": "italic"
      }
    }
  ]
}