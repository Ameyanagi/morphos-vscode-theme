    "terminal.ansiGreen": "#67AAE9",
    "terminal.ansiYellow": "#E7B155",
    "terminal.ansiBlue": "#79EC8A",
    "terminal.ansiMagenta": "#83BAF1",
    "terminal.ansiCyan": "#E7B155",
    "terminal.ansiWhite": "#f5f3ee",
