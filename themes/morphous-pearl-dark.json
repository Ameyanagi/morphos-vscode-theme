    "terminal.ansiRed": "#d8aeb8",
    "terminal.ansiGreen": "#c98fa0",
    "terminal.ansiYellow": "#c7a86a",
    "terminal.ansiBlue": "#aeb4b4",
    "terminal.ansiMagenta": "#d8aeb8",
    "terminal.ansiCyan": "#c7a86a",
    "terminal.ansiWhite": "#fbf8ef",
