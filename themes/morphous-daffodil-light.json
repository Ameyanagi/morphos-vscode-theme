    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#ffd11a",
    "terminal.ansiYellow": "#6fae4a",
    "terminal.ansiBlue": "#ffc84d",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#6fae4a",
    "terminal.ansiWhite": "#1a2416",
