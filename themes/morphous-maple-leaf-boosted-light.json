{
  "name": "Morphous Maple Leaf (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#932C25",
    "foreground": "#3A2A1F",
    "widget.border": "#00000015",
    "selection.background": "#83482125",
    "editor.background": "#FBF9F3",
    "editor.foreground": "#3A2A1F",
    "editor.lineHighlightBackground": "#FCF9F350",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#932C25",
    "editor.selectionBackground": "#83482125",
    "editor.inactiveSelectionBackground": "#8348212580",
    "editorLineNumber.foreground": "#9baec080",
    "editorLineNumber.activeForeground": "#932C25",
    "sideBar.background": "#FCF9F3",
    "sideBar.foreground": "#3A2A1F",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FCF9F380",
    "sideBarSectionHeader.foreground": "#3A2A1F",
    "sideBarTitle.foreground": "#932C25",
    "activityBar.background": "#FBF9F3",
    "activityBar.foreground": "#932C25",
    "activityBar.inactiveForeground": "#3A2A1F60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#932C25",
    "activityBarBadge.foreground": "#FBF9F3",
    "statusBar.background": "#FBF9F3",
    "statusBar.foreground": "#3A2A1F",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FBF9F3",
    "titleBar.activeBackground": "#FBF9F3",
    "titleBar.activeForeground": "#3A2A1F",
    "titleBar.inactiveBackground": "#FBF9F3",
    "titleBar.inactiveForeground": "#3A2A1F60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FCF9F3aa",
    "tab.activeBackground": "#FBF9F3",
    "tab.activeForeground": "#3A2A1F",
    "tab.inactiveBackground": "#FBF9F360",
    "tab.inactiveForeground": "#3A2A1F80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#932C25",
    "list.activeSelectionBackground": "#932C2530",
    "list.activeSelectionForeground": "#3A2A1F",
    "list.hoverBackground": "#FCF9F340",
    "list.hoverForeground": "#3A2A1F",
    "list.inactiveSelectionBackground": "#932C2515",
    "list.inactiveSelectionForeground": "#3A2A1F",
    "list.highlightForeground": "#932C25",
    "terminal.background": "#FBF9F3",
    "terminal.foreground": "#3A2A1F",
    "terminal.ansiBlack": "#3A2A1F",
    "terminal.ansiRed": "#763519",
    "terminal.ansiGreen": "#932C25",
    "terminal.ansiYellow": "#A38529",
    "terminal.ansiBlue": "#834821",
    "terminal.ansiMagenta": "#763519",
    "terminal.ansiCyan": "#A38529",
    "terminal.ansiWhite": "#3A2A1F",
    "input.background": "#FCF9F3",
    "input.foreground": "#3A2A1F",
    "input.border": "#00000015",
    "input.placeholderForeground": "#3A2A1F60",
    "button.background": "#932C25",
    "button.foreground": "#FBF9F3",
    "button.hoverBackground": "#932C25dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#834821",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#834821",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#932C25"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A38529"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#763519"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#3A2A1F"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#3A2A1F"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#3A2A1Fdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#3A2A1F80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#3A2A1F"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A38529",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#932C25"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#834821"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#932C25"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9baec0"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#763519"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#932C25"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A38529"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#932C25",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A38529"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#932C25"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#834821"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    }
  ]
}