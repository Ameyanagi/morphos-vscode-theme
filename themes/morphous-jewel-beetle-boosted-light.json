      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7b8f72",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#836521"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7b8f72",
        "fontStyle": "italic"
      }
    }
