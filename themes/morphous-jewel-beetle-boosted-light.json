        "meta.object.member"
      ],
      "settings": {
        "foreground": "#09110f"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#09110fdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
