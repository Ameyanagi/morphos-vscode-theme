{
  "name": "Morphous Lynx (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#C08A5A",
    "foreground": "#111111",
    "widget.border": "#00000015",
    "selection.background": "#28282825",
    "editor.background": "#FBFCFD",
    "editor.foreground": "#111111",
    "editor.lineHighlightBackground": "#F2F4F750",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#C08A5A",
    "editor.selectionBackground": "#28282825",
    "editor.inactiveSelectionBackground": "#2828282580",
    "editorLineNumber.foreground": "#D9DEE380",
    "editorLineNumber.activeForeground": "#C08A5A",
    "sideBar.background": "#F2F4F7",
    "sideBar.foreground": "#111111",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F2F4F780",
    "sideBarSectionHeader.foreground": "#111111",
    "sideBarTitle.foreground": "#C08A5A",
    "activityBar.background": "#FBFCFD",
    "activityBar.foreground": "#C08A5A",
    "activityBar.inactiveForeground": "#11111160",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#C08A5A",
    "activityBarBadge.foreground": "#FBFCFD",
    "statusBar.background": "#FBFCFD",
    "statusBar.foreground": "#111111",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FBFCFD",
    "titleBar.activeBackground": "#FBFCFD",
    "titleBar.activeForeground": "#111111",
    "titleBar.inactiveBackground": "#FBFCFD",
    "titleBar.inactiveForeground": "#11111160",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F2F4F7aa",
    "tab.activeBackground": "#FBFCFD",
    "tab.activeForeground": "#111111",
    "tab.inactiveBackground": "#FBFCFD60",
    "tab.inactiveForeground": "#11111180",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#C08A5A",
    "list.activeSelectionBackground": "#C08A5A30",
    "list.activeSelectionForeground": "#111111",
    "list.hoverBackground": "#F2F4F740",
    "list.hoverForeground": "#111111",
    "list.inactiveSelectionBackground": "#C08A5A15",
    "list.inactiveSelectionForeground": "#111111",
    "list.highlightForeground": "#C08A5A",
    "terminal.background": "#FBFCFD",
    "terminal.foreground": "#111111",
    "terminal.ansiBlack": "#111111",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#C08A5A",
    "terminal.ansiYellow": "#2A4D3D",
    "terminal.ansiBlue": "#282828",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#2A4D3D",
    "terminal.ansiWhite": "#111111",
    "input.background": "#F2F4F7",
    "input.foreground": "#111111",
    "input.border": "#00000015",
    "input.placeholderForeground": "#11111160",
    "button.background": "#C08A5A",
    "button.foreground": "#FBFCFD",
    "button.hoverBackground": "#C08A5Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D9DEE3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#282828",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#282828",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#C08A5A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#2A4D3D"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#111111dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#11111180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#2A4D3D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#C08A5A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#282828"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C08A5A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D9DEE3"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#C08A5A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#2A4D3D"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#C08A5A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#2A4D3D"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#C08A5A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D9DEE3",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#282828"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D9DEE3",
        "fontStyle": "italic"
      }
    }
  ]
}