    "terminal.ansiYellow": "#b69ad7",
    "terminal.ansiBlue": "#7c5cff",
    "terminal.ansiMagenta": "#f7f2e8",
    "terminal.ansiCyan": "#b69ad7",
    "terminal.ansiWhite": "#241a16",
