    "terminal.ansiRed": "#19764C",
    "terminal.ansiGreen": "#258C93",
    "terminal.ansiYellow": "#29A37A",
    "terminal.ansiBlue": "#21837E",
    "terminal.ansiMagenta": "#19764C",
    "terminal.ansiCyan": "#29A37A",
    "terminal.ansiWhite": "#101f1f",
