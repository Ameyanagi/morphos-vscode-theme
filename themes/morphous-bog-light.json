    "editor.inactiveSelectionBackground": "#6a7a3f2580",
    "editorLineNumber.foreground": "#a7acb280",
    "editorLineNumber.activeForeground": "#3a2e24",
    "sideBar.background": "#fffaf0",
    "sideBar.foreground": "#1b1d1f",
    "sideBar.border": "#00000015",
