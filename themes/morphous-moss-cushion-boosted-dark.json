    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#B1EC79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#DDEBD6",
        "fontStyle": "italic"
