    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#1B1F19"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
