      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8D9188",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#21833B"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8D9188",
        "fontStyle": "italic"
      }
    }
