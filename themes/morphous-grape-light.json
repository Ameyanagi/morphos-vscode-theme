    "terminal.ansiBlack": "#1E1A22",
    "terminal.ansiRed": "#7B4E2B",
    "terminal.ansiGreen": "#6A309A",
    "terminal.ansiYellow": "#6A8F3A",
    "terminal.ansiBlue": "#8EA0B7",
    "terminal.ansiMagenta": "#7B4E2B",
    "terminal.ansiCyan": "#6A8F3A",
    "terminal.ansiWhite": "#1E1A22",
