    "terminal.ansiYellow": "#A32943",
    "terminal.ansiBlue": "#21837F",
    "terminal.ansiMagenta": "#19763B",
    "terminal.ansiCyan": "#A32943",
    "terminal.ansiWhite": "#0F172A",
    "input.background": "#E9F7F5",
    "input.foreground": "#0F172A",
