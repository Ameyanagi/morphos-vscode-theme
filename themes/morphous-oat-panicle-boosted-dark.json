      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#EADFC6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#92EC79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#EADFC6",
        "fontStyle": "italic"
      }
    }
