        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#55A5E7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#88E967"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#92EC79"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#88E967"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
