      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9aa0a3",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECC979"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9aa0a3",
        "fontStyle": "italic"
      }
