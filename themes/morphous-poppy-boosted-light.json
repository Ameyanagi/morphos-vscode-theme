    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F9F7F0aa",
    "tab.activeBackground": "#F9F7F0",
    "tab.activeForeground": "#1A1A1A",
    "tab.inactiveBackground": "#F9F7F060",
    "tab.inactiveForeground": "#1A1A1A80",
