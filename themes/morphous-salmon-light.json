{
  "name": "Morphous Salmon Scale and Run (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#d86658",
    "foreground": "#20262a",
    "widget.border": "#00000015",
    "selection.background": "#aeb7b725",
    "editor.background": "#e5e8e5",
    "editor.foreground": "#20262a",
    "editor.lineHighlightBackground": "#f5f2ea50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#d86658",
    "editor.selectionBackground": "#aeb7b725",
    "editor.inactiveSelectionBackground": "#aeb7b72580",
    "editorLineNumber.foreground": "#9baec080",
    "editorLineNumber.activeForeground": "#d86658",
    "sideBar.background": "#f5f2ea",
    "sideBar.foreground": "#20262a",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#f5f2ea80",
    "sideBarSectionHeader.foreground": "#20262a",
    "sideBarTitle.foreground": "#d86658",
    "activityBar.background": "#e5e8e5",
    "activityBar.foreground": "#d86658",
    "activityBar.inactiveForeground": "#20262a60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#d86658",
    "activityBarBadge.foreground": "#e5e8e5",
    "statusBar.background": "#e5e8e5",
    "statusBar.foreground": "#20262a",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#e5e8e5",
    "titleBar.activeBackground": "#e5e8e5",
    "titleBar.activeForeground": "#20262a",
    "titleBar.inactiveBackground": "#e5e8e5",
    "titleBar.inactiveForeground": "#20262a60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#f5f2eaaa",
    "tab.activeBackground": "#e5e8e5",
    "tab.activeForeground": "#20262a",
    "tab.inactiveBackground": "#e5e8e560",
    "tab.inactiveForeground": "#20262a80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#d86658",
    "list.activeSelectionBackground": "#d8665830",
    "list.activeSelectionForeground": "#20262a",
    "list.hoverBackground": "#f5f2ea40",
    "list.hoverForeground": "#20262a",
    "list.inactiveSelectionBackground": "#d8665815",
    "list.inactiveSelectionForeground": "#20262a",
    "list.highlightForeground": "#d86658",
    "terminal.background": "#e5e8e5",
    "terminal.foreground": "#20262a",
    "terminal.ansiBlack": "#20262a",
    "terminal.ansiRed": "#4d9586",
    "terminal.ansiGreen": "#d86658",
    "terminal.ansiYellow": "#3f7f9d",
    "terminal.ansiBlue": "#aeb7b7",
    "terminal.ansiMagenta": "#4d9586",
    "terminal.ansiCyan": "#3f7f9d",
    "terminal.ansiWhite": "#20262a",
    "input.background": "#f5f2ea",
    "input.foreground": "#20262a",
    "input.border": "#00000015",
    "input.placeholderForeground": "#20262a60",
    "button.background": "#d86658",
    "button.foreground": "#e5e8e5",
    "button.hoverBackground": "#d86658dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#aeb7b7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#aeb7b7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#d86658"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#3f7f9d"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#4d9586"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#20262a"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#20262a"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#20262add",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#20262a80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#20262a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#3f7f9d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#d86658"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#aeb7b7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#d86658"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9baec0"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#4d9586"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#d86658"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#3f7f9d"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#d86658",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#3f7f9d"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#d86658"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#aeb7b7"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    }
  ]
}