      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7d8f76",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#8bbf3f"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7d8f76",
        "fontStyle": "italic"
