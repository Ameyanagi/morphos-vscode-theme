      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#3f6f2b"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#b8c7bf"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#3f6f2b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
