      ],
      "settings": {
        "foreground": "#7a4a2f"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#788a5a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#b98a5b"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#788a5a",
        "fontStyle": "italic"
      }
    }
