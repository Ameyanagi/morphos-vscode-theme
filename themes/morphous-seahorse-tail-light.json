    "statusBar.background": "#FAF5EF",
    "statusBar.foreground": "#15383A",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FAF5EF",
    "titleBar.activeBackground": "#FAF5EF",
