{
  "name": "Morphous Leafcutter Ant (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#AA391D",
    "foreground": "#101b3d",
    "widget.border": "#00000015",
    "selection.background": "#7c5cff25",
    "editor.background": "#FAF7F2",
    "editor.foreground": "#101b3d",
    "editor.lineHighlightBackground": "#E7E2D750",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#AA391D",
    "editor.selectionBackground": "#7c5cff25",
    "editor.inactiveSelectionBackground": "#7c5cff2580",
    "editorLineNumber.foreground": "#EFE7D780",
    "editorLineNumber.activeForeground": "#AA391D",
    "sideBar.background": "#E7E2D7",
    "sideBar.foreground": "#101b3d",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#E7E2D780",
    "sideBarSectionHeader.foreground": "#101b3d",
    "sideBarTitle.foreground": "#AA391D",
    "activityBar.background": "#FAF7F2",
    "activityBar.foreground": "#AA391D",
    "activityBar.inactiveForeground": "#101b3d60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#AA391D",
    "activityBarBadge.foreground": "#FAF7F2",
    "statusBar.background": "#FAF7F2",
    "statusBar.foreground": "#101b3d",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FAF7F2",
    "titleBar.activeBackground": "#FAF7F2",
    "titleBar.activeForeground": "#101b3d",
    "titleBar.inactiveBackground": "#FAF7F2",
    "titleBar.inactiveForeground": "#101b3d60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#E7E2D7aa",
    "tab.activeBackground": "#FAF7F2",
    "tab.activeForeground": "#101b3d",
    "tab.inactiveBackground": "#FAF7F260",
    "tab.inactiveForeground": "#101b3d80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#AA391D",
    "list.activeSelectionBackground": "#AA391D30",
    "list.activeSelectionForeground": "#101b3d",
    "list.hoverBackground": "#E7E2D740",
    "list.hoverForeground": "#101b3d",
    "list.inactiveSelectionBackground": "#AA391D15",
    "list.inactiveSelectionForeground": "#101b3d",
    "list.highlightForeground": "#AA391D",
    "terminal.background": "#FAF7F2",
    "terminal.foreground": "#101b3d",
    "terminal.ansiBlack": "#101b3d",
    "terminal.ansiRed": "#D97A43",
    "terminal.ansiGreen": "#AA391D",
    "terminal.ansiYellow": "#4E8E2F",
    "terminal.ansiBlue": "#7c5cff",
    "terminal.ansiMagenta": "#D97A43",
    "terminal.ansiCyan": "#4E8E2F",
    "terminal.ansiWhite": "#101b3d",
    "input.background": "#E7E2D7",
    "input.foreground": "#101b3d",
    "input.border": "#00000015",
    "input.placeholderForeground": "#101b3d60",
    "button.background": "#AA391D",
    "button.foreground": "#FAF7F2",
    "button.hoverBackground": "#AA391Ddd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#EFE7D7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#7c5cff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7c5cff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#AA391D"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#4E8E2F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#D97A43"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#101b3d"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#101b3d"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#101b3ddd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#101b3d80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#101b3d"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#4E8E2F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#AA391D"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#AA391D"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#EFE7D7"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#D97A43"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#AA391D"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#4E8E2F"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#AA391D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#4E8E2F"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#AA391D"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#EFE7D7",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#EFE7D7",
        "fontStyle": "italic"
      }
    }
  ]
}