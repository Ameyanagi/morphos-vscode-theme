    "terminal.ansiRed": "#4A3A2A",
    "terminal.ansiGreen": "#7A5A3A",
    "terminal.ansiYellow": "#2D7F88",
    "terminal.ansiBlue": "#F4E9E6",
    "terminal.ansiMagenta": "#4A3A2A",
    "terminal.ansiCyan": "#2D7F88",
    "terminal.ansiWhite": "#F6FAF8",
