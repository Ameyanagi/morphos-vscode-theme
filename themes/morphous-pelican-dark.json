    "sideBar.border": "#ffffff15",
    "sideBarSectionHeader.background": "#133F5280",
    "sideBarSectionHeader.foreground": "#F7F3EC",
    "sideBarTitle.foreground": "#F2C14E",
    "activityBar.background": "#133F52",
    "activityBar.foreground": "#F2C14E",
    "activityBar.inactiveForeground": "#F7F3EC60",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#F2C14E",
    "activityBarBadge.foreground": "#133F52",
    "statusBar.background": "#133F52",
    "statusBar.foreground": "#F7F3EC",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#133F52",
    "titleBar.activeBackground": "#133F52",
    "titleBar.activeForeground": "#F7F3EC",
    "titleBar.inactiveBackground": "#133F52",
    "titleBar.inactiveForeground": "#F7F3EC60",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#133F52dd",
    "tab.activeBackground": "#133F52",
    "tab.activeForeground": "#F7F3EC",
    "tab.inactiveBackground": "#0E3A4D60",
    "tab.inactiveForeground": "#F7F3EC80",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#F2C14E",
    "list.activeSelectionBackground": "#F2C14E30",
    "list.activeSelectionForeground": "#F7F3EC",
    "list.hoverBackground": "#0E3A4D40",
    "list.hoverForeground": "#F7F3EC",
    "list.inactiveSelectionBackground": "#F2C14E15",
    "list.inactiveSelectionForeground": "#F7F3EC",
    "list.highlightForeground": "#F2C14E",
    "terminal.background": "#133F52",
    "terminal.foreground": "#F7F3EC",
    "terminal.ansiBlack": "#133F52",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#F2C14E",
    "terminal.ansiYellow": "#4DB6D6",
    "terminal.ansiBlue": "#FFF6E5",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#4DB6D6",
    "terminal.ansiWhite": "#F7F3EC",
    "input.background": "#0E3A4D",
    "input.foreground": "#F7F3EC",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#F7F3EC60",
    "button.background": "#F2C14E",
    "button.foreground": "#133F52",
    "button.hoverBackground": "#F2C14Edd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#FFF6E5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFF6E5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#F2C14E"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#4DB6D6"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#F7F3EC"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#F7F3EC"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F7F3ECdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#F7F3EC80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F7F3EC"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#4DB6D6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#F2C14E"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FFF6E5"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#F2C14E"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9baec0"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#F2C14E"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#4DB6D6"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#F2C14E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#4DB6D6"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#F2C14E"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#FFF6E5"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    }
  ]
}