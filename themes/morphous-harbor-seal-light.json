    "terminal.ansiBlack": "#2B3037",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#2E6F8E",
    "terminal.ansiYellow": "#98A2AD",
    "terminal.ansiBlue": "#D6DBDF",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#98A2AD",
    "terminal.ansiWhite": "#2B3037",
