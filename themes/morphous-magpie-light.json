{
  "name": "Morphous Magpie Iridescence (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#00d1b2",
    "foreground": "#080c0c",
    "widget.border": "#00000015",
    "selection.background": "#0077ff25",
    "editor.background": "#ffffff",
    "editor.foreground": "#080c0c",
    "editor.lineHighlightBackground": "#e9ecef50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#00d1b2",
    "editor.selectionBackground": "#0077ff25",
    "editor.inactiveSelectionBackground": "#0077ff2580",
    "editorLineNumber.foreground": "#77a08a80",
    "editorLineNumber.activeForeground": "#00d1b2",
    "sideBar.background": "#e9ecef",
    "sideBar.foreground": "#080c0c",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#e9ecef80",
    "sideBarSectionHeader.foreground": "#080c0c",
    "sideBarTitle.foreground": "#00d1b2",
    "activityBar.background": "#ffffff",
    "activityBar.foreground": "#00d1b2",
    "activityBar.inactiveForeground": "#080c0c60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#00d1b2",
    "activityBarBadge.foreground": "#ffffff",
    "statusBar.background": "#ffffff",
    "statusBar.foreground": "#080c0c",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#ffffff",
    "titleBar.activeBackground": "#ffffff",
    "titleBar.activeForeground": "#080c0c",
    "titleBar.inactiveBackground": "#ffffff",
    "titleBar.inactiveForeground": "#080c0c60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#e9ecefaa",
    "tab.activeBackground": "#ffffff",
    "tab.activeForeground": "#080c0c",
    "tab.inactiveBackground": "#ffffff60",
    "tab.inactiveForeground": "#080c0c80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#00d1b2",
    "list.activeSelectionBackground": "#00d1b230",
    "list.activeSelectionForeground": "#080c0c",
    "list.hoverBackground": "#e9ecef40",
    "list.hoverForeground": "#080c0c",
    "list.inactiveSelectionBackground": "#00d1b215",
    "list.inactiveSelectionForeground": "#080c0c",
    "list.highlightForeground": "#00d1b2",
    "terminal.background": "#ffffff",
    "terminal.foreground": "#080c0c",
    "terminal.ansiBlack": "#080c0c",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#00d1b2",
    "terminal.ansiYellow": "#10c76a",
    "terminal.ansiBlue": "#0077ff",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#10c76a",
    "terminal.ansiWhite": "#080c0c",
    "input.background": "#e9ecef",
    "input.foreground": "#080c0c",
    "input.border": "#00000015",
    "input.placeholderForeground": "#080c0c60",
    "button.background": "#00d1b2",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#00d1b2dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#77a08a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#0077ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#0077ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#00d1b2"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#10c76a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#080c0c"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#080c0c"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#080c0cdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#080c0c80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#080c0c"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#10c76a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#00d1b2"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#0077ff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#00d1b2"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#77a08a"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#00d1b2"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#10c76a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#00d1b2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#10c76a"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#00d1b2"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#77a08a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#0077ff"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#77a08a",
        "fontStyle": "italic"
      }
    }
  ]
}