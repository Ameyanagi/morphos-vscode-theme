    "statusBar.background": "#F6ECDA",
    "statusBar.foreground": "#1D0F08",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F6ECDA",
    "titleBar.activeBackground": "#F6ECDA",
    "titleBar.activeForeground": "#1D0F08",
    "titleBar.inactiveBackground": "#F6ECDA",
    "titleBar.inactiveForeground": "#1D0F0860",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#E7D7BFaa",
    "tab.activeBackground": "#F6ECDA",
    "tab.activeForeground": "#1D0F08",
    "tab.inactiveBackground": "#F6ECDA60",
    "tab.inactiveForeground": "#1D0F0880",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#3E2F24",
    "list.activeSelectionBackground": "#3E2F2430",
    "list.activeSelectionForeground": "#1D0F08",
    "list.hoverBackground": "#E7D7BF40",
