    "terminal.ansiBlack": "#1D0F08",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#3E2F24",
    "terminal.ansiYellow": "#5A6B3A",
    "terminal.ansiBlue": "#C39D75",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#5A6B3A",
    "terminal.ansiWhite": "#1D0F08",
    "input.background": "#E7D7BF",
    "input.foreground": "#1D0F08",
    "input.border": "#00000015",
    "input.placeholderForeground": "#1D0F0860",
    "button.background": "#3E2F24",
    "button.foreground": "#F6ECDA",
    "button.hoverBackground": "#3E2F24dd"
