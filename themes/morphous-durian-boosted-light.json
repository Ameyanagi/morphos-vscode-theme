        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A37A29",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#749325"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#21835F"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
