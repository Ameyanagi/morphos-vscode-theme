      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7a684a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#21835F"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7a684a",
        "fontStyle": "italic"
      }
    }
