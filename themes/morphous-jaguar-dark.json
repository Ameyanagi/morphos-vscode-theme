    "terminal.ansiRed": "#2E7A47",
    "terminal.ansiGreen": "#E6B23C",
    "terminal.ansiYellow": "#1E5A3A",
    "terminal.ansiBlue": "#C48F4A",
    "terminal.ansiMagenta": "#2E7A47",
    "terminal.ansiCyan": "#1E5A3A",
    "terminal.ansiWhite": "#D4A017",
    "input.background": "#0F0F0F",
