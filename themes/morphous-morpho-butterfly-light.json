{
  "name": "Morphous Morpho Butterfly (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#0A64FF",
    "foreground": "#0D0B0F",
    "widget.border": "#00000015",
    "selection.background": "#1FAF8A25",
    "editor.background": "#F6FAFB",
    "editor.foreground": "#0D0B0F",
    "editor.lineHighlightBackground": "#FFFFFF50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#0A64FF",
    "editor.selectionBackground": "#1FAF8A25",
    "editor.inactiveSelectionBackground": "#1FAF8A2580",
    "editorLineNumber.foreground": "#6C7A7C80",
    "editorLineNumber.activeForeground": "#0A64FF",
    "sideBar.background": "#FFFFFF",
    "sideBar.foreground": "#0D0B0F",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFFFFF80",
    "sideBarSectionHeader.foreground": "#0D0B0F",
    "sideBarTitle.foreground": "#0A64FF",
    "activityBar.background": "#F6FAFB",
    "activityBar.foreground": "#0A64FF",
    "activityBar.inactiveForeground": "#0D0B0F60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#0A64FF",
    "activityBarBadge.foreground": "#F6FAFB",
    "statusBar.background": "#F6FAFB",
    "statusBar.foreground": "#0D0B0F",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F6FAFB",
    "titleBar.activeBackground": "#F6FAFB",
    "titleBar.activeForeground": "#0D0B0F",
    "titleBar.inactiveBackground": "#F6FAFB",
    "titleBar.inactiveForeground": "#0D0B0F60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFFFFaa",
    "tab.activeBackground": "#F6FAFB",
    "tab.activeForeground": "#0D0B0F",
    "tab.inactiveBackground": "#F6FAFB60",
    "tab.inactiveForeground": "#0D0B0F80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#0A64FF",
    "list.activeSelectionBackground": "#0A64FF30",
    "list.activeSelectionForeground": "#0D0B0F",
    "list.hoverBackground": "#FFFFFF40",
    "list.hoverForeground": "#0D0B0F",
    "list.inactiveSelectionBackground": "#0A64FF15",
    "list.inactiveSelectionForeground": "#0D0B0F",
    "list.highlightForeground": "#0A64FF",
    "terminal.background": "#F6FAFB",
    "terminal.foreground": "#0D0B0F",
    "terminal.ansiBlack": "#0D0B0F",
    "terminal.ansiRed": "#AEEBFF",
    "terminal.ansiGreen": "#0A64FF",
    "terminal.ansiYellow": "#3FD4FF",
    "terminal.ansiBlue": "#1FAF8A",
    "terminal.ansiMagenta": "#AEEBFF",
    "terminal.ansiCyan": "#3FD4FF",
    "terminal.ansiWhite": "#0D0B0F",
    "input.background": "#FFFFFF",
    "input.foreground": "#0D0B0F",
    "input.border": "#00000015",
    "input.placeholderForeground": "#0D0B0F60",
    "button.background": "#0A64FF",
    "button.foreground": "#F6FAFB",
    "button.hoverBackground": "#0A64FFdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6C7A7C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#1FAF8A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1FAF8A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#0A64FF"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#3FD4FF"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#AEEBFF"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#0D0B0F"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#0D0B0F"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#0D0B0Fdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#0D0B0F80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#0D0B0F"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#3FD4FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#0A64FF"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#1FAF8A"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#0A64FF"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#6C7A7C"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#AEEBFF"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#0A64FF"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#3FD4FF"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#0A64FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#3FD4FF"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#0A64FF"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#6C7A7C",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#1FAF8A"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#6C7A7C",
        "fontStyle": "italic"
      }
    }
  ]
}