    "activityBar.inactiveForeground": "#251f1760",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#749325",
    "activityBarBadge.foreground": "#F7F1E3",
    "statusBar.background": "#F7F1E3",
    "statusBar.foreground": "#251f17",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7F1E3",
    "titleBar.activeBackground": "#F7F1E3",
    "titleBar.activeForeground": "#251f17",
    "titleBar.inactiveBackground": "#F7F1E3",
    "titleBar.inactiveForeground": "#251f1760",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#87623Baa",
    "tab.activeBackground": "#F7F1E3",
    "tab.activeForeground": "#251f17",
    "tab.inactiveBackground": "#F7F1E360",
    "tab.inactiveForeground": "#251f1780",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#749325",
    "list.activeSelectionBackground": "#74932530",
    "list.activeSelectionForeground": "#251f17",
    "list.hoverBackground": "#87623B40",
    "list.hoverForeground": "#251f17",
    "list.inactiveSelectionBackground": "#74932515",
    "list.inactiveSelectionForeground": "#251f17",
    "list.highlightForeground": "#749325",
    "terminal.background": "#F7F1E3",
    "terminal.foreground": "#251f17",
    "terminal.ansiBlack": "#251f17",
    "terminal.ansiRed": "#657619",
    "terminal.ansiGreen": "#749325",
    "terminal.ansiYellow": "#7CA329",
    "terminal.ansiBlue": "#836421",
    "terminal.ansiMagenta": "#657619",
    "terminal.ansiCyan": "#7CA329",
    "terminal.ansiWhite": "#251f17",
    "input.background": "#87623B",
    "input.foreground": "#251f17",
    "input.border": "#00000015",
    "input.placeholderForeground": "#251f1760",
    "button.background": "#749325",
    "button.foreground": "#F7F1E3",
    "button.hoverBackground": "#749325dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#836421",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#836421",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#749325"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#7CA329"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#657619"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#251f17"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#251f17"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#251f17dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#251f1780"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#251f17"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#7CA329",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#749325"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#836421"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#749325"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9baec0"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#657619"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#749325"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#7CA329"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#749325",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#7CA329"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#749325"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#836421"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    }
  ]
}