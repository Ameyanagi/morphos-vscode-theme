{
  "name": "Morphous Goldfish (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#f46a21",
    "foreground": "#233025",
    "widget.border": "#00000015",
    "selection.background": "#6e8f5b25",
    "editor.background": "#fff7ec",
    "editor.foreground": "#233025",
    "editor.lineHighlightBackground": "#ead7b750",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#f46a21",
    "editor.selectionBackground": "#6e8f5b25",
    "editor.inactiveSelectionBackground": "#6e8f5b2580",
    "editorLineNumber.foreground": "#9baec080",
    "editorLineNumber.activeForeground": "#f46a21",
    "sideBar.background": "#ead7b7",
    "sideBar.foreground": "#233025",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#ead7b780",
    "sideBarSectionHeader.foreground": "#233025",
    "sideBarTitle.foreground": "#f46a21",
    "activityBar.background": "#fff7ec",
    "activityBar.foreground": "#f46a21",
    "activityBar.inactiveForeground": "#23302560",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#f46a21",
    "activityBarBadge.foreground": "#fff7ec",
    "statusBar.background": "#fff7ec",
    "statusBar.foreground": "#233025",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#fff7ec",
    "titleBar.activeBackground": "#fff7ec",
    "titleBar.activeForeground": "#233025",
    "titleBar.inactiveBackground": "#fff7ec",
    "titleBar.inactiveForeground": "#23302560",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#ead7b7aa",
    "tab.activeBackground": "#fff7ec",
    "tab.activeForeground": "#233025",
    "tab.inactiveBackground": "#fff7ec60",
    "tab.inactiveForeground": "#23302580",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#f46a21",
    "list.activeSelectionBackground": "#f46a2130",
    "list.activeSelectionForeground": "#233025",
    "list.hoverBackground": "#ead7b740",
    "list.hoverForeground": "#233025",
    "list.inactiveSelectionBackground": "#f46a2115",
    "list.inactiveSelectionForeground": "#233025",
    "list.highlightForeground": "#f46a21",
    "terminal.background": "#fff7ec",
    "terminal.foreground": "#233025",
    "terminal.ansiBlack": "#233025",
    "terminal.ansiRed": "#d7e8e4",
    "terminal.ansiGreen": "#f46a21",
    "terminal.ansiYellow": "#f7b733",
    "terminal.ansiBlue": "#6e8f5b",
    "terminal.ansiMagenta": "#d7e8e4",
    "terminal.ansiCyan": "#f7b733",
    "terminal.ansiWhite": "#233025",
    "input.background": "#ead7b7",
    "input.foreground": "#233025",
    "input.border": "#00000015",
    "input.placeholderForeground": "#23302560",
    "button.background": "#f46a21",
    "button.foreground": "#fff7ec",
    "button.hoverBackground": "#f46a21dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#6e8f5b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6e8f5b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#f46a21"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#f7b733"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#d7e8e4"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#233025"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#233025"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#233025dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#23302580"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#233025"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#f7b733",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#f46a21"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#6e8f5b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f46a21"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#9baec0"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#d7e8e4"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#f46a21"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#f7b733"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#f46a21",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#f7b733"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#f46a21"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#6e8f5b"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#9baec0",
        "fontStyle": "italic"
      }
    }
  ]
}