{
  "name": "Morphous Bumblebee (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#937725",
    "foreground": "#111111",
    "widget.border": "#00000015",
    "selection.background": "#34218325",
    "editor.background": "#FFFAF0",
    "editor.foreground": "#111111",
    "editor.lineHighlightBackground": "#FCF7EE50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#937725",
    "editor.selectionBackground": "#34218325",
    "editor.inactiveSelectionBackground": "#3421832580",
    "editorLineNumber.foreground": "#E9E2CF80",
    "editorLineNumber.activeForeground": "#937725",
    "sideBar.background": "#FCF7EE",
    "sideBar.foreground": "#111111",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FCF7EE80",
    "sideBarSectionHeader.foreground": "#111111",
    "sideBarTitle.foreground": "#937725",
    "activityBar.background": "#FFFAF0",
    "activityBar.foreground": "#937725",
    "activityBar.inactiveForeground": "#11111160",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#937725",
    "activityBarBadge.foreground": "#FFFAF0",
    "statusBar.background": "#FFFAF0",
    "statusBar.foreground": "#111111",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FFFAF0",
    "titleBar.activeBackground": "#FFFAF0",
    "titleBar.activeForeground": "#111111",
    "titleBar.inactiveBackground": "#FFFAF0",
    "titleBar.inactiveForeground": "#11111160",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FCF7EEaa",
    "tab.activeBackground": "#FFFAF0",
    "tab.activeForeground": "#111111",
    "tab.inactiveBackground": "#FFFAF060",
    "tab.inactiveForeground": "#11111180",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#937725",
    "list.activeSelectionBackground": "#93772530",
    "list.activeSelectionForeground": "#111111",
    "list.hoverBackground": "#FCF7EE40",
    "list.hoverForeground": "#111111",
    "list.inactiveSelectionBackground": "#93772515",
    "list.inactiveSelectionForeground": "#111111",
    "list.highlightForeground": "#937725",
    "terminal.background": "#FFFAF0",
    "terminal.foreground": "#111111",
    "terminal.ansiBlack": "#111111",
    "terminal.ansiRed": "#5F1976",
    "terminal.ansiGreen": "#937725",
    "terminal.ansiYellow": "#A36A29",
    "terminal.ansiBlue": "#342183",
    "terminal.ansiMagenta": "#5F1976",
    "terminal.ansiCyan": "#A36A29",
    "terminal.ansiWhite": "#111111",
    "input.background": "#FCF7EE",
    "input.foreground": "#111111",
    "input.border": "#00000015",
    "input.placeholderForeground": "#11111160",
    "button.background": "#937725",
    "button.foreground": "#FFFAF0",
    "button.hoverBackground": "#937725dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#E9E2CF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#342183",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#342183",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A36A29"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#111111dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#11111180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A36A29",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#342183"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#E9E2CF"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A36A29"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#937725",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A36A29"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#937725"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E9E2CF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#342183"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E9E2CF",
        "fontStyle": "italic"
      }
    }
  ]
}