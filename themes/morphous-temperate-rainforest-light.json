    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#e5eadf80",
    "sideBarSectionHeader.foreground": "#123228",
    "sideBarTitle.foreground": "#4f7f3f",
    "activityBar.background": "#f4f7f1",
    "activityBar.foreground": "#4f7f3f",
    "activityBar.inactiveForeground": "#12322860",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#4f7f3f",
    "activityBarBadge.foreground": "#f4f7f1",
    "statusBar.background": "#f4f7f1",
    "statusBar.foreground": "#123228",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#f4f7f1",
    "titleBar.activeBackground": "#f4f7f1",
    "titleBar.activeForeground": "#123228",
    "titleBar.inactiveBackground": "#f4f7f1",
    "titleBar.inactiveForeground": "#12322860",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#e5eadfaa",
    "tab.activeBackground": "#f4f7f1",
    "tab.activeForeground": "#123228",
    "tab.inactiveBackground": "#f4f7f160",
    "tab.inactiveForeground": "#12322880",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#4f7f3f",
    "list.activeSelectionBackground": "#4f7f3f30",
    "list.activeSelectionForeground": "#123228",
    "list.hoverBackground": "#e5eadf40",
    "list.hoverForeground": "#123228",
    "list.inactiveSelectionBackground": "#4f7f3f15",
    "list.inactiveSelectionForeground": "#123228",
    "list.highlightForeground": "#4f7f3f",
    "terminal.background": "#f4f7f1",
    "terminal.foreground": "#123228",
    "terminal.ansiBlack": "#123228",
    "terminal.ansiRed": "#c4b96f",
    "terminal.ansiGreen": "#4f7f3f",
    "terminal.ansiYellow": "#8fb86a",
    "terminal.ansiBlue": "#76513e",
    "terminal.ansiMagenta": "#c4b96f",
    "terminal.ansiCyan": "#8fb86a",
    "terminal.ansiWhite": "#123228",
    "input.background": "#e5eadf",
    "input.foreground": "#123228",
    "input.border": "#00000015",
    "input.placeholderForeground": "#12322860",
    "button.background": "#4f7f3f",
    "button.foreground": "#f4f7f1",
    "button.hoverBackground": "#4f7f3fdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8b8171",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#76513e",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#76513e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4f7f3f"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#8fb86a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c4b96f"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#123228"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#123228"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#123228dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#12322880"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#123228"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#8fb86a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#4f7f3f"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#76513e"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4f7f3f"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#8b8171"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c4b96f"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#4f7f3f"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#8fb86a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#4f7f3f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8fb86a"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#4f7f3f"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8b8171",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#76513e"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8b8171",
        "fontStyle": "italic"
      }
    }
  ]
}