    "editor.lineHighlightBackground": "#e5eadf50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#4f7f3f",
    "editor.selectionBackground": "#76513e25",
    "editor.inactiveSelectionBackground": "#76513e2580",
    "editorLineNumber.foreground": "#8b817180",
    "editorLineNumber.activeForeground": "#4f7f3f",
    "sideBar.background": "#e5eadf",
