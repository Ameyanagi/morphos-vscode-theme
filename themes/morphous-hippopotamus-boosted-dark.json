      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7B6A74",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECB879"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7B6A74",
        "fontStyle": "italic"
      }
    }
