    "statusBar.background": "#F8F3F7",
    "statusBar.foreground": "#1B1020",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F8F3F7",
    "titleBar.activeBackground": "#F8F3F7",
