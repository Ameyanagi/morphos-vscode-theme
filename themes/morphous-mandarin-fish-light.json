    "activityBar.inactiveForeground": "#06122060",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#FF6A00",
    "activityBarBadge.foreground": "#F7FAFC",
    "statusBar.background": "#F7FAFC",
    "statusBar.foreground": "#061220",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7FAFC",
    "titleBar.activeBackground": "#F7FAFC",
    "titleBar.activeForeground": "#061220",
    "titleBar.inactiveBackground": "#F7FAFC",
    "titleBar.inactiveForeground": "#06122060",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F2E9D8aa",
    "tab.activeBackground": "#F7FAFC",
    "tab.activeForeground": "#061220",
    "tab.inactiveBackground": "#F7FAFC60",
    "tab.inactiveForeground": "#06122080",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#FF6A00",
    "list.activeSelectionBackground": "#FF6A0030",
    "list.activeSelectionForeground": "#061220",
    "list.hoverBackground": "#F2E9D840",
    "list.hoverForeground": "#061220",
    "list.inactiveSelectionBackground": "#FF6A0015",
    "list.inactiveSelectionForeground": "#061220",
    "list.highlightForeground": "#FF6A00",
    "terminal.background": "#F7FAFC",
    "terminal.foreground": "#061220",
    "terminal.ansiBlack": "#061220",
    "terminal.ansiRed": "#C8F31D",
    "terminal.ansiGreen": "#FF6A00",
    "terminal.ansiYellow": "#00C6EF",
    "terminal.ansiBlue": "#005EFF",
    "terminal.ansiMagenta": "#C8F31D",
    "terminal.ansiCyan": "#00C6EF",
    "terminal.ansiWhite": "#061220",
    "input.background": "#F2E9D8",
    "input.foreground": "#061220",
    "input.border": "#00000015",
    "input.placeholderForeground": "#06122060",
    "button.background": "#FF6A00",
    "button.foreground": "#F7FAFC",
    "button.hoverBackground": "#FF6A00dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#485D68",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#005EFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#005EFF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#FF6A00"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#00C6EF"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#C8F31D"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#061220"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#061220"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#061220dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#06122080"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#061220"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#00C6EF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#FF6A00"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#005EFF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FF6A00"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#485D68"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#C8F31D"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#FF6A00"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#00C6EF"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#FF6A00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#00C6EF"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#FF6A00"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#485D68",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#005EFF"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#485D68",
        "fontStyle": "italic"
      }
    }
  ]
}