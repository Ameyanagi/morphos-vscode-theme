    "terminal.ansiRed": "#B66B38",
    "terminal.ansiGreen": "#7A3F2A",
    "terminal.ansiYellow": "#E8D0B8",
    "terminal.ansiBlue": "#6F563F",
    "terminal.ansiMagenta": "#B66B38",
    "terminal.ansiCyan": "#E8D0B8",
    "terminal.ansiWhite": "#F7F1E8",
    "input.background": "#1E1A16",
    "input.foreground": "#F7F1E8",
