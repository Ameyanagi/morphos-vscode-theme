    "terminal.background": "#FFF9F5",
    "terminal.foreground": "#0A1A12",
    "terminal.ansiBlack": "#0A1A12",
    "terminal.ansiRed": "#762819",
    "terminal.ansiGreen": "#93252E",
    "terminal.ansiYellow": "#A38929",
    "terminal.ansiBlue": "#218349",
    "terminal.ansiMagenta": "#762819",
    "terminal.ansiCyan": "#A38929",
    "terminal.ansiWhite": "#0A1A12",
    "input.background": "#FFF6F0",
    "input.foreground": "#0A1A12",
    "input.border": "#00000015",
