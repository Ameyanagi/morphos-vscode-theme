    "statusBar.background": "#FFF9F5",
    "statusBar.foreground": "#0A1A12",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FFF9F5",
    "titleBar.activeBackground": "#FFF9F5",
