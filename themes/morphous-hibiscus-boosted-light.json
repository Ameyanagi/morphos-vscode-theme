    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFF6F0aa",
    "tab.activeBackground": "#FFF9F5",
    "tab.activeForeground": "#0A1A12",
    "tab.inactiveBackground": "#FFF9F560",
