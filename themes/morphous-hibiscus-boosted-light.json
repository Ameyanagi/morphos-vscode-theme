    "tab.border": "#00000015",
    "tab.activeBorderTop": "#93252E",
    "list.activeSelectionBackground": "#93252E30",
    "list.activeSelectionForeground": "#0A1A12",
    "list.hoverBackground": "#FFF6F040",
