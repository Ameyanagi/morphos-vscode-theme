  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8c8173",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#ECAF79",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ECAF79",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#67E3E9"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#66E755"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#BCF183"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#dde6e1"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#dde6e1"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#dde6e1dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#dde6e180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#dde6e1"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#66E755",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#67E3E9"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ECAF79"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#67E3E9"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#8c8173"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#BCF183"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#67E3E9"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#66E755"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#67E3E9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#66E755"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#67E3E9"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#8c8173",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#ECAF79"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#8c8173",
        "fontStyle": "italic"
      }
    }
  ]
}