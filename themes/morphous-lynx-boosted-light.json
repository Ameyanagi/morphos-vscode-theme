{
  "name": "Morphous Lynx (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#935825",
    "foreground": "#111111",
    "widget.border": "#00000015",
    "selection.background": "#83212125",
    "editor.background": "#FCFCFD",
    "editor.foreground": "#111111",
    "editor.lineHighlightBackground": "#F6F7F950",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#935825",
    "editor.selectionBackground": "#83212125",
    "editor.inactiveSelectionBackground": "#8321212580",
    "editorLineNumber.foreground": "#D9DEE380",
    "editorLineNumber.activeForeground": "#935825",
    "sideBar.background": "#F6F7F9",
    "sideBar.foreground": "#111111",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#F6F7F980",
    "sideBarSectionHeader.foreground": "#111111",
    "sideBarTitle.foreground": "#935825",
    "activityBar.background": "#FCFCFD",
    "activityBar.foreground": "#935825",
    "activityBar.inactiveForeground": "#11111160",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#935825",
    "activityBarBadge.foreground": "#FCFCFD",
    "statusBar.background": "#FCFCFD",
    "statusBar.foreground": "#111111",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FCFCFD",
    "titleBar.activeBackground": "#FCFCFD",
    "titleBar.activeForeground": "#111111",
    "titleBar.inactiveBackground": "#FCFCFD",
    "titleBar.inactiveForeground": "#11111160",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F6F7F9aa",
    "tab.activeBackground": "#FCFCFD",
    "tab.activeForeground": "#111111",
    "tab.inactiveBackground": "#FCFCFD60",
    "tab.inactiveForeground": "#11111180",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#935825",
    "list.activeSelectionBackground": "#93582530",
    "list.activeSelectionForeground": "#111111",
    "list.hoverBackground": "#F6F7F940",
    "list.hoverForeground": "#111111",
    "list.inactiveSelectionBackground": "#93582515",
    "list.inactiveSelectionForeground": "#111111",
    "list.highlightForeground": "#935825",
    "terminal.background": "#FCFCFD",
    "terminal.foreground": "#111111",
    "terminal.ansiBlack": "#111111",
    "terminal.ansiRed": "#5F1976",
    "terminal.ansiGreen": "#935825",
    "terminal.ansiYellow": "#29A36C",
    "terminal.ansiBlue": "#832121",
    "terminal.ansiMagenta": "#5F1976",
    "terminal.ansiCyan": "#29A36C",
    "terminal.ansiWhite": "#111111",
    "input.background": "#F6F7F9",
    "input.foreground": "#111111",
    "input.border": "#00000015",
    "input.placeholderForeground": "#11111160",
    "button.background": "#935825",
    "button.foreground": "#FCFCFD",
    "button.hoverBackground": "#935825dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#D9DEE3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#832121",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#832121",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#935825"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#29A36C"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#111111dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#11111180"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#29A36C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#935825"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#832121"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#935825"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#D9DEE3"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#935825"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#29A36C"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#935825",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#29A36C"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#935825"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#D9DEE3",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#832121"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D9DEE3",
        "fontStyle": "italic"
      }
    }
  ]
}