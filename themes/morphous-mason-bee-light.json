{
  "name": "Morphous Mason Bee (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#005F9E",
    "foreground": "#0E1720",
    "widget.border": "#00000015",
    "selection.background": "#EEF2F425",
    "editor.background": "#FBFAF6",
    "editor.foreground": "#0E1720",
    "editor.lineHighlightBackground": "#FFFDFC50",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#005F9E",
    "editor.selectionBackground": "#EEF2F425",
    "editor.inactiveSelectionBackground": "#EEF2F42580",
    "editorLineNumber.foreground": "#6F7E8680",
    "editorLineNumber.activeForeground": "#005F9E",
    "sideBar.background": "#FFFDFC",
    "sideBar.foreground": "#0E1720",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFFDFC80",
    "sideBarSectionHeader.foreground": "#0E1720",
    "sideBarTitle.foreground": "#005F9E",
    "activityBar.background": "#FBFAF6",
    "activityBar.foreground": "#005F9E",
    "activityBar.inactiveForeground": "#0E172060",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#005F9E",
    "activityBarBadge.foreground": "#FBFAF6",
    "statusBar.background": "#FBFAF6",
    "statusBar.foreground": "#0E1720",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FBFAF6",
    "titleBar.activeBackground": "#FBFAF6",
    "titleBar.activeForeground": "#0E1720",
    "titleBar.inactiveBackground": "#FBFAF6",
    "titleBar.inactiveForeground": "#0E172060",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFDFCaa",
    "tab.activeBackground": "#FBFAF6",
    "tab.activeForeground": "#0E1720",
    "tab.inactiveBackground": "#FBFAF660",
    "tab.inactiveForeground": "#0E172080",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#005F9E",
    "list.activeSelectionBackground": "#005F9E30",
    "list.activeSelectionForeground": "#0E1720",
    "list.hoverBackground": "#FFFDFC40",
    "list.hoverForeground": "#0E1720",
    "list.inactiveSelectionBackground": "#005F9E15",
    "list.inactiveSelectionForeground": "#0E1720",
    "list.highlightForeground": "#005F9E",
    "terminal.background": "#FBFAF6",
    "terminal.foreground": "#0E1720",
    "terminal.ansiBlack": "#0E1720",
    "terminal.ansiRed": "#1282C6",
    "terminal.ansiGreen": "#005F9E",
    "terminal.ansiYellow": "#F4E7C7",
    "terminal.ansiBlue": "#EEF2F4",
    "terminal.ansiMagenta": "#1282C6",
    "terminal.ansiCyan": "#F4E7C7",
    "terminal.ansiWhite": "#0E1720",
    "input.background": "#FFFDFC",
    "input.foreground": "#0E1720",
    "input.border": "#00000015",
    "input.placeholderForeground": "#0E172060",
    "button.background": "#005F9E",
    "button.foreground": "#FBFAF6",
    "button.hoverBackground": "#005F9Edd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6F7E86",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#EEF2F4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#EEF2F4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#005F9E"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#F4E7C7"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#1282C6"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#0E1720"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#0E1720"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#0E1720dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#0E172080"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#0E1720"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#F4E7C7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#005F9E"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#EEF2F4"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#005F9E"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#6F7E86"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#1282C6"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#005F9E"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#F4E7C7"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#005F9E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#F4E7C7"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#005F9E"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#6F7E86",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#EEF2F4"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#6F7E86",
        "fontStyle": "italic"
      }
    }
  ]
}