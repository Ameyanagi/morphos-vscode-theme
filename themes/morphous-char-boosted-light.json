    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#0F1A23"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
