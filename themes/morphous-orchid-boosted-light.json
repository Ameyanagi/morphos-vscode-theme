    "terminal.ansiRed": "#765F19",
    "terminal.ansiGreen": "#93255E",
    "terminal.ansiYellow": "#A32974",
    "terminal.ansiBlue": "#368321",
    "terminal.ansiMagenta": "#765F19",
    "terminal.ansiCyan": "#A32974",
    "terminal.ansiWhite": "#2b1726",
