    "terminal.ansiYellow": "#c7923a",
    "terminal.ansiBlue": "#8a8f68",
    "terminal.ansiMagenta": "#f6ead3",
    "terminal.ansiCyan": "#c7923a",
    "terminal.ansiWhite": "#ead5ad",
