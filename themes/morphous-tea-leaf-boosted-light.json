      ],
      "settings": {
        "foreground": "#218362"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#D7EBC8",
        "fontStyle": "italic"
