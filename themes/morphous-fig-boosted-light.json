    "activityBar.inactiveForeground": "#22131d60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#932572",
    "activityBarBadge.foreground": "#FEF9F6",
    "statusBar.background": "#FEF9F6",
    "statusBar.foreground": "#22131d",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FEF9F6",
    "titleBar.activeBackground": "#FEF9F6",
    "titleBar.activeForeground": "#22131d",
    "titleBar.inactiveBackground": "#FEF9F6",
    "titleBar.inactiveForeground": "#22131d60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F4E7DCaa",
    "tab.activeBackground": "#FEF9F6",
    "tab.activeForeground": "#22131d",
    "tab.inactiveBackground": "#FEF9F660",
    "tab.inactiveForeground": "#22131d80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#932572",
    "list.activeSelectionBackground": "#93257230",
    "list.activeSelectionForeground": "#22131d",
    "list.hoverBackground": "#F4E7DC40",
    "list.hoverForeground": "#22131d",
    "list.inactiveSelectionBackground": "#93257215",
    "list.inactiveSelectionForeground": "#22131d",
    "list.highlightForeground": "#932572",
    "terminal.background": "#FEF9F6",
    "terminal.foreground": "#22131d",
    "terminal.ansiBlack": "#22131d",
    "terminal.ansiRed": "#397619",
    "terminal.ansiGreen": "#932572",
    "terminal.ansiYellow": "#A37429",
    "terminal.ansiBlue": "#83212C",
    "terminal.ansiMagenta": "#397619",
    "terminal.ansiCyan": "#A37429",
    "terminal.ansiWhite": "#22131d",
    "input.background": "#F4E7DC",
    "input.foreground": "#22131d",
    "input.border": "#00000015",
    "input.placeholderForeground": "#22131d60",
    "button.background": "#932572",
    "button.foreground": "#FEF9F6",
    "button.hoverBackground": "#932572dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7d9b62",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#83212C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#83212C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#932572"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A37429"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#397619"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#22131d"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#22131d"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#22131ddd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#22131d80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#22131d"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A37429",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#932572"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#83212C"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#932572"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#7d9b62"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#397619"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#932572"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A37429"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#932572",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A37429"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#932572"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#7d9b62",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#83212C"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#7d9b62",
        "fontStyle": "italic"
      }
    }
  ]
}