    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#1D5B34",
    "terminal.ansiYellow": "#A6C747",
    "terminal.ansiBlue": "#D9EFE7",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#A6C747",
    "terminal.ansiWhite": "#F3EFE4",
