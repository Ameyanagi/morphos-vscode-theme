    "activityBar.inactiveForeground": "#382F2460",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#936E25",
    "activityBarBadge.foreground": "#FCFCFC",
    "statusBar.background": "#FCFCFC",
    "statusBar.foreground": "#382F24",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#FCFCFC",
    "titleBar.activeBackground": "#FCFCFC",
    "titleBar.activeForeground": "#382F24",
    "titleBar.inactiveBackground": "#FCFCFC",
    "titleBar.inactiveForeground": "#382F2460",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#F9F8F6aa",
    "tab.activeBackground": "#FCFCFC",
    "tab.activeForeground": "#382F24",
    "tab.inactiveBackground": "#FCFCFC60",
    "tab.inactiveForeground": "#382F2480",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#936E25",
    "list.activeSelectionBackground": "#936E2530",
    "list.activeSelectionForeground": "#382F24",
    "list.hoverBackground": "#F9F8F640",
    "list.hoverForeground": "#382F24",
    "list.inactiveSelectionBackground": "#936E2515",
    "list.inactiveSelectionForeground": "#382F24",
    "list.highlightForeground": "#936E25",
    "terminal.background": "#FCFCFC",
    "terminal.foreground": "#382F24",
    "terminal.ansiBlack": "#382F24",
    "terminal.ansiRed": "#5F1976",
    "terminal.ansiGreen": "#936E25",
    "terminal.ansiYellow": "#A38129",
    "terminal.ansiBlue": "#218341",
    "terminal.ansiMagenta": "#5F1976",
    "terminal.ansiCyan": "#A38129",
    "terminal.ansiWhite": "#382F24",
    "input.background": "#F9F8F6",
    "input.foreground": "#382F24",
    "input.border": "#00000015",
    "input.placeholderForeground": "#382F2460",
    "button.background": "#936E25",
    "button.foreground": "#FCFCFC",
    "button.hoverBackground": "#936E25dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#E7E5DF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#218341",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#218341",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#936E25"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#A38129"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#382F24"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#382F24"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#382F24dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#382F2480"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#382F24"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#A38129",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#936E25"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#218341"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#936E25"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#E7E5DF"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#5F1976"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#936E25"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#A38129"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#936E25",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A38129"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#936E25"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#E7E5DF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#218341"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#E7E5DF",
        "fontStyle": "italic"
      }
    }
  ]
}