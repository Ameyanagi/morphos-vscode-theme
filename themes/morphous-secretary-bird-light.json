    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#d0c7ac80",
    "sideBarSectionHeader.foreground": "#22201d",
    "sideBarTitle.foreground": "#181716",
    "activityBar.background": "#f7f4ea",
    "activityBar.foreground": "#181716",
    "activityBar.inactiveForeground": "#22201d60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#181716",
    "activityBarBadge.foreground": "#f7f4ea",
    "statusBar.background": "#f7f4ea",
    "statusBar.foreground": "#22201d",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#f7f4ea",
    "titleBar.activeBackground": "#f7f4ea",
    "titleBar.activeForeground": "#22201d",
    "titleBar.inactiveBackground": "#f7f4ea",
    "titleBar.inactiveForeground": "#22201d60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#d0c7acaa",
    "tab.activeBackground": "#f7f4ea",
    "tab.activeForeground": "#22201d",
    "tab.inactiveBackground": "#f7f4ea60",
    "tab.inactiveForeground": "#22201d80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#181716",
    "list.activeSelectionBackground": "#18171630",
    "list.activeSelectionForeground": "#22201d",
    "list.hoverBackground": "#d0c7ac40",
    "list.hoverForeground": "#22201d",
    "list.inactiveSelectionBackground": "#18171615",
    "list.inactiveSelectionForeground": "#22201d",
    "list.highlightForeground": "#181716",
    "terminal.background": "#f7f4ea",
    "terminal.foreground": "#22201d",
    "terminal.ansiBlack": "#22201d",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#181716",
    "terminal.ansiYellow": "#f27a21",
    "terminal.ansiBlue": "#d7d9d4",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#f27a21",
    "terminal.ansiWhite": "#22201d",
    "input.background": "#d0c7ac",
    "input.foreground": "#22201d",
    "input.border": "#00000015",
    "input.placeholderForeground": "#22201d60",
    "button.background": "#181716",
    "button.foreground": "#f7f4ea",
    "button.hoverBackground": "#181716dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a5a66d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#d7d9d4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d7d9d4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#181716"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#f27a21"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#22201d"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#22201d"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#22201ddd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#22201d80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#22201d"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#f27a21",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#181716"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#d7d9d4"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#181716"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#a5a66d"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#181716"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#f27a21"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#181716",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#f27a21"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#181716"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#a5a66d",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#d7d9d4"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#a5a66d",
        "fontStyle": "italic"
      }
    }
  ]
}