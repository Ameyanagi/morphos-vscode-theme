{
  "name": "Morphous Scarlet Macaw / Parrot (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#e1261c",
    "foreground": "#151820",
    "widget.border": "#00000015",
    "selection.background": "#1357c825",
    "editor.background": "#fff2d6",
    "editor.foreground": "#151820",
    "editor.lineHighlightBackground": "#FBF7F050",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#e1261c",
    "editor.selectionBackground": "#1357c825",
    "editor.inactiveSelectionBackground": "#1357c82580",
    "editorLineNumber.foreground": "#2f6f3e80",
    "editorLineNumber.activeForeground": "#e1261c",
    "sideBar.background": "#FBF7F0",
    "sideBar.foreground": "#151820",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FBF7F080",
    "sideBarSectionHeader.foreground": "#151820",
    "sideBarTitle.foreground": "#e1261c",
    "activityBar.background": "#fff2d6",
    "activityBar.foreground": "#e1261c",
    "activityBar.inactiveForeground": "#15182060",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#e1261c",
    "activityBarBadge.foreground": "#fff2d6",
    "statusBar.background": "#fff2d6",
    "statusBar.foreground": "#151820",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#fff2d6",
    "titleBar.activeBackground": "#fff2d6",
    "titleBar.activeForeground": "#151820",
    "titleBar.inactiveBackground": "#fff2d6",
    "titleBar.inactiveForeground": "#15182060",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FBF7F0aa",
    "tab.activeBackground": "#fff2d6",
    "tab.activeForeground": "#151820",
    "tab.inactiveBackground": "#fff2d660",
    "tab.inactiveForeground": "#15182080",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#e1261c",
    "list.activeSelectionBackground": "#e1261c30",
    "list.activeSelectionForeground": "#151820",
    "list.hoverBackground": "#FBF7F040",
    "list.hoverForeground": "#151820",
    "list.inactiveSelectionBackground": "#e1261c15",
    "list.inactiveSelectionForeground": "#151820",
    "list.highlightForeground": "#e1261c",
    "terminal.background": "#fff2d6",
    "terminal.foreground": "#151820",
    "terminal.ansiBlack": "#151820",
    "terminal.ansiRed": "#f8c72e",
    "terminal.ansiGreen": "#e1261c",
    "terminal.ansiYellow": "#008f5a",
    "terminal.ansiBlue": "#1357c8",
    "terminal.ansiMagenta": "#f8c72e",
    "terminal.ansiCyan": "#008f5a",
    "terminal.ansiWhite": "#151820",
    "input.background": "#FBF7F0",
    "input.foreground": "#151820",
    "input.border": "#00000015",
    "input.placeholderForeground": "#15182060",
    "button.background": "#e1261c",
    "button.foreground": "#fff2d6",
    "button.hoverBackground": "#e1261cdd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#2f6f3e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#1357c8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1357c8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#e1261c"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#008f5a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#f8c72e"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#151820"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#151820"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#151820dd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#15182080"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#151820"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#008f5a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#e1261c"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#1357c8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#e1261c"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#2f6f3e"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#f8c72e"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#e1261c"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#008f5a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#e1261c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#008f5a"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#e1261c"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#2f6f3e",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#1357c8"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#2f6f3e",
        "fontStyle": "italic"
      }
    }
  ]
}