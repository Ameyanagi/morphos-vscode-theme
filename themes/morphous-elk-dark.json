    "terminal.ansiYellow": "#5E884C",
    "terminal.ansiBlue": "#E6DED2",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#5E884C",
    "terminal.ansiWhite": "#FAF7F2",
