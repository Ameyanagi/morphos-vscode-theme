    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFFFF780",
    "sideBarSectionHeader.foreground": "#172006",
    "sideBarTitle.foreground": "#7FAE1F",
    "activityBar.background": "#FAF9ED",
