    "terminal.ansiYellow": "#297EA3",
    "terminal.ansiBlue": "#628321",
    "terminal.ansiMagenta": "#763D19",
    "terminal.ansiCyan": "#297EA3",
    "terminal.ansiWhite": "#231c18",
