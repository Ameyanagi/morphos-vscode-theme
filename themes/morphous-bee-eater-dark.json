        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#1aa6b7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#2f8f5b"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#f2c94c"
      }
