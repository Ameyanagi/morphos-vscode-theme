    "activityBar.inactiveForeground": "#ECEDE760",
    "activityBar.border": "#ffffff15",
    "activityBarBadge.background": "#67E9B5",
    "activityBarBadge.foreground": "#0A1F17",
    "statusBar.background": "#0A1F17",
    "statusBar.foreground": "#ECEDE7",
    "statusBar.border": "#ffffff15",
    "statusBar.noFolderBackground": "#0A1F17",
    "titleBar.activeBackground": "#0A1F17",
    "titleBar.activeForeground": "#ECEDE7",
    "titleBar.inactiveBackground": "#0A1F17",
    "titleBar.inactiveForeground": "#ECEDE760",
    "titleBar.border": "#ffffff15",
    "editorGroupHeader.tabsBackground": "#0A1F17dd",
    "tab.activeBackground": "#0A1F17",
    "tab.activeForeground": "#ECEDE7",
    "tab.inactiveBackground": "#0A0A0A60",
    "tab.inactiveForeground": "#ECEDE780",
    "tab.border": "#ffffff15",
    "tab.activeBorderTop": "#67E9B5",
    "list.activeSelectionBackground": "#67E9B530",
    "list.activeSelectionForeground": "#ECEDE7",
    "list.hoverBackground": "#0A0A0A40",
