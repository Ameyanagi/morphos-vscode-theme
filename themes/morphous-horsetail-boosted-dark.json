    "terminal.background": "#0A1F17",
    "terminal.foreground": "#ECEDE7",
    "terminal.ansiBlack": "#0A1F17",
    "terminal.ansiRed": "#D683F1",
    "terminal.ansiGreen": "#67E9B5",
    "terminal.ansiYellow": "#6BE755",
    "terminal.ansiBlue": "#79EC8E",
    "terminal.ansiMagenta": "#D683F1",
    "terminal.ansiCyan": "#6BE755",
    "terminal.ansiWhite": "#ECEDE7",
    "input.background": "#0A0A0A",
    "input.foreground": "#ECEDE7",
    "input.border": "#ffffff15",
    "input.placeholderForeground": "#ECEDE760",
    "button.background": "#67E9B5",
    "button.foreground": "#0A1F17",
    "button.hoverBackground": "#67E9B5dd"
