      "settings": {
        "foreground": "#E9677B"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#EC7988"
      }
    },
    {
      "scope": [
