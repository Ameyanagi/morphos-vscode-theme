    "terminal.ansiRed": "#e7b45b",
    "terminal.ansiGreen": "#c9643d",
    "terminal.ansiYellow": "#64a9cf",
    "terminal.ansiBlue": "#d89a3d",
    "terminal.ansiMagenta": "#e7b45b",
    "terminal.ansiCyan": "#64a9cf",
    "terminal.ansiWhite": "#f7e4c3",
