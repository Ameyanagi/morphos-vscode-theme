        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#6f9fb2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#7f9f76"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#b6c99a"
      }
