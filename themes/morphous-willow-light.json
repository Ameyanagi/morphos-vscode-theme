        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#26302b"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#26302bdd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#26302b80"
      }
    },
    {
      "scope": [
        "keyword.operator"
