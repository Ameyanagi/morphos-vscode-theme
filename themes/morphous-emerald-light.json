    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#006b45",
    "activityBarBadge.foreground": "#fbf7ec",
    "statusBar.background": "#fbf7ec",
    "statusBar.foreground": "#080c0a",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#fbf7ec",
    "titleBar.activeBackground": "#fbf7ec",
    "titleBar.activeForeground": "#080c0a",
    "titleBar.inactiveBackground": "#fbf7ec",
    "titleBar.inactiveForeground": "#080c0a60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#f1e5c8aa",
    "tab.activeBackground": "#fbf7ec",
    "tab.activeForeground": "#080c0a",
    "tab.inactiveBackground": "#fbf7ec60",
    "tab.inactiveForeground": "#080c0a80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#006b45",
    "list.activeSelectionBackground": "#006b4530",
    "list.activeSelectionForeground": "#080c0a",
    "list.hoverBackground": "#f1e5c840",
    "list.hoverForeground": "#080c0a",
    "list.inactiveSelectionBackground": "#006b4515",
    "list.inactiveSelectionForeground": "#080c0a",
    "list.highlightForeground": "#006b45",
    "terminal.background": "#fbf7ec",
    "terminal.foreground": "#080c0a",
    "terminal.ansiBlack": "#080c0a",
    "terminal.ansiRed": "#c06bdc",
    "terminal.ansiGreen": "#006b45",
    "terminal.ansiYellow": "#86e7ef",
    "terminal.ansiBlue": "#7c5cff",
    "terminal.ansiMagenta": "#c06bdc",
    "terminal.ansiCyan": "#86e7ef",
    "terminal.ansiWhite": "#080c0a",
    "input.background": "#f1e5c8",
    "input.foreground": "#080c0a",
    "input.border": "#00000015",
    "input.placeholderForeground": "#080c0a60",
    "button.background": "#006b45",
    "button.foreground": "#fbf7ec",
    "button.hoverBackground": "#006b45dd"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#28302c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#7c5cff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7c5cff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#006b45"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#86e7ef"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#080c0a"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#080c0a"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#080c0add",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#080c0a80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#080c0a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#86e7ef",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#006b45"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#006b45"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#28302c"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#c06bdc"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#006b45"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#86e7ef"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#006b45",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#86e7ef"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#006b45"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#28302c",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#7c5cff"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#28302c",
        "fontStyle": "italic"
      }
    }
  ]
}