    "editor.inactiveSelectionBackground": "#0E7C762580",
    "editorLineNumber.foreground": "#B7CFCF80",
    "editorLineNumber.activeForeground": "#0B5F5A",
    "sideBar.background": "#FFFFFF",
    "sideBar.foreground": "#062F2E",
    "sideBar.border": "#00000015",
    "sideBarSectionHeader.background": "#FFFFFF80",
    "sideBarSectionHeader.foreground": "#062F2E",
    "sideBarTitle.foreground": "#0B5F5A",
    "activityBar.background": "#F7FBFB",
    "activityBar.foreground": "#0B5F5A",
    "activityBar.inactiveForeground": "#062F2E60",
    "activityBar.border": "#00000015",
    "activityBarBadge.background": "#0B5F5A",
    "activityBarBadge.foreground": "#F7FBFB",
    "statusBar.background": "#F7FBFB",
    "statusBar.foreground": "#062F2E",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7FBFB",
    "titleBar.activeBackground": "#F7FBFB",
    "titleBar.activeForeground": "#062F2E",
    "titleBar.inactiveBackground": "#F7FBFB",
    "titleBar.inactiveForeground": "#062F2E60",
    "titleBar.border": "#00000015",
    "editorGroupHeader.tabsBackground": "#FFFFFFaa",
    "tab.activeBackground": "#F7FBFB",
    "tab.activeForeground": "#062F2E",
    "tab.inactiveBackground": "#F7FBFB60",
    "tab.inactiveForeground": "#062F2E80",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#0B5F5A",
    "list.activeSelectionBackground": "#0B5F5A30",
    "list.activeSelectionForeground": "#062F2E",
    "list.hoverBackground": "#FFFFFF40",
    "list.hoverForeground": "#062F2E",
    "list.inactiveSelectionBackground": "#0B5F5A15",
    "list.inactiveSelectionForeground": "#062F2E",
    "list.highlightForeground": "#0B5F5A",
    "terminal.background": "#F7FBFB",
    "terminal.foreground": "#062F2E",
    "terminal.ansiBlack": "#062F2E",
    "terminal.ansiRed": "#137A6C",
    "terminal.ansiGreen": "#0B5F5A",
    "terminal.ansiYellow": "#8FDDE6",
    "terminal.ansiBlue": "#0E7C76",
    "terminal.ansiMagenta": "#137A6C",
    "terminal.ansiCyan": "#8FDDE6",
    "terminal.ansiWhite": "#062F2E",
    "input.background": "#FFFFFF",
    "input.foreground": "#062F2E",
    "input.border": "#00000015",
    "input.placeholderForeground": "#062F2E60",
    "button.background": "#0B5F5A",
    "button.foreground": "#F7FBFB",
    "button.hoverBackground": "#0B5F5Add"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B7CFCF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#0E7C76",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#0E7C76",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#0B5F5A"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#8FDDE6"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#137A6C"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#062F2E"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#062F2E"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#062F2Edd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#062F2E80"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#062F2E"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.type",
        "support.class",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#8FDDE6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#0B5F5A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#0E7C76"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#0B5F5A"
      }
    },
    {
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#B7CFCF"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#137A6C"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#0B5F5A"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#8FDDE6"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#0B5F5A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#8FDDE6"
      }
    },
    {
      "scope": [
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#0B5F5A"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#B7CFCF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#0E7C76"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#B7CFCF",
        "fontStyle": "italic"
      }
    }
  ]
}