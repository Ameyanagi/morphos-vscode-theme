    "terminal.ansiBlack": "#121416",
    "terminal.ansiRed": "#6D8F5A",
    "terminal.ansiGreen": "#8A5B37",
    "terminal.ansiYellow": "#3E7A4A",
    "terminal.ansiBlue": "#C69A6B",
    "terminal.ansiMagenta": "#6D8F5A",
    "terminal.ansiCyan": "#3E7A4A",
    "terminal.ansiWhite": "#121416",
    "input.background": "#E6D7C2",
    "input.foreground": "#121416",
    "input.border": "#00000015",
