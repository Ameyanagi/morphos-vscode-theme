    "statusBar.background": "#F7F4ED",
    "statusBar.foreground": "#121416",
    "statusBar.border": "#00000015",
    "statusBar.noFolderBackground": "#F7F4ED",
    "titleBar.activeBackground": "#F7F4ED",
