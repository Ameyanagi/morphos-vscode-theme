    "tab.activeForeground": "#121416",
    "tab.inactiveBackground": "#F7F4ED60",
    "tab.inactiveForeground": "#12141680",
    "tab.border": "#00000015",
    "tab.activeBorderTop": "#8A5B37",
    "list.activeSelectionBackground": "#8A5B3730",
    "list.activeSelectionForeground": "#121416",
